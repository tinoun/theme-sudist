,"mobile_height":"custom","mobile_custom_height":500,"desktop_radius_selector":"d-border-radius-bottom","mobile_radius_selector":"m-border-radius-bottom","top_space_desktop":0,"bottom_space_desktop":0,"top_space_mobile":0,"bottom_space_mobile":0}},"histoire_timeline_KfRNCF":{"type":"histoire-timeline","blocks":{"milestone_EAbUmW":{"type":"milestone","settings":{"year":"étape 1","image":"shopify:\/\/shop_images\/fleurs-de-coton-bio_2545b9a5-ac05-42f1-8346-106a5880b030.jpg","title":"Sélection des matières","text":"<p>Un t-shirt classique est généralement conçu dans un coton d’environ 150 g\/m².<br\/><br\/>Chez SUDIST, nous avons fait le choix d’un coton plus épais, en 220 g\/m², afin d’offrir un t-shirt plus résistant, plus durable et mieux structuré, capable de tenir des années dans le temps.<br\/><br\/><\/p>"}},"milestone_9ULtYV":{"type":"milestone","settings":{"year":"étape 2","image":"shopify:\/\/shop_images\/2_8f457c7c-2762-4bc6-bc61-13c2172978eb.jpg","title":"Patronnage & coupe","text":"<p>Les rouleaux de tissu sont découpés à l’atelier selon nos propres patrons.<br\/><br\/>Cette étape permet de garantir une coupe régulière, une meilleure tenue du vêtement et une cohérence sur l’ensemble des tailles. Les tshirts sudist sont ainsi uniques !<\/p>"}},"milestone_FyAB76":{"type":"milestone","settings":{"year":"étape 3","image":"shopify:\/\/shop_images\/t-shirt-atelier.jpg","title":"Confection","text":"<p>Les différentes pièces du t-shirt sont assemblées par des couturiers qualifiés.<br\/><br\/>La confection est réalisée dans notre atelier en Provence ou, pour certaines productions destinées aux professionnels, dans notre atelier partenaire au Portugal, selon les volumes et les besoins spécifiques. Un tshirt prend en moyenne 15 minutes pour être assemblé.<\/p>"}},"milestone_R9HNiM":{"type":"milestone","settings":{"year":"étape 4","image":"shopify:\/\/shop_images\/broderie.png","title":"Personnalisation","text":"<p>Selon le modèle, le visuel est brodé ou imprimé directement à l’atelier, uniquement après validation de la commande.<br\/><br\/>Cette étape réalisée à la demande permet d’éviter toute surproduction et de garantir un marquage précis, réalisé spécifiquement pour chaque t-shirt.<\/p>"}},"milestone_eDeQtP":{"type":"milestone","settings":{"year":"2020","title":"Expédition","text":"<p>Chaque t-shirt est contrôlé individuellement avant expédition.<br\/><br\/>Les finitions, la coupe et le marquage sont vérifiés afin de garantir un produit conforme à nos standards avant d’être emballé et envoyé.<br\/><br\/><\/p>"}}},"block_order":["milestone_EAbUmW","milestone_9ULtYV","milestone_FyAB76","milestone_R9HNiM","milestone_eDeQtP"],"name":"Histoire - Timeline","settings":{"section_visibility":"always","color_scheme":"","section_background":"solid","section_container_width":"container","subheading":"","heading":"LA FABRICATION DE NOS VÊMENTS","markers_font":"accent-font","markers_text":"highlight-color","heading_size":"h2","seo_heading":"h2","description":"Découvrez toutes les étapes de la fabrication de nos vêtements de Provence","description_size":"text-large","heading_alignment":"center","btn_text":"","btn_url":"","button_size":"normal-button","button_style":"solid","top_space_desktop":70,"bottom_space_desktop":70,"top_space_mobile":40,"bottom_space_mobile":40}},"collapsible_Het8Ui":{"type":"collapsible","blocks":{"collapse_grid_TGVPF3":{"type":"collapse_grid","settings":{"collapsible_content_heading":"5 minutes & 6 000 points","collapsible_content_description":"<p>sont nécessaires pour broder une cigale, 8 minutes en incluant le temps de préparation du vêtement et du cadre.<\/p>"}},"collapse_grid_WcNier":{"type":"collapse_grid","settings":{"collapsible_content_heading":"140 degrés","collapsible_content_description":"<p>C'est la température minimale idéale pour une impression optimale de nos feuilles de transfert sur nos vêtements !<\/p>"}},"collapse_grid_e3xTzY":{"type":"collapse_grid","settings":{"collapsible_content_heading":"50 