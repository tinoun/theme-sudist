<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="robots" content="index, follow">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %}
        &ndash; tagged "{{ current_tags | join: ', ' }}"
      {%- endif -%}
      {%- if current_page != 1 %}
        &ndash; Page {{ current_page -}}
      {%- endif -%}
      {%- unless page_title contains shop.name %}
        &ndash; {{ shop.name -}}
      {%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {%- if localization.available_languages.size > 1 -%}
      {%- for language in localization.available_languages -%}
        <link rel="alternate" hreflang="{{ language.iso_code }}" href="{{ request.origin }}{{ routes.root_url }}{{ request.path }}{% if language.primary == false %}?locale={{ language.iso_code }}{% endif %}">
      {%- endfor -%}
      <link rel="alternate" hreflang="x-default" href="{{ request.origin }}{{ request.path }}">
    {%- endif -%}

    {{ content_for_header }}
    {% render 'context-style-variables' %}

    {%- comment -%}
    ============================================================
    OPTIMISATION CSS - Résolution du Render Blocking (240ms)
    ============================================================
    
    AVANT : Tous les CSS chargés en bloquant (450ms de blocage)
    APRÈS : CSS critiques inline + CSS non-critiques différés
    
    Gain attendu : -240ms de render blocking
    ============================================================
    {%- endcomment -%}

    {%- comment -%}
    ÉTAPE 1 : CSS CRITIQUES - Base + Theme (inline recommandé mais preload pour commencer)
    Ces CSS sont nécessaires pour le rendu initial
    {%- endcomment -%}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {%- comment -%}
    ÉTAPE 2 : CSS NON-CRITIQUES - Chargement différé avec preload
    Ces CSS peuvent être chargés après le rendu initial
    {%- endcomment -%}
    
    {%- comment -%} Swiper (carrousel) - Uniquement si utilisé sur la page {%- endcomment -%}
    <link rel="preload" as="style" href="{{ 'swiper-bundle.min.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}"></noscript>
    
    {%- comment -%} Animations - Non critique pour le premier rendu {%- endcomment -%}
    <link rel="preload" as="style" href="{{ 'animate.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="{{ 'animate.css' | asset_url }}"></noscript>
    
    {%- comment -%} Components - Peut être différé {%- endcomment -%}
    <link rel="preload" as="style" href="{{ 'component.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="{{ 'component.css' | asset_url }}"></noscript>

    {%- comment -%}
    ÉTAPE 3 : CSS CONDITIONNEL - Chargement uniquement sur pages spécifiques
    {%- endcomment -%}
    {%- if template contains 'account' or template contains 'customer' or template.name == 'login' -%}
      <link rel="preload" as="style" href="{{ 'account.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
      <noscript><link rel="stylesheet" href="{{ 'account.css' | asset_url }}"></noscript>
    {%- endif -%}

    {%- comment -%} Model Viewer - Déjà optimisé avec media="print" {%- endcomment -%}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >

    {%- comment -%}
    PRELOAD DES POLICES - Déjà bien optimisé
    {%- endcomment -%}
    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_heading_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_heading_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_accent_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_accent_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
    {%- endif -%}

    {%- if settings.predictive_search_enabled -%}
    {%- endif -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    {% render 'context-variables' %}
  </head>

  <body class="king" id="king-body">
    <a class="skip-to-content-link button" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    <div class="body-main form-input-{{ settings.form_inputs_height }}" id="king-body-main">
      {% sections 'header-group' %}
      <div class="pinned-content">
        <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
          {{ content_for_layout }}
        </main>
        {% sections 'footer-group' %}
      </div>
      {% sections 'overlay-group' %}
    </div>
    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    {% render 'popup',
      modal_name: 'localization-form',
      modal_position: 'center',
      modal_size: 'medium',
      popup_color_scheme: settings.popup_color_scheme
    %}
    {% render 'scroll-to-top' %}
   
 
<script>
  window.b2bCustomer = {
    loggedIn: {% if customer %}true{% else %}false{% endif %},
    email: "{{ customer.email | escape }}"
  };
  (function() {
    var loaded = false;
    function loadWidgets() {
      if (loaded) return;
      loaded = true;
      var chat = document.createElement('script');
      chat.src = 'https://sav-assistant-next.vercel.app/widget/chat.js';
      chat.dataset.server = 'https://sav-assistant-next.vercel.app';
      chat.dataset.brand = 'Sudist';
      document.body.appendChild(chat);
      var b2b = document.createElement('script');
      b2b.src = 'https://sav-assistant-next.vercel.app/widget/b2b-pricing.js';
      b2b.dataset.server = 'https://sav-assistant-next.vercel.app';
      document.body.appendChild(b2b);
    }
    setTimeout(loadWidgets, 3000);
    ['scroll', 'click', 'touchstart', 'mousemove'].forEach(function(evt) {
      document.addEventListener(evt, loadWidgets, { once: true, passive: true });
    });
  })();
</script>
  
</body>
</html>
