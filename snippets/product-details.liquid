{% comment %}
  currentVariant is coming from main-product
  product_form_id is coming from main-product
  
  FIX iOS VIDEO : Vidéos chargées directement avec playsinline + muted
{% endcomment %}
{% for block in section.blocks %}
  {% case block.type %}
    {% when 'query_form' %}
      {% liquid
        if share_block != true
          assign share_block = false
        endif
        assign help_block_heading = false
        if block.settings.help_with_share_icons == true
          assign with_share_icons = block.settings.help_with_share_icons
        else
          assign with_share_icons = false
        endif
      %}
      {%- liquid
        if block.settings.title != blank
          assign help_block_heading = true
          render 'product-query-form', block: block
        endif
      -%}
      {% capture queryForm %}  
        <product-query-form class="product--query-form"
        data-queryform="{{ block.id }}"
        id="product-query-form-{{ block.id }}"
        {{ block.shopify_attributes }}>
            <div class="product--query-hyperlink">
                <a href="/" class="product--query-form-title text-underline cursor-pointer">{{ block.settings.title }}</a>
            </div>
        </product-query-form>
      {% endcapture %}
    {% when 'social_sharing' %}
      {% liquid
        assign share_block = true
      %}
    {% when 'preorder_countdown' %}
      {% liquid
        assign has_preorder_countdown = true
      %}
  {% endcase %}
{% endfor %}

{% if pdp_layout_style == 'layout_2' %}
  <div
    class="container-fullwidth{% if section.settings.section_container_width == 'no-container' %} d-pl-0{% endif %} m-pl-0 m-pr-0"
  >
{% endif %}
<div
  class="product--wrapper {{ pdp_layout_style }} product-grid-{{ section.settings.images_views }}"
  data-product-layout="{{ pdp_layout_style }}"
>
  <div class="row no-gutters">
    {% liquid
      if pdp_layout_style == 'layout_1' or pdp_layout_style == 'layout_3'
        assign colpart = 'col-md-12 col-lg-12 col-xl-12'
      elsif pdp_layout_style == 'layout_2'
        assign colpart = 'col-md-7 col-lg-7 col-xl-8'
      endif

      if pdp_layout_style == 'layout_1'
        assign spaceBetween = 2
      elsif pdp_layout_style == 'layout_2' or pdp_layout_style == 'layout_3'
        assign spaceBetween = 2
      endif

      assign image_size = section.settings.image_ratio
      if image_size == 'landscape'
        assign imageRatio = '70%'
      elsif image_size == 'square'
        assign imageRatio = '100%'
      elsif image_size == 'portrait'
        assign imageRatio = '130%'
      elsif image_size == 'adpat_to_first_image'
        assign imageRatio = 1 | divided_by: product.featured_media.aspect_ratio | times: 100 | minus: 1 | append: '%'
      else
        assign imageRatio = 120 | append: '%'
      endif

      assign counter = 0
    %}
    <div class="col-12 col-sm-12 {{ colpart }}">
      {% if pdp_layout_style == 'layout_2' %}
        {% render 'media-thumbnails-gallery', product: product, section: section, currentVariant: currentVariant %}
      {% else %}
        <product-media
          {% if pdp_layout_style == 'layout_2' %}
            data-media-layout="thumbnails"
          {% endif %}
          data-id="{{ section.id }}-{{ product.id }}"
        >
          <div class="main--product-image-wrapper">
            {% if product != blank %}
              <swiper-content
                class="main--product-media"
                data-id="{{ section.id }}-{{ product.id }}"
                data-resize="false"
                {% if pdp_layout_style == 'layout_2' %}
                  data-thumbs="true"
                {% endif %}
                data-product-slider="product-{{ section.id }}-{{ product.id }}"
              >
                <div
                  class="main--product-image-slider-outer swiper"
                  data-swiper-main
                  data-swiper='
                    {
                        "loop": {% if product.media.size > 1 %}true{% else %}false{% endif %},
                        "speed": {% if section.settings.autoplay %}6000{% else %}800{% endif %},
                         "slidesPerView": {%- if pdp_layout_style == 'layout_1' -%}1.2{%- elsif pdp_layout_style == 'layout_3' -%}1.2{%- else -%}"auto"{%- endif -%},
                        "spaceBetween": {{ spaceBetween }},
                        "navigation": {
                            "enabled": false,
                            "nextEl": ".swiper-button-next-{{ section.id }}",
                            "prevEl": ".swiper-button-prev-{{ section.id }}"
                        },
                        {% if section.settings.autoplay %}
                        "autoplay":{
                          "delay":1,
                          "disableOnInteraction":false,
                          "pauseOnMouseEnter":false
                        },
                        {% endif %}
                        {% if product.media.size == 1 %}
                        "centeredSlides":true,
                        {% endif %}
                        "resizeObserver":true,
                        "breakpoints": {
                          "768": {
                          "slidesPerView": {%- if pdp_layout_style == 'layout_1' -%}{{ section.settings.images_views }}{%- elsif pdp_layout_style == 'layout_3' -%}{{ section.settings.images_views }}{%- else -%}"auto"{%- endif -%},
                              "navigation": {
                                "enabled": true,
                                "nextEl": ".swiper-button-next-{{ section.id }}",
                                "prevEl": ".swiper-button-prev-{{ section.id }}"
                            }
                          }
                        }
                    }
                  '
                  data-product-media="main-media-{{ section.id }}-{{ product.id }}"
                >
                  <div
                    class="main--product-image-slider{% if section.settings.autoplay %} swiper-autoplay{% endif %} swiper-wrapper is-slider pb-0"
                    data-main-product-slider=""
                  >
                    {% if product.media.size > 0 %}
                      {%- if product.selected_or_first_available_variant.featured_image != null -%}
                        {% liquid
                          if image_size == 'auto'
                            assign imageRatio = 1 | divided_by: product.selected_or_first_available_variant.featured_image.aspect_ratio | times: 100 | minus: 1 | append: '%'
                          endif
                        %}
                        {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}

                        {% capture product_images %} 
                          
                              <div class="main--product-item swiper-slide" data-media-id="{{ section.id }}-{{ featured_media.id }}">
                                <div class="main--product-img media-wrapper width-100 height-100">
                                  <media-zoom-button data-section="{{ section.id }}" data-index="{{ counter }}"></media-zoom-button>
                                  <div class="media" style="--image_ratio:{{ imageRatio }};">
                                   {{
                                      featured_media
                                      | image_url: width: 1946
                                      | image_tag:
                                        sizes: 'auto',
                                        widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
                                    }}
                                  </div>
                                </div>
                              </div>
                          
                          {% endcapture %}

                        {% if product.media.size == 1 and section.settings.slider_images_views == 'duplicates' %}
                          {% for i in (1..4) %}
                            {{ product_images }}
                          {% endfor %}
                        {% else %}
                          {{ product_images }}
                        {% endif %}
                      {% endif %}
                      {% for media in product.media %}
                        {% unless media.id == product.selected_or_first_available_variant.featured_media.id %}
                          {% assign counter = counter | plus: 1 %}
                          {% liquid
                            if image_size == 'auto'
                              assign imageRatio = 1 | divided_by: media.preview_image.aspect_ratio | times: 100 | minus: 1 | append: '%'
                            endif

                            if media.media_type == 'model'
                              assign imageRatio = '100' | append: '%'
                            endif
                          %}
                          {% capture product_images %} 
                          <div class="main--product-item swiper-slide" data-media-id="{{ section.id }}-{{ media.id }}">
                            <div class="main--product-img media-wrapper width-100 height-100">
                              <div class="media" style="--image_ratio:{{ imageRatio }};">
                                {% case media.media_type %}
                                  {% when 'image' %}
                                    {% if product.featured_media != blank %}
                                      <media-zoom-button
                                        data-section="{{ section.id }}"
                                        data-index="{% if product.selected_or_first_available_variant.featured_media!= blank %}{{ counter }}{% else %}{{ forloop.index0 }}{% endif %}"
                                      ></media-zoom-button>
                                      {{
                                        media
                                        | image_url: width: 1946
                                        | image_tag:
                                          sizes: 'auto',
                                          widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
                                      }}
                                    {% endif %}
                                  
                                  {%- when 'video' -%}
                                    {%- liquid
                                      if media.preview_image.aspect_ratio
                                        assign media_aspect_ratio = media.preview_image.aspect_ratio
                                      endif
                                    -%}
                                    
                                    {%- comment -%} 
                                      FIX iOS : Chargement direct de la vidéo (pas de template/deferred)
                                      avec playsinline et muted pour autoplay sur iOS
                                    {%- endcomment -%}
                                    <div class="product-video-wrapper" data-media-type="video" data-media-id="{{ media.id }}">
                                      {{
                                        media
                                        | media_tag:
                                          image_size: '2048x',
                                          loading: 'lazy',
                                          class: 'product-video no-js-hidden',
                                          autoplay: true,
                                          loop: true,
                                          controls: false,
                                          muted: true,
                                          preload: 'metadata',
                                          playsinline: true
                                      }}
                                    </div>

                                  {%- when 'external_video' -%}
                                    {% liquid
                                      assign videoUrl = media | external_video_url
                                      assign videoClass = 'youtube-video'
                                      if videoUrl contains 'vimeo'
                                        assign videoClass = 'vimeo-video'
                                      endif
                                    %}

                                    <div class="product-external-video-wrapper" data-media-type="external_video" data-media-id="{{ media.id }}">
                                      {{
                                        media
                                        | external_video_url: autoplay: false, loop: false, controls: true
                                        | external_video_tag: class: videoClass, loading: 'lazy'
                                      }}
                                    </div>

                                  {%- when 'model' -%}
                                    {%- liquid
                                      if media.preview_image.aspect_ratio
                                        assign media_aspect_ratio = media.preview_image.aspect_ratio
                                      endif
                                    -%}
                                    <product-model>
                                      {{
                                        media
                                        | model_viewer_tag:
                                          image_size: true,
                                          reveal: 'interaction',
                                          toggleable: true,
                                          data-model-id: media.id
                                      }}
                                      <button class="close-product-model hidden">
                                        <svg width="12" height="12" viewBox="0 0 22 22" fill="none">
                                          <path d="M21.7987 20.826L11.9721 10.9958L21.7987 1.16552C22.0561 0.899047 22.0561 0.476499 21.7987 0.20994C21.5349 -0.0632507 21.0997 -0.0708067 20.8266 0.193065L11 10.0233L1.17343 0.193149C0.907055 -0.0642582 0.484664 -0.0642582 0.218204 0.193149C-0.0548867 0.457021 -0.0624398 0.892415 0.201335 1.16561L10.0279 10.9958L0.201335 20.826C0.0724268 20.9549 1.71925e-08 21.1298 1.71925e-08 21.3122C-8.39964e-05 21.692 0.307751 21.9999 0.687425 22C0.869793 22.0002 1.04469 21.9276 1.17343 21.7984L11 11.9682L20.8266 21.7985C20.9553 21.9277 21.1303 22.0002 21.3127 22C21.4949 21.9999 21.6696 21.9275 21.7985 21.7987C22.0671 21.5301 22.0672 21.0946 21.7987 20.826Z" fill="currentColor"></path>
                                        </svg>
                                      </button>
                                      <button
                                        class="button button--full-width product__xr-button"
                                        type="button"
                                        aria-label="{{ 'products.product.xr_button_label' | t }}"
                                        data-shopify-xr
                                        data-shopify-model3d-id="{{ media.id }}"
                                        data-shopify-title="{{ product.title | escape }}"
                                        data-shopify-xr-hidden
                                      >
                                        {{ 'products.product.xr_button' | t }}
                                      </button>
                                    </product-model>
                                {% endcase %}
                              </div>
                            </div>
                          </div>
                        {% endcapture %}

                          {% if product.media.size == 1 and section.settings.slider_images_views == 'duplicates' %}
                            {% for i in (1..4) %}
                              {{ product_images }}
                            {% endfor %}
                          {% else %}
                            {{ product_images }}
                          {% endif %}
                        {% endunless %}
                      {% endfor %}
                    {% else %}
                      {% for i in (1..4) %}
                        <div class="main--product-item swiper-slide">
                          <div class="main--product-img media-wrapper width-100 height-100">
                            <div class="media" style="--image_ratio:100%">
                              {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                    {% endif %}
                  </div>
                  {% if section.settings.autoplay != true %}
                    {% if product.media.size > 1 or section.settings.slider_images_views == 'duplicates' %}
                      <div class="swiper--button-wrapper">
                        {% liquid
                          if settings.slilder_button_style == 'square'
                            assign btnIcon = 'curve-arrow'
                          else
                            assign btnIcon = 'arrow-icon'
                          endif
                        %}
                        <swiper-nav class="swiper-button-next swiper-button swiper-button-next-{{ section.id }} button-{{ settings.slilder_button_style }}">
                          {% render 'icons', icon: btnIcon %}
                        </swiper-nav>
                        <swiper-nav class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }} button-{{ settings.slilder_button_style }}">
                          {% render 'icons', icon: btnIcon %}
                        </swiper-nav>
                      </div>
                    {% endif %}
                  {% endif %}
                </div>
              </swiper-content>
            {% else %}
              <div class="main--product-media">
                <div class="main--product-image">
                  <div class="main--product-image-slider">
                    <div class="main--product-item">
                      <div class="main--product-img media-wrapper width-100 height-100">
                        <div class="media" style="--image_ratio:100%">
                          {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </product-media>
      {% endif %}
    </div>
    {% if pdp_layout_style == 'layout_1' %}
      <product-set
        id="main--product-info-{{ section.id }}"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        class="d-block main--product-info-container width-100"
      >
        {% liquid
          if section.settings.first_layout_height == 'screen_wise'
            assign layoutHeightClass = 'content--height-screen'
          elsif section.settings.first_layout_height == 'section_wise'
            assign layoutHeightClass = 'content--height-section'
          endif
        %}
        <div class="main--product-content-wrapper {{ layoutHeightClass }}">
          <div class="main--product-content">
            <div class="main--product-content-inner">
              {% render 'product-set',
                section: section,
                product: product,
                currentVariant: currentVariant,
                product_form_id: product_form_id,
                source: source,
                pdp_layout_style: pdp_layout_style
              %}
            </div>
          </div>
        </div>
      </product-set>
    {% elsif pdp_layout_style == 'layout_2' %}
      <div class="col-12 col-sm-12 col-md-5 col-lg-5 col-xl-4">
        <product-set
          id="main--product-info-{{ section.id }}"
          data-section="{{ section.id }}"
          data-url="{{ product.url }}"
          class="d-block main--product-info-container width-100"
        >
          <div class="product-info-details">
            {% render 'product-set',
              section: section,
              product: product,
              currentVariant: currentVariant,
              product_form_id: product_form_id,
              source: source,
              pdp_layout_style: pdp_layout_style
            %}
          </div>
        </product-set>
      </div>
    {% endif %}
  </div>
  {% if pdp_layout_style == 'layout_3' %}
    {% render 'sticky-add-to-cart', product: product, section: section, currentVariant: currentVariant %}
  {% endif %}

  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'query_form' %}
        {% liquid
          assign help_block_heading = false
          if block.settings.title != blank
            assign help_block_heading = true
          endif
        %}
        {% capture queryForm %}  
            <product-query-form class="product--query-form"
            data-queryform="{{ block.id }}"
            id="product-query-form-{{ block.id }}"
            {{ block.shopify_attributes }}>
                <div class="product--query-hyperlink">
                  <a href="/product-query-form" class="product--query-form-title text-underline cursor-pointer">{{ block.settings.title }}</a>
                </div>
            </product-query-form>
        {% endcapture %}
        {% liquid
          assign with_share_icons = false
          if block.settings.help_with_share_icons == true
            assign with_share_icons = block.settings.help_with_share_icons
          endif
        %}
      {%- when 'icon-with-text' -%}
        {% capture icontext %} 
          <div class="custom-icons-box">
          <ul class="list-inline custom-icons-list">
          {% if block.settings.text_1 != blank %} 
            <li class="custom-icons-item">
              <span class="custom-icons-icon small-icon">
                {% if block.settings.icon_1 != blank %}
                  {% render 'lazy-image', image: block.settings.icon_1 %}
                {% else %}
                  {% render 'icons', icon: block.settings.icon_list_1 %}
                {% endif %}
              </span>
              {% if block.settings.text_1 != blank %}
                <p class="custom-icons-text">{{ block.settings.text_1 }}</p>
              {% endif %}
            </li>
          {% endif %}
          {% if block.settings.text_2 != blank %} 
            <li class="custom-icons-item">
              <span class="custom-icons-icon small-icon">
                {% if block.settings.icon_2 != blank %}
                  {% render 'lazy-image', image: block.settings.icon_2 %}
                {% else %}
                  {% render 'icons', icon: block.settings.icon_list_2 %}
                {% endif %}
              </span>
              {% if block.settings.text_2 != blank %}
                <p class="custom-icons-text">{{ block.settings.text_2 }}</p>
              {% endif %}
            </li>
          {% endif %}
          {% if block.settings.text_3 != blank %} 
            <li class="custom-icons-item">
              <span class="custom-icons-icon small-icon">
                {% if block.settings.icon_3 != blank %}
                  {% render 'lazy-image', image: block.settings.icon_3 %}
                {% else %}
                  {% render 'icons', icon: block.settings.icon_list_3 %}
                {% endif %}
              </span>
              {% if block.settings.text_3 != blank %}
                <p class="custom-icons-text">{{ block.settings.text_3 }}</p>
              {% endif %}
            </li>
          {% endif %}
          </ul>
          </div>
        {% endcapture %}

      {% when 'payment_icons' %}
        {% capture payment_icons %}
              {%  liquid 
              assign enabled_payment_types =  shop.enabled_payment_types 
              %}
              {%- unless enabled_payment_types == empty -%}
                <div class="product-payment-icons">
              {% render 'payment-icons' %}
                </div>
              {%- endunless -%}
        {% endcapture %}

      {% when 'complementary_products' %}
        {% capture complementary_products %} 
          <product-recommendations
              class="d-block complementary-products no-js-hidden"
              data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.products_count }}&intent=complementary"
            >
          {% render 'product-recommendation',
            product_list: recommendations.products,
            limit: block.settings.products_count,
            block: block,
            pdp_layout_style: pdp_layout_style
          %}
          </product-recommendations>
        {% endcapture %}
      {% when 'custom_liquid' %}
        {% capture custom_liquid %} 
          {% if block.settings.custom_liquid != blank %}
            <div class="product--custom-liquid" id="product--custom-text-{{ section.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
            </div>
        {% endif %}
        {% endcapture %}
      
      {% when 'preorder_countdown' %}
        {% capture preorder_countdown_block %}
          {% render 'preorder-countdown', block: block %}
        {% endcapture %}
    {% endcase %}
  {% endfor %}

  {% capture product_layout_3_content %} 
    {% for block in section.blocks %}
      {% case block.type %}
      {%- when '@app' -%}
        <div class="product-app-block">
          {% render block %}
        </div>
        
        {% when 'title' %}
          {%- comment -%}
          ==========================================
          TITRE SUPPRIMÉ ICI POUR LAYOUT_3
          Le H1 est maintenant dans sticky-add-to-cart.liquid
          pour éviter le doublon en mobile
          ==========================================
          {%- endcomment -%}
    
          {% when 'custom_text' %}
            {% if block.settings.text != blank %}
              <div
                class="product--description {{ block.settings.text_description_size }}"
                id="product--custom-text-{{ section.id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% when 'custom_liquid' %}   
            {{ custom_liquid }}
          {% when 'pickup_availability' %}
              {%- assign pickup_availabilities = currentVariant.store_availabilities | where: 'pick_up_enabled', true -%}
              <div class="pickup-info" data-main-pickup-info="{{ section.id }}-{{ product.id }}">
                <pickup-info
                  class="product--pickup-availability d-block"
                  id="pickup-availability-{{ section.id }}-{{ product.id }}"
                  data-root-url="{{ routes.root_url }}"
                  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  data-has-only-default-variant="{{ product.has_only_default_variant }}"
                  data-section-scheme="{{ section.settings.color_scheme }}"
                  {% if currentVariant.available and pickup_availabilities.size > 0 %}
                    available
                  {% endif %}
                  data-pickup-availability
                  {{ block.shopify_attributes }}
                >
                  {% render 'pickup-availability', product: product, currentVariant: currentVariant %}
                </pickup-info>
              </div>
        {% when 'payment_icons' %}
          {{ payment_icons }}
        {% when 'query_form' %}
          
          {% if with_share_icons == true and share_block == false and help_block_heading == true %}
            <div class="product-query-form">
              {{ queryForm }}
            </div>
          {% endif %}
          {% if with_share_icons == false and help_block_heading == true%}
            <div class="product-query-form">
              {{ queryForm }}
            </div>
          {% endif %}

        {% when 'social_sharing' %}
          {% if settings.share_facebook or settings.tweet_twitter or settings.pin_pinterest or settings.share_telegram  or settings.share_email or with_share_icons == true
            and help_block_heading == true %}
            <div class="product--social-share{% if with_share_icons == true %} social--share-with-help{% endif %}">
              {% assign share_url = request.origin | append: product.url %}
        
              {% if settings.share_facebook or settings.tweet_twitter or settings.pin_pinterest or settings.share_telegram or settings.share_email %}
                <div class="product--share-icons">
                    {% render 'social-share', block: block, share_link: share_url, product: product %}
                </div>
              {% endif %}
              {% if help_block_heading == true and with_share_icons == true %}
                    {{ queryForm }}
              {% endif %}
            </div>
          {% endif %}

        {%- when 'icon-with-text' -%}
          {{ icontext }}
        
        {% when 'preorder_countdown' %}
          {{ preorder_countdown_block }}
        
        {% when 'description' %}
            {% if block.settings.description_style == 'fullwidth' and product.description != blank %}
                <div class="product--description product--description-fullwidth rte" {{ block.shopify_attributes }}>
                {{ product.description | replace: '<table', '<div class="table--responsive"><table' | replace: '</table>', '</table></div>' }}
                </div>
            {% endif %}
        {% when 'size_chart' %}
          {% liquid 
            assign optionName = settings.size_name | downcase
            for option in product.options
              assign optionList = settings.size_name | downcase
              assign currentOptionName = option | downcase
              if optionList contains currentOptionName
                assign optionName = currentOptionName
                assign sizeChart = pages[block.settings.size_chart_page]
                if sizeChart != blank and block.settings.size_chart_style != 'accordion'
                  render 'size-chart', block: block, sizeGuide: true, sizeChart: sizeChart
                endif
                break
              endif
            endfor %}       
        {% when 'custom_content' %}
            {% if block.settings.content != blank or block.settings.heading != blank %}
              <div class="product--custom-content" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="product--custom-content-heading text-xlarge heading-font">{{ block.settings.heading }}</h2>
                {% endif %}
                {% if block.settings.content != blank %}
                  <div class="product--custom-content-desc rte" id="product--custom-content-{{ section.id }}">
                    {{ block.settings.content }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
        {% when 'complementary_products' %}
          {{ complementary_products }}
        {% when 'inventory_status' %}
            {% render 'product-inventory', product: product, currentVariant: currentVariant, block: block %}
        {% when 'social_proof_viewers' %}
            {{ 'social-proof-viewers.css' | asset_url | stylesheet_tag }}
            <social-proof-viewers
              class="social-proof-viewers"
              data-min="{{ block.settings.min_viewers }}"
              data-max="{{ block.settings.max_viewers }}"
              data-interval="{{ block.settings.update_interval }}"
              data-text="{{ block.settings.viewer_text | escape }}"
              {{ block.shopify_attributes }}
            ></social-proof-viewers>
            <script src="{{ 'social-proof-viewers.js' | asset_url }}" defer="defer"></script>
        {% when 'divider' %}
          <div class="product-block-divider">
          <span></span>
          </div>
        {% endcase %}
    {% endfor %}
  {% endcapture %}

  {%- capture accordionContent -%}
    {% for block in section.blocks %}
      {% case block.type %}
        {%  when 'collapsible_content' %}
          {% assign collapsible_content_type = block.settings.collapsible_content_type  %}
          {% if collapsible_content_type == 'page' %}
              {% assign page = pages[block.settings.page_content] %}
              {% if block.settings.heading != blank
                and page.content != blank
                %}
                <div class="product-accordion">
                  <details class="product-accordion--item border-bottom" {{ block.shopify_attributes }}>
                    <summary class="product-accordion--heading detail-summary">
                      <h3 class="product-accordion--heading-text h6">{{ block.settings.heading }}</h3>
                      <span class="product-accordion--icon">
                        {% render 'icons', icon: 'accordion-icon' %}
                      </span>
                    </summary>
                    <div class="product-accordion--content" data-accordion-content>
                      <div class="product-accordion--content-body rte">
                        {{ page.content | replace: '<table', '<div class="table--responsive"><table' | replace: '</table>', '</table></div>' }}
                      </div>
                    </div>
                  </details>
                </div>
              {% endif %}            
          {% else %}

          {% if block.settings.heading != blank
            and block.settings.description != blank
            %}
            <div class="product-accordion">
              <details class="product-accordion--item border-bottom" {{ block.shopify_attributes }}>
                <summary class="product-accordion--heading detail-summary">
                  <h3 class="product-accordion--heading-text h6">{{ block.settings.heading }}</h3>
                  <span class="product-accordion--icon">
                    {% render 'icons', icon: 'accordion-icon' %}
                  </span>
                </summary>
                <div class="product-accordion--content" data-accordion-content>
                  <div class="product-accordion--content-body rte">
                    {{ block.settings.description }}
                  </div>
                </div>
              </details>
            </div>
          {% endif %}
          {% endif %}
        {% when 'description' %}
          {% if block.settings.description_style == 'accordion'
            and product.description != blank
            %}
            <div class="product-accordion">
              <details class="product-accordion--item border-bottom" {{ block.shopify_attributes }}>
                <summary class="product-accordion--heading detail-summary">
                  <h2 class="product-accordion--heading-text h6">Description</h2>
                  <span class="product-accordion--icon">
                    {% render 'icons', icon: 'accordion-icon' %}
                  </span>
                </summary>
                <div class="product-accordion--content" data-accordion-content>
                  <div class="product-accordion--content-body rte">
                    {{ product.description | replace: '<table', '<div class="table--responsive"><table' | replace: '</table>', '</table></div>' }}
                  </div>
                </div>
              </details>
            </div>
          {% endif %}
        {% when 'size_chart' %}
          {% liquid 
            assign optionName = settings.size_name | downcase
            for option in product.options
              assign optionList = settings.size_name | downcase
              assign currentOptionName = option | downcase
              if optionList contains currentOptionName
                assign optionName = currentOptionName
                assign sizeChart = pages[block.settings.size_chart_page]
                if sizeChart != blank and block.settings.size_chart_style == 'accordion'
                  render 'size-chart', block: block, sizeGuide: true, sizeChart: sizeChart
                endif
                break
              endif
            endfor %}  
      {% endcase %}
    {% endfor %}
  {% endcapture %}

  {% capture productBottomContent %} 
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'description' %}
          {% if block.settings.description_style == 'fullwidth' and product.description != blank%}
              <div class="product--description rte" {{ block.shopify_attributes }}>
              {{ product.description | replace: '<table', '<div class="table--responsive"><table' | replace: '</table>', '</table></div>' }}
              </div>
          {% endif %}
          {% when 'size_chart' %}
            {% liquid 
            assign optionName = settings.size_name | downcase
            for option in product.options
              assign optionList = settings.size_name | downcase
              assign currentOptionName = option | downcase
              if optionList contains currentOptionName
                assign optionName = currentOptionName
                assign sizeChart = pages[block.settings.size_chart_page]
                if sizeChart != blank and block.settings.size_chart_style == 'fullwidth'
                  render 'size-chart', block: block, sizeGuide: true, sizeChart: sizeChart
                endif
                break
              endif
            endfor %}  
        {% when 'custom_content' %}
            {% if block.settings.content != blank or block.settings.heading != blank %}
              <div class="product--custom-content" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="product--custom-content-heading text-xlarge heading-font">{{ block.settings.heading }}</h2>
                {% endif %}
                {% if block.settings.content != blank %}
                  <div class="product--custom-content-desc rte" id="product--custom-content-{{ section.id }}" >
                    {{ block.settings.content }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
        {% when 'complementary_products' %}
          {{ complementary_products }}
        
        {% when 'custom_liquid' %}
          {{ custom_liquid }}
      {% endcase %}
    {% endfor %}
  {% endcapture %}

  {% if accordionContent != blank or product_layout_3_content != blank %}
    {% if pdp_layout_style == 'layout_3' %}
      <div class="container-fullwidth">
        <div class="product--detail-bottom-content product-content-fullwidth">
          {{ product_layout_3_content }}
          {% if accordionContent %}
            <div class="product--detail-accordion">
              {{ accordionContent }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% if pdp_layout_style != 'layout_3' and pdp_layout_style != 'layout_2' %}
    {% if accordionContent or productBottomContent %}
      {% if pdp_layout_style == 'layout_1' %}<div class="container-fullwidth">{% endif %}
      <div class="product--detail-bottom-content">
        {{ productBottomContent }}
        {% if accordionContent %}
          <div class="product--detail-accordion">
            {{ accordionContent }}
          </div>
        {% endif %}
      </div>
      {% if pdp_layout_style == 'layout_1' %}</div>{% endif %}
    {% endif %}
  {% endif %}
</div>
{% if pdp_layout_style == 'layout_2' %}</div>{% endif %}
{% if request.page_type == 'product' and section.settings.is_sticky_addtocart and product %}
  {% render 'sticky-buy-button', product: product, section: section, currentVariant: currentVariant %}
{% endif %}

{% comment %} Script pour initialiser les vidéos sur iOS {% endcomment %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Fonction pour configurer et lancer les vidéos produit
    function initProductVideos() {
      document.querySelectorAll('.product-video-wrapper video, .product-video').forEach(function(video) {
        // Attributs essentiels pour iOS
        video.setAttribute('playsinline', '');
        video.setAttribute('webkit-playsinline', '');
        video.muted = true;
        video.loop = true;
        
        // Tenter l'autoplay
        var playPromise = video.play();
        if (playPromise !== undefined) {
          playPromise.catch(function(error) {
            console.log('Autoplay prevented, waiting for user interaction');
          });
        }
      });
    }

    // Initialiser au chargement
    initProductVideos();

    // Observer pour les vidéos chargées dynamiquement (Swiper, AJAX, etc.)
    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.addedNodes.length) {
          initProductVideos();
        }
      });
    });

    observer.observe(document.body, { childList: true, subtree: true });

    // Gestion de la visibilité - pause/play quand la slide change
    document.querySelectorAll('.product-video-wrapper video').forEach(function(video) {
      var videoObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.play().catch(function() {});
          } else {
            entry.target.pause();
          }
        });
      }, { threshold: 0.5 });

      videoObserver.observe(video);
    });
  });
</script>
