{{ 'hamburger-menu.css' | asset_url | stylesheet_tag }}
<hamburger-menu class="hamburger-menu scheme-{{ section.settings.hamburger_color_scheme }}">
  <div class="hamburger-menu--wrapper">
    <div class="hamburger-menu--content">
      <div class="hamburger-menu--header">
        <div class="hamburger-menu--logo">
          <a
            class="header--logo"
            href="{{ routes.root_url }}"
            aria-label="{{ shop.name }}"
          >
            {%- if section.settings.logo != blank -%}
              {%- assign image_2x_size = section.settings.desktop_logo_width | times: 2 | at_most: 2560 -%}
              <img
                srcset="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }} 1x, {{ section.settings.logo | image_url: width: image_2x_size }} 2x"
                src="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }}"
                loading="lazy"
                width="{{ section.settings.desktop_logo_width }}"
                height="{{ section.settings.desktop_logo_width | divided_by : section.settings.logo.aspect_ratio | round }}"
                alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
              >
            {% else %}
              <span class="header--logo-text text-medium">{{ shop.name }}</span>
            {% endif %}
          </a>
        </div>
        <div class="hamburger-menu--social-link">
          {% if section.settings.hamburger_menu_btn_text != blank and section.settings.hamburger_menu_btn_link %}
            <a href="{{ section.settings.hamburger_menu_btn_link }}" class="button {{ settings.button_animation_style }}">
              {% render 'button-appearance', button_text: section.settings.hamburger_menu_btn_text, icon: 'arrow-right' %}
            </a>
          {% endif %}
          {% liquid
            if section.settings.hamburger_menu_social_media
              render 'social-icons'
            endif
          %}
        </div>
        <button class="hamburger-menu--close cross_button">
          <svg class="close-icon" width="20" height="20" viewBox="0 0 23.691 22.723">
            <g transform="translate(-126.154 -143.139)">
              <line x2="23" y2="22" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></line>
              <path d="M0,22,23,0" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></path>
            </g>
          </svg>
        </button>
      </div>
      <div class="hamburger-menu--body">
        <div class="hamburger-menu--body-content d-flex width-100 height-100{% if section.settings.hamburger_menu_card_image == blank %} no-image-card{% endif %}">
          {% if section.settings.menu != blank %}
            <div class="hamburger-menu--left-content pos-relative">
              <div class="hamburger-menu--menus width-100 height-100">
                <ul class="hamburger-menu--menu-list width-100 height-100">
                  {% assign reverseBlocks = section.blocks | reverse %}
                  {% for link in section.settings.menu.links %}
                    {%- liquid
                      assign megaMenuStatus = false
                      assign linkTitle = link.title | handleize
                      assign indexmenu = forloop.index
                      assign megamenuStyle = ''
                      capture megaMenuData
                        for block in section.blocks
                          case block.type
                            when 'style-1'
                              assign blockLabel = block.settings.title | handleize
                              if blockLabel == linkTitle
                                assign megaMenuStatus = true
                                assign megamenuStyle = 'style-1'
                                assign megamenuClass = 'mega-menu-' | append: indexmenu
                                render 'mega-menu', block: block, megamenu: megamenuClass
                              endif
                            when 'style-2'
                              assign blockLabel = block.settings.title | handleize
                              if blockLabel == linkTitle
                                assign megaMenuStatus = true
                                assign megamenuStyle = 'style-2'
                                assign megamenuClass = 'mega-menu2-' | append: indexmenu
                                render 'mega-menu2', block: block, megamenu: megamenuClass
                              endif
                            when 'style-3'
                              assign blockLabel = block.settings.title | handleize
                              if blockLabel == linkTitle
                                assign megaMenuStatus = true
                                assign megamenuStyle = 'style-3'
                                assign megamenuClass = 'mega-menu3-' | append: indexmenu
                                render 'mega-menu3', section: section, block: block, megamenu: megamenuClass, hamburgerMenu: 'true'
                              endif
                          endcase
                          if megaMenuStatus
                            break
                          endif
                        endfor
                      endcapture
                    -%}
                    <li
                      class="hamburger-menu--menu-item"
                      data-hamburger-menu
                      {% if link.links.size > 0 or megaMenuData != blank %}
                        data-hamburger-item
                      {% endif %}
                    >
                      <a class="hamburger-menu--menu-link {{ section.settings.font_type }} h4" href="{{ link.url }}">
                        {{- link.title }}
                        {% if link.links.size > 0 or megaMenuData != blank %}
                          <svg viewBox="0 0 30 30" fill="none">
                            <path d="M2.28235 23.9034L28.4671 6.84609" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
                            <path d="M6.84607 2.28238L28.4671 6.84609L23.9034 28.4671" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
                          </svg>
                        {% endif %}
                      </a>
                      {% if link.links.size > 0 or megaMenuData != blank %}
                        <div class="hamburger-menu--submenu">
                          <div class="hamburger-menu--submenu-inner width-100 height-100">
                            <ul class="hamburger-menu--submenu-list">
                              {% for childLink in link.links %}
                                {% assign childIndex = forloop.index %}
                                <li class="hamburger-menu--submenu-item animate-{{ childIndex }}">
                                  <a class="hamburger-menu--submenu-link {{ section.settings.submenu_font_type }} h6" href="{{ childLink.url }}">
                                    {{- childLink.title -}}
                                  </a>
                                  {% if childLink.links.size > 0 %}
                                    <ul class="hamburger-menu--submenu-inner-list">
                                      {% for grandChildLink in childLink.links %}
                                        {% assign grandIndex = forloop.index %}
                                        <li class="hamburger-menu--submenu-inner-item animate-{{ grandIndex }}">
                                          <a class="hamburger-menu--submenu-inner-link" href="{{ grandChildLink.url }}">
                                            {{- grandChildLink.title -}}
                                          </a>
                                        </li>
                                      {% endfor %}
                                    </ul>
                                  {% endif %}
                                </li>
                              {% endfor %}
                            </ul>
                            {% comment %} {{ megaMenuData }} {% endcomment %}
                            {% render 'hamburger-megamenu',
                              link: link,
                              section: section,
                              block: section.blocks,
                              megamenuStyle: megamenuStyle
                            %}
                          </div>
                        </div>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          {% endif %}
          {% if section.settings.hamburger_menu_card_image != blank %}
            <div class="hamburger-menu--right-content">
              <div class="hamburger-menu--image-item pos-relative width-100 height-100">
                <div class="hamburger-menu--image media-wrapper media-overlay width-100 height-100">
                  <div class="media media-fixed">
                    {% render 'lazy-image', image: section.settings.hamburger_menu_card_image %}
                  </div>
                </div>
                {% if section.settings.hamburger_menu_card_heading != blank
                  or section.settings.hamburger_menu_card_desc != blank
                %}
                  <div class="hamburger-menu--image-content">
                    {% if section.settings.hamburger_menu_card_heading != blank %}
                      <h5 class="heading-font h5">{{ section.settings.hamburger_menu_card_heading }}</h5>
                    {% endif %}
                    {% if section.settings.hamburger_menu_card_desc != blank %}
                      <p>{{ section.settings.hamburger_menu_card_desc }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
      {% if section.settings.hamburger_menu_bottom_menu != blank
        or section.settings.hamburger_menu_bottom_text != blank
        or section.settings.hamburger_menu_marquee_text != blank
      %}
        <div class="hamburger-menu--footer">
          {% if section.settings.hamburger_menu_bottom_menu != blank
            or section.settings.hamburger_menu_bottom_text != blank
          %}
            <div class="hamburger-menu--footer-menu">
              {% if section.settings.hamburger_menu_bottom_menu != blank %}
                <ul class="list-inline">
                  {% for link in section.settings.hamburger_menu_bottom_menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
              {% if section.settings.hamburger_menu_bottom_text != blank %}
                <p class="">{{ section.settings.hamburger_menu_bottom_text | newline_to_br }}</p>
              {% endif %}
            </div>
          {% endif %}
          {% if section.settings.hamburger_menu_marquee_text != blank %}

            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}

            <div class="hamburger-menu--footer-marquee">
              <div
                class="hamburger-menu--footer-marquee-item"
                style="--animation_speed: {{ section.settings.hamburger_menu_marquee_speed }}s;"
              >
                {% for i in (1..3) %}
                  <h6 class="hamburger-menu--footer-marquee-node heading-font h2">
                    {{ section.settings.hamburger_menu_marquee_text | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                  </h6>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</hamburger-menu>
