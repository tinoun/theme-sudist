{% if section.index <= 2 %}
  {{ 'short-menu.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'short-menu.css' | asset_url | stylesheet_tag }}

<quick-short-menu class="short-menu width-100">
  <button class="short-menu--button pos-relative">
    <div class="short-menu--button-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M0 8H24M0 17H24" stroke="currentColor" stroke-width="3.5"></path>
      </svg>
    </div>
    <div class="short-menu--button-text width-100 text-center">
      <span class="heading-font h5">{{ section.settings.quick_menu_heading | default: 'Menu' }}</span>
    </div>
  </button>

  <nav class="short-menu--menu" data-menu>
    <div class="short-menu--menu-list text-center">
      {% assign reverseMenu = section.settings.quick_menu.links | reverse %}
      {% for link in reverseMenu %}
        <div
          class="short-menu--menu-item width-100{% if forloop.rindex0 == 0 %} active{% endif %}"
          data-index="{{ forloop.rindex0 }}"
          data-quick-menu-link
        >
          <a href="{{ link.url }}" class="short-menu--menu-link width-100 pos-relative heading-font h5">
            {{- link.title -}}
          </a>
        </div>
      {% endfor %}
      <span class="short-menu--menu-link-cursor heading-font h5">&nbsp;</span>
    </div>
  </nav>
</quick-short-menu>
