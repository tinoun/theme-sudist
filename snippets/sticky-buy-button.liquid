<sticky-buy-button
  class="sticky-buy-button-wrapper fade-out"
  id="sticky-buy-button-{{ section.id }}"
  form="main-product-form-{{ section.id }}"
>
  <div class="sticky--button-box">
    <div class="sticky--close" data-sticky-close>
      <svg class="close-icon cursor-pointer" width="20" height="20" viewBox="0 0 23.691 22.723">
        <g transform="translate(-126.154 -143.139)">
            <line x2="23" y2="22" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></line>
            <path d="M0,22,23,0" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></path>
        </g>
      </svg>
    </div>
    <div class="sticky--product-card" id="StickyProductForm-{{ section.id }}">
      <div class="sticky--product-image media-wrapper">
        <div class="media" style="--image_ratio:100%;">
          {% if product.featured_media != blank %}
            {% render 'lazy-image', image: product.featured_media.preview_image %}
          {% else %}
            {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
      <div class="sticky--product-detail">
        {% if product != blank %}
          <p class="product--title text-medium">
            {{- product.title | escape -}}
          </p>

          {% unless product.has_only_default_variant %}
            <p class="product--variant-title text-small">
              {{ product.selected_or_first_available_variant.title }}
            </p>
          {% endunless %}
        {% endif %}

        <div class="product--pricing" id="sticky-price--wrapper-{{ section.id }}">
          {% render 'product-price', product: product, currentVariant: currentVariant, source: 'sticky-buy-button' %}
          {% if product != blank %}
            <div {{ block.shopify_attributes }} class="product--installment-form">
              {%- assign product_form_installment_id = 'main-product-form-installment-' | append: section.id -%}
              {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                {{ form | payment_terms }}
              {%- endform -%}
            </div>
          {% endif %}
        </div>
      </div>
      <div class="sticky--product-expand-detail">
        <button
          type="submit"
          name="add"
          form="main-product-form-{{ section.id}}-{{ product.id }}"
          data-button="product--submit-{{ product.id }}"
          id="sticky-product--submit-btn-{{ section.id }}"
          class="product--icon"
          data-add-to-cart
          aria-label="Add to cart"
          data-sticky-buy-button
          {% if currentVariant.available == false or quantity_rule_soldout %}
            disabled="disabled"
          {% endif %}
        >
          <span data-atc-text data-product-button class="width-100 height-100 d-flex">
            {%- render 'icons', icon: 'cart' -%}
          </span>
          {% comment %}
            <span class="product--submit-btn-loader hidden" data-atc-loader>
              {%- render 'icons', icon: 'animated-loader' -%}
            </span>
          {% endcomment %}
        </button>
      </div>
    </div>
  </div>
</sticky-buy-button>
