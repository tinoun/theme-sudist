{% if block.settings[imageSetting] != blank %}
  <{% if block.settings[linkSetting] != blank %}a href="{{ block.settings[linkSetting] }}"{% else %}div{% endif %} class="header--menu-megamenu-image focus-inside pos-relative width-100" {% if overlay_opacity %} style="--image_overlay_opacity:{{ overlay_opacity }}"{% endif %} {{ block.shopify_attributes }}>
    {%- if block.settings[imageSetting] != blank -%}
      {% assign image = block.settings[imageSetting] %}
      <div class="header--menu-megamenu-img media-wrapper width-100 height-100 media-overlay">
        <div class="media" style="--image_ratio:70%;">
          {% render 'lazy-image', image: image %}
        </div>
      </div>
    {%- endif -%}
    {%- if block.settings[headingSetting] != blank -%}
      <div class="header--menu-megamenu-image-content">
        <p class="header--menu-megamenu-image-title image-overlay-heading h6 {{ section.settings.submenu_font_type }}">
          {% if section.settings.submenu_font_style == 'bold' %}
            <strong>
          {% endif %}
          {{ block.settings[headingSetting] }}
          {% if section.settings.submenu_font_style == 'bold' %}
            </strong>
          {% endif %}
        </p>
      </div>
    {%- endif -%}
    {% comment %} {%- if block.settings[linkSetting] != blank -%}
      <a href="{{ block.settings[linkSetting] }}" class="focus-inside header--menu-megamenu-image-link"></a>
    {%- endif -%} {% endcomment %}
  </{% if block.settings[linkSetting] != blank %}a{% else %}div{% endif %}>
{% endif %}
