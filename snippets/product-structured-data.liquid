{% comment %}
  =====================================================
  SNIPPET: product-structured-data.liquid
  
  Données structurées personnalisées pour Google Rich Results
  - Corrige priceValidUntil manquant
  - Ajoute aggregateRating (Judge.me)
  
  INSTALLATION:
  1. Créez ce fichier dans snippets/product-structured-data.liquid
  2. Dans sections/main-product.liquid, ajoutez à la fin (avant {% schema %}) :
     {% render 'product-structured-data', product: product %}
  3. Désactivez les microdonnées Shopify dans les paramètres du thème
  =====================================================
{% endcomment %}

{%- liquid
  assign next_year = 'now' | date: '%Y' | plus: 1
  assign price_valid_until = next_year | append: '-12-31'
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "productID": "{{ product.id }}",
  {% if product.vendor != blank %}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {% endif %}
  "category": {{ product.type | json }},
  "image": [
    {% for image in product.images limit: 5 %}
    "https:{{ image | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  {% if product.variants.size == 1 %}
  {%- assign variant = product.variants.first -%}
  {% if variant.sku != blank %}"sku": {{ variant.sku | json }},{% endif %}
  {% if variant.barcode != blank %}"gtin": {{ variant.barcode | json }},{% endif %}
  "offers": {
    "@type": "Offer",
    "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#offer",
    "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
    "priceCurrency": "{{ shop.currency }}",
    "price": "{{ variant.price | money_without_currency | replace: ' ', '' | replace: ',', '.' }}",
    "priceValidUntil": "{{ price_valid_until }}",
    "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
  {% else %}
  "offers": [
    {% for variant in product.variants %}
    {
      "@type": "Offer",
      "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#offer",
      "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
      "name": {{ variant.title | json }},
      "priceCurrency": "{{ shop.currency }}",
      "price": "{{ variant.price | money_without_currency | replace: ' ', '' | replace: ',', '.' }}",
      "priceValidUntil": "{{ price_valid_until }}",
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      {% if variant.sku != blank %}"sku": {{ variant.sku | json }},{% endif %}
      {% if variant.barcode != blank %}"gtin": {{ variant.barcode | json }},{% endif %}
      "seller": {
        "@type": "Organization",
        "name": {{ shop.name | json }}
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
  {% endif %}
  
  {% comment %} ===== JUDGE.ME REVIEWS ===== {% endcomment %}
  {% if product.metafields.reviews.rating.value != blank %}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value }}",
    "reviewCount": "{{ product.metafields.reviews.rating_count.value | default: 1 }}",
    "bestRating": "5",
    "worstRating": "1"
  }
  {% elsif product.metafields.judgeme.rating.value != blank %}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.judgeme.rating.value }}",
    "reviewCount": "{{ product.metafields.judgeme.review_count.value | default: 1 }}",
    "bestRating": "5",
    "worstRating": "1"
  }
  {% endif %}
}
</script>
