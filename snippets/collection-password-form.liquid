<div class="collection-password-popup--content">
  {%- if section.settings.gate_image != blank -%}
    <div class="collection-password-popup--image">
      {{ section.settings.gate_image | image_url: width: 800 | image_tag:
        class: 'collection-password-popup--img',
        loading: 'eager',
        widths: '400, 600, 800'
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.gate_heading != blank -%}
    <h5 class="h4 heading-font collection-password-popup--heading">
      {{ section.settings.gate_heading }}
    </h5>
  {%- endif -%}

  {%- if section.settings.welcome_text != blank -%}
    <p class="collection-password-popup--desc">
      {{ section.settings.welcome_text | newline_to_br }}
    </p>
  {%- endif -%}

  {%- if section.settings.enable_countdown and section.settings.countdown_date != blank -%}
    <div class="collection-password-popup--countdown" data-collection-gate-countdown data-countdown-date="{{ section.settings.countdown_date }}">
      {%- if section.settings.countdown_label != blank -%}
        <p class="collection-password-popup--countdown-label">{{ section.settings.countdown_label }}</p>
      {%- endif -%}
      <div class="collection-password-popup--countdown-timer">
        <div class="countdown-unit">
          <span class="countdown-value" data-countdown-days>00</span>
          <span class="countdown-label">j</span>
        </div>
        <span class="countdown-separator">:</span>
        <div class="countdown-unit">
          <span class="countdown-value" data-countdown-hours>00</span>
          <span class="countdown-label">h</span>
        </div>
        <span class="countdown-separator">:</span>
        <div class="countdown-unit">
          <span class="countdown-value" data-countdown-minutes>00</span>
          <span class="countdown-label">min</span>
        </div>
        <span class="countdown-separator">:</span>
        <div class="countdown-unit">
          <span class="countdown-value" data-countdown-seconds>00</span>
          <span class="countdown-label">s</span>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="collection-password-popup--form">
    <div class="form-group">
      <label class="hidden" for="CollectionPassword--{{ section.id }}">
        {{ 'sections.collection_password_gate.password_label' | t }}
      </label>
      {%- assign gate_placeholder = section.settings.placeholder_text -%}
      {%- if gate_placeholder == blank -%}
        {%- assign gate_placeholder = 'sections.collection_password_gate.password_placeholder' | t -%}
      {%- endif -%}
      <div class="collection-password-popup--input-wrap">
        <input
          type="password"
          id="CollectionPassword--{{ section.id }}"
          class="form-control"
          data-collection-password-input
          autocomplete="off"
          placeholder="{{ gate_placeholder }}"
        >
        {%- if section.settings.enable_show_password -%}
          <button
            type="button"
            class="collection-password-popup--toggle-visibility"
            data-collection-password-toggle
            aria-label="{{ 'sections.collection_password_gate.show_password' | t }}"
          >
            <svg data-icon-eye width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg data-icon-eye-off width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- assign gate_error = section.settings.error_text -%}
    {%- if gate_error == blank -%}
      {%- assign gate_error = 'sections.collection_password_gate.error_default' | t -%}
    {%- endif -%}
    <div class="form--message error" data-collection-password-error style="display: none;">
      {{ gate_error }}
    </div>

    {%- assign gate_button = section.settings.button_text -%}
    {%- if gate_button == blank -%}
      {%- assign gate_button = 'sections.collection_password_gate.button_default' | t -%}
    {%- endif -%}
    <button
      type="button"
      class="button medium-button button-block"
      data-collection-password-submit
      aria-label="{{ gate_button }}"
    >
      {{ gate_button }}
    </button>
  </div>
</div>
