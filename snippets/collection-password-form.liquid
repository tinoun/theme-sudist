<div class="collection-password-popup--content">
  {%- if section.settings.gate_heading != blank -%}
    <h5 class="h4 heading-font collection-password-popup--heading">
      {{ section.settings.gate_heading }}
    </h5>
  {%- endif -%}

  {%- if section.settings.welcome_text != blank -%}
    <p class="collection-password-popup--desc">
      {{ section.settings.welcome_text | newline_to_br }}
    </p>
  {%- endif -%}

  <div class="collection-password-popup--form">
    <div class="form-group">
      <label class="hidden" for="CollectionPassword--{{ section.id }}">
        {{ 'sections.collection_password_gate.password_label' | t }}
      </label>
      {%- assign gate_placeholder = section.settings.placeholder_text -%}
      {%- if gate_placeholder == blank -%}
        {%- assign gate_placeholder = 'sections.collection_password_gate.password_placeholder' | t -%}
      {%- endif -%}
      <input
        type="password"
        id="CollectionPassword--{{ section.id }}"
        class="form-control"
        data-collection-password-input
        autocomplete="off"
        placeholder="{{ gate_placeholder }}"
      >
    </div>

    {%- assign gate_error = section.settings.error_text -%}
    {%- if gate_error == blank -%}
      {%- assign gate_error = 'sections.collection_password_gate.error_default' | t -%}
    {%- endif -%}
    <div class="form--message error" data-collection-password-error style="display: none;">
      {{ gate_error }}
    </div>

    {%- assign gate_button = section.settings.button_text -%}
    {%- if gate_button == blank -%}
      {%- assign gate_button = 'sections.collection_password_gate.button_default' | t -%}
    {%- endif -%}
    <button
      type="button"
      class="button medium-button button-block"
      data-collection-password-submit
      aria-label="{{ gate_button }}"
    >
      {{ gate_button }}
    </button>
  </div>
</div>
