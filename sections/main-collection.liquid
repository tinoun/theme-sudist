{% if section.index <= 2 %}
  {{ 'main-collection.css' | asset_url | preload_tag: as: 'style' }}
  {{ 'edito-card.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'main-collection.css' | asset_url | stylesheet_tag }}
{{ 'edito-card.css' | asset_url | stylesheet_tag }}

{% liquid
  assign isfiltersSidebar = false

  if section.settings.sorting
    assign isfiltersSidebar = true
  endif

  if collection.filters.size > 0
    if section.settings.filters
      assign isfiltersSidebar = true
    endif
  endif

  assign isfiltersAlways = false
  if section.settings.show_filters_always
    assign isfiltersAlways = true
  endif

  comment
    Récupérer les blocs édito triés par position
  endcomment
  assign edito_blocks = section.blocks | where: "type", "edito_card" | sort: "settings.position"
%}

<div
  class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}"
>
  <div class="{{ settings.container_width }}">
    <div
      class="main-collection--wrapper{% if isfiltersSidebar %}{% if section.settings.filter_layout == 'horizontal-bottom'%} filter-layout-horizontal {{ section.settings.filter_layout }}{% else %} filter-layout-{{ section.settings.filter_layout }}{% endif %}{% endif %}"
      data-collection-wrapper
    >
      {% if section.settings.is_subcollections and section.settings.collection_list.count > 0 %}
        <div class="collection-category--main">
          <ul class="collection-category--list">
            {% for collection in section.settings.collection_list %}
              <li class="collection-category--item" is="hover-li">
                <a
                  class="collection-category--link{% if collection.featured_image != blank %} has-image{% endif %}"
                  href="{{ collection.url }}"
                >
                  {% if collection.featured_image != blank %}
                    <div class="collection-category--image media-wrapper rounded">
                      <div class="media" style="--image_ratio:100%;">
                        {%- render 'lazy-image', image: collection.featured_image -%}
                      </div>
                    </div>
                  {% endif %}
                  <span class="collection-category--title">{{ collection.title }}</span>
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {% liquid
        if section.settings.filter_layout == 'horizontal'
          if isfiltersSidebar and section.blocks.size >= 1 and collection.filters.size > 0
            render 'horizontal-filters', section: section, block: section.blocks
          endif
        endif
      %}

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'products_grid' %}
            {% if collection.products_count > 0 %}
            <div class="collection--topbar" data-collection-topbar>
              {% if isfiltersSidebar == true %}
                <filter-toggler>
                  <button
                    class="button filter-toggle-button {{ section.settings.filter_button_size }} hidden d-md-flex{% if isfiltersAlways == true %} filters-opened{% endif %}"
                    data-filters-nav
                  >
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M16 6a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1h-2.55a2.5 2.5 0 0 1-4.9 0H3V7h10.55ZM8 15a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1H10.45a2.5 2.5 0 0 1-4.9 0H3v-1h2.55Z"></path>
                    </svg>
                    <span>
                      {%- if isfiltersAlways == true %}{{ 'products.facets.hide_filter' | t }}{% else %}{{ 'products.facets.show_filter' | t }}{% endif -%}
                    </span>
                  </button>
                  <button
                    class="button filter-toggle-button d-flex d-md-none{% if isfiltersAlways == true %} filters-opened{% endif %}"
                    data-filters-mobile
                  >
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M16 6a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1h-2.55a2.5 2.5 0 0 1-4.9 0H3V7h10.55ZM8 15a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1H10.45a2.5 2.5 0 0 1-4.9 0H3v-1h2.55Z"></path>
                    </svg>
                    <span> {{ 'products.facets.show_filter' | t }} </span>
                  </button>
                </filter-toggler>
              {% endif %}

              <h6 class="filter--results-text text-large" data-coll-products-count="{{ collection.products_count }}">
                {% for block in section.blocks %}
                  {% assign count_limit = block.settings.products_limit %}
                {% endfor %}
                {% paginate collection.products by count_limit %}
                  {% assign current_page = paginate.current_page %}
                {% endpaginate %}
                {% assign product_counts = count_limit | times: current_page %}
                <div data-collection-count>
                  <span class="collection-products--count" data-total-products-count>
                    {% if product_counts > collection.products_count %}
                      {{- collection.products_count -}}
                      /{{ collection.products_count }}
                    {% else %}
                      {{- product_counts -}}
                      /{{ collection.products_count }}
                    {% endif -%}
                  </span>
                  <span class="collection-products--text">
                    {{- collection.products_count | pluralize: 'Produit', 'Produits' -}}
                  </span>
                </div>
              </h6>
            </div>
           {% endif %}
        {% endcase %}
      {% endfor %}

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'products_grid' %}
            <div
              class="{% if collection.products_count > 0 %}main-collection--products{% endif %}{% if isfiltersSidebar == true and isfiltersAlways == true %} open-filter{% endif %}"
              {{ block.shopify_attributes }}
              data-products-wrapper
            >
              {% if isfiltersSidebar == true and collection.products_count > 0 %}
                <div class="filter--sidebar" data-filter-always="{{ isfiltersAlways }}" data-filters-sidebar>
                  <div class="filter--sidebar-overlay d-block d-md-none"></div>
                  <filter-faced-form class="d-block height-100" data-mobile-filter-sticky="false">
                    <form class="filter--sidebar-content height-100" id="filter-sorting-form">
                      <div class="filter--sidebar-header d-grid d-md-none">
                        <h5 class="filter--sidebar-heading h5">{{ 'products.facets.filter_and_sort' | t }}</h5>

                        <button type="button" class="drawer-close" aria-label="Fermer" data-mobile-filter-toggle>
                          <svg class="close-icon" width="20" height="20" viewBox="0 0 23.691 22.723">
                            <g transform="translate(-126.154 -143.139)">
                              <line x2="23" y2="22" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></line>
                              <path d="M0,22,23,0" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></path>
                            </g>
                          </svg>
                        </button>
                      </div>
                      <div class="filter--columns height-100">
                        {% assign is_appiled_filters = false %}
                        {% capture applied_filters %}
                            {%- for filter in collection.filters -%}
                              {%- for value in filter.active_values -%}
                                <li class="filter--applied-item" is="hover-li">
                                  <filter-remove>
                                    <a href="{{ value.url_to_remove }}">
                                      <span>
                                        {{ value.label | escape }}
                                      </span>
                                      {% render 'icons', icon: 'cross-icon' %}
                                      <span class="hidden">{{ 'products.facets.clear_filter' | t }}</span>
                                    </a>
                                  </filter-remove>
                                </li>
                                {% assign is_appiled_filters = true %}
                              {%- endfor -%}
                              {% if filter.type == 'price_range' %}
                                {%- if filter.min_value.value != null or filter.max_value.value != null -%}
                                  {% assign is_appiled_filters = true %}
                                  <li class="filter--applied-item" is="hover-li">
                                    <filter-remove>
                                      <a href="{{ filter.url_to_remove }}">
                                        <span>
                                          {%- if filter.min_value.value -%}
                                            {{ filter.min_value.value | money }}
                                          {%- else -%}
                                            {{ 0 | money }}
                                          {%- endif -%}
                                          - 
                                          {%- if filter.max_value.value -%}
                                            {{ filter.max_value.value | money }}
                                          {%- else -%}
                                            {{ filter.range_max | money }}
                                          {%- endif -%}
                                        </span>
                                        {% render 'icons', icon: 'cross-icon' %}
                                        <span class="hidden">{{ 'products.facets.clear_filter' | t }}</span>
                                      </a>
                                    </filter-remove>
                                  </li>
                                {%- endif -%}
                              {% endif %}
                            {%- endfor -%}
                          {% endcapture %}

                        {% if is_appiled_filters %}
                          <div class="filter--columns-item filter--applied">
                            <h6 class="filter--columns-heading text-large">{{ 'products.facets.apply' | t }}</h6>
                            <div class="filter--applied-list">
                              <ul data-applied-filters>
                                {{ applied_filters }}
                              </ul>
                              <filter-remove>
                                <a class="clear-filter-button text-underline" href="{{ collection.url }}"
                                  >{{ 'products.facets.clear' | t }}</a
                                >
                              </filter-remove>
                            </div>
                          </div>
                        {% endif %}
                        {% if section.settings.sorting %}
                          {% render 'sorting',
                            collection: collection,
                            filterstyle: 'vertical',
                            style: section.settings.sort_style
                          %}
                        {% endif %}

                        {% if section.settings.show_category_menus and section.settings.menu != blank %}
                          <div class="filter--columns-item filter--category-menus">
                            <h6 class="filter--columns-heading text-large">
                              {{ section.settings.category_title | default: section.settings.menu.title }}
                            </h6>
                            <div class="filter--option-list">
                              <ul class="filter--option-list-items">
                                {% for link in section.settings.menu.links %}
                                  <li class="filter-option-item">
                                    <a class="" href="{{ link.url }}">{{ link.title }}</a>
                                  </li>
                                {% endfor %}
                              </ul>
                            </div>
                          </div>
                        {% endif %}

                        {% if section.settings.filters %}
                          {% render 'filters', collection: collection %}
                        {% endif %}
                      </div>
                    </form>
                  </filter-faced-form>
                </div>
              {% endif %}

              {% paginate collection.products by block.settings.products_limit %}
                <div
                  class="main-collection--products-box"
                  data-collections-grid
                  id="collection--list-grid"
                  data-id="{{ section.id }}"
                  data-section="{{ section.id }}"
                  data-url="{{ collection.url }}?page={{ paginate.current_page }}"
                >
                  {% if collection.products_count > 0 %}
                    <div class="main-collection--products-list{% if section.settings.enable_sezane_layout %} sezane-layout{% endif %}" main-collection-products data-products-per-page="{{ block.settings.products_limit }}">
                      {%- comment -%} Calculer l'offset basé sur la page actuelle {%- endcomment -%}
                      {%- assign products_per_page = block.settings.products_limit -%}
                      {%- assign current_page = paginate.current_page -%}
                      {%- assign page_offset = current_page | minus: 1 | times: products_per_page -%}
                      
                      {%- comment -%} Compteur pour la position absolue dans toute la collection {%- endcomment -%}
                      {%- assign grid_position = page_offset -%}
                      
                      {%- for product in collection.products limit: block.settings.products_limit -%}
                        {%- assign grid_position = grid_position | plus: 1 -%}
                        
                        {%- comment -%} Déterminer si ce produit doit être fullscreen (layout Sézane) {%- endcomment -%}
                        {%- assign is_fullscreen = false -%}
                        {%- if section.settings.enable_sezane_layout -%}
                          {%- assign modulo = grid_position | modulo: 3 -%}
                          {%- if modulo == 0 -%}
                            {%- assign is_fullscreen = true -%}
                          {%- endif -%}
                        {%- endif -%}
                        
                        {%- comment -%} Afficher les cartes édito à leur position absolue {%- endcomment -%}
                        {%- if section.settings.enable_edito_cards -%}
                          {%- for edito_block in edito_blocks -%}
                            {%- if edito_block.settings.position == grid_position -%}
                              <div
                                class="product--card edito-card{% if edito_block.settings.card_size == 'double' %} edito-card--double{% endif %}"
                                {% if settings.is_card_animation %}is="card-animate"{% endif %}
                                {{ edito_block.shopify_attributes }}
                                data-edito-position="{{ edito_block.settings.position }}"
                              >
                                {% render 'edito-card', block: edito_block, cardImageSize: block.settings.card_image_size %}
                              </div>
                              {%- assign grid_position = grid_position | plus: 1 -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}
                        
                        <div
                          class="product--card{% if is_fullscreen %} collection--fullscreen{% endif %}"
                          {% if settings.is_card_animation %}
                            is="card-animate"
                          {% endif %}
                        >
                          {% render 'product-card',
                            cardproduct: product,
                            cardImageSize: block.settings.card_image_size,
                            source: 'main-collection'
                          %}
                        </div>
                      {%- endfor -%}
                    </div>
                  {% else %}
                    {% render 'empty-card', source: 'main-collection' %}
                  {% endif %}
                  {% if block.settings.pagination_type %}
                    {% if paginate.next %}
                      {% if block.settings.pagination_type == 'infinite' %}
                        <data-scroll class="infinte-scroll" data-scroll-event>
                          <a
                            href="{{ paginate.next.url }}"
                            aria-label="chargement"
                            data-current-page="{{ paginate.current_page }}"
                            data-product-count="{{ block.settings.products_limit }}"
                            data-total-product="{{ collection.products_count }}"
                          ></a>
                          <div class="collection-loader text-center hidden" data-infinite-scroll>
                            <svg
                              width="40"
                              height="40"
                              style="shape-rendering: auto; animation-play-state: running; animation-delay: 0s; background: none;"
                              viewBox="0 0 100 100"
                              preserveAspectRatio="xMidYMid"
                            >
                              <circle cx="50" cy="50" fill="none" stroke="#d9e2ed" stroke-width="6" r="35"
                                  stroke-dasharray="164.93361431346415 56.97787143782138"
                                  style="animation-play-state: running; animation-delay: 0s;"
                                  transform="rotate(115.597 50 50)">
                                  <animateTransform attributeName="transform" type="rotate" calcMode="linear"
                                      values="0 50 50;360 50 50" keyTimes="0;1" dur="1s" begin="0s"
                                      repeatCount="indefinite">
                                  </animateTransform>
                              </circle>
                            </svg>
                          </div>
                        </data-scroll>
                      {% elsif block.settings.pagination_type == 'load_more' %}
                        <load-more class="d-block collection-loader text-center infinte-scroll" data-load-more>
                          <a
                            class="collection-load-more button"
                            href="{{ paginate.next.url }}"
                            aria-label="charger-plus"
                            data-products-load
                            data-current-page="{{ paginate.current_page }}"
                            data-product-count="{{ block.settings.products_limit }}"
                            data-total-product="{{ collection.products_count }}"
                          >
                            <span>{{ 'sections.collection_list.load_more' | t }}</span>
                          </a>
                          <div class="collection-loader text-center hidden" data-infinite-scroll>
                            <svg
                              width="40"
                              height="40"
                              style="shape-rendering: auto; animation-play-state: running; animation-delay: 0s; background: none;"
                              viewBox="0 0 100 100"
                              preserveAspectRatio="xMidYMid"
                            >
                              <circle cx="50" cy="50" fill="none" stroke="#d9e2ed" stroke-width="6" r="35"
                                  stroke-dasharray="164.93361431346415 56.97787143782138"
                                  style="animation-play-state: running; animation-delay: 0s;"
                                  transform="rotate(115.597 50 50)">
                                  <animateTransform attributeName="transform" type="rotate" calcMode="linear"
                                      values="0 50 50;360 50 50" keyTimes="0;1" dur="1s" begin="0s"
                                      repeatCount="indefinite">
                                  </animateTransform>
                              </circle>
                            </svg>
                          </div>
                        </load-more>
                      {% endif %}
                    {% endif %}
                  {% endif %}
                  {% if paginate.pages > 1 and block.settings.pagination_type == 'page_number' %}
                    {% render 'pagination', paginate: paginate, anchor: '' %}
                  {% endif %}
                </div>
              {% endpaginate %}
            </div>
        {% endcase %}
      {% endfor %}

      {% if section.settings.filter_layout == 'horizontal' and section.settings.horizontal_top_filter_sticky == true and collection.products_count > 0 %}
      <sticky-filter-button class="sticky-filter-button-wrapper" data-sticky-button-filter>
        <button class="button filter-toggle-button hidden d-md-flex" data-filters-nav="" data-sticky-toggle-button>
          <svg class="open-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M16 6a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1h-2.55a2.5 2.5 0 0 1-4.9 0H3V7h10.55ZM8 15a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm-2.45 1a2.5 2.5 0 0 1 4.9 0H21v1H10.45a2.5 2.5 0 0 1-4.9 0H3v-1h2.55Z">
            </path>
          </svg> 
          <svg class="close-icon hidden" width="20" height="20" viewBox="0 0 23.691 22.723">
            <g transform="translate(-126.154 -143.139)">
              <line x2="23" y2="22" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></line>
              <path d="M0,22,23,0" transform="translate(126.5 143.5)" fill="none" stroke="CurrentColor" stroke-width="2"></path>
            </g>
          </svg> 
        </button>
        <div class="sticky-horizontal-filter" data-sticky-filter>
          {% liquid
            if section.settings.filter_layout == 'horizontal' and section.settings.horizontal_top_filter_sticky == true
              if isfiltersSidebar and section.blocks.size >= 1 and collection.filters.size > 0
                render 'horizontal-sticky-filters', section: section, block: section.blocks
              endif
            endif
          %}
        </div>
      </sticky-filter-button>
      {% endif %}
    </div>
  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --image_overlay_opacity: {{ section.settings.overlay_opacity }};
    }

  {%   if section.settings.filter_layout == 'vertical' %}
     @media (min-width:1025px) {
      #shopify-section-{{ section.id }}{
        {% if section.settings.desktop_row_count <= 3 %}
          --row_count: {{ section.settings.desktop_row_count }};
        {% else %}
            --row_count: 3;
        {% endif %}

      }
    }
    @media (min-width:1280px) {
      #shopify-section-{{ section.id }} {
        --row_count: {{ section.settings.desktop_row_count }};
      }
    }
  {%  else %}
       #shopify-section-{{ section.id }} {
      --row_count: {{ section.settings.desktop_row_count }};
    } 
  {% endif %}
  @media (min-width:768px) {
    #shopify-section-{{ section.id }} .collection-list--inner {
      --column_count: {{ section.settings.column_count }};
    }
  }

    @media only screen and (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          --top_spacing: {{ section.settings.top_space_mobile }}px !important;
          --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
        }
        #shopify-section-{{ section.id }} .collection-list--inner {
        --column_count: 2;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
        @media(max-width: 767px) {
            #shopify-section-{{ section.id }} {
              display: none !important;
            }
        }
    {% elsif section.settings.section_visibility == 'small' %}
        @media(min-width: 768px) {
            #shopify-section-{{ section.id }}  {
              display: none !important;
            }
        }
    {% endif %}

    /* Styles pour les cartes éditoriales */
    #shopify-section-{{ section.id }} .edito-card {
      grid-column: span 1;
    }

    #shopify-section-{{ section.id }} .edito-card--double {
      grid-column: span 2;
    }

    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} .edito-card--double {
        grid-column: span 1;
      }
    }
</style>

{% schema %}
{
  "name": "t:sections.main-collection.name",
  "tag": "section",
  "class": "section-main-collection",
  "blocks": [
    {
      "type": "products_grid",
      "name": "t:sections.main-collection.blocks.products_grid.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "products_limit",
          "min": 9,
          "max": 36,
          "step": 3,
          "default": 12,
          "label": "t:sections.main-collection.blocks.products_grid.settings.products_limit.label"
        },
        {
          "type": "select",
          "id": "card_image_size",
          "label": "t:sections.main-collection.blocks.products_grid.settings.card_image_size.label",
          "default": "auto",
          "options": [
            {
              "value": "auto",
              "label": "t:sections.all.image_ratio.auto_ratio.label"
            },
            {
              "value": "landscape",
              "label": "t:sections.all.image_ratio.landscape.label"
            },
            {
              "value": "portrait",
              "label": "t:sections.all.image_ratio.portrait.label"
            },
            {
              "value": "square",
              "label": "t:sections.all.image_ratio.square.label"
            }
          ]
        },
        {
          "type": "select",
          "id": "pagination_type",
          "default": "page_number",
          "label": "t:sections.main-collection.blocks.products_grid.settings.pagination_type.label",
          "options": [
            {
              "value": "page_number",
              "label": "t:sections.main-collection.blocks.products_grid.settings.pagination_type.page_number.label"
            },
            {
              "value": "load_more",
              "label": "t:sections.main-collection.blocks.products_grid.settings.pagination_type.load_more.label"
            },
            {
              "value": "infinite",
              "label": "t:sections.main-collection.blocks.products_grid.settings.pagination_type.infinite.label"
            }
          ]
        }
      ]
    },
    {
      "type": "edito_card",
      "name": "Carte éditoriale",
      "settings": [
        {
          "type": "range",
          "id": "position",
          "min": 1,
          "max": 50,
          "step": 1,
          "default": 6,
          "label": "Position dans la grille",
          "info": "La carte apparaîtra à cette position dans la grille de produits"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Type de média",
          "default": "image",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Vidéo"
            }
          ]
        },
        {
          "type": "select",
          "id": "card_size",
          "label": "Taille de la carte",
          "default": "single",
          "options": [
            {
              "value": "single",
              "label": "Simple (1 colonne)"
            },
            {
              "value": "double",
              "label": "Double (2 colonnes)"
            }
          ]
        },
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image mobile (optionnel)",
          "info": "Si non définie, l'image desktop sera utilisée"
        },
        {
          "type": "header",
          "content": "Vidéo"
        },
        {
          "type": "video",
          "id": "video_shopify",
          "label": "Vidéo Shopify"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "URL vidéo externe",
