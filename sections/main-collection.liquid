<script>
(function() {
  const displayed = {};
  
  function process() {
    document.querySelectorAll('[data-edito-position]:not([data-processed])').forEach(card => {
      const pos = card.dataset.editoPosition;
      card.setAttribute('data-processed', 'true');
      if (displayed[pos]) {
        card.remove();
      } else {
        displayed[pos] = true;
      }
    });
  }
  
  // Exécuter immédiatement et à chaque changement du DOM
  process();
  new MutationObserver(process).observe(document.body, { childList: true, subtree: true });
})();
</script>
