

  {{ 'dual-media-slideshow.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'dual-media-slideshow.js' | asset_url }}" defer></script>
  {% liquid
    if section.settings.section_container_width == 'global'
      assign containerClass = settings.container_width
    else
      assign containerClass = section.settings.section_container_width
    endif
  %}
  <div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }} ">
    <div class="{{ containerClass }}">
      <div class="dual-media-slideshow--container">
        <div class="dual-media-slideshow--main {{ section.settings.column_ratio }}" is="dual-media-slideshow">
          <div class="dual-media-slideshow dual-media-slideshow--left d-none d-md-block">
              <div class="dual-media-slideshow--outer swiper"
              data-swiper-left='{
                "speed": 1500,
                "slidesPerView": 1,
                {% if section.settings.carousel_autoplay %}
                "autoplay": {
                  "delay": {{ section.settings.carousel_interval | times:1000 }}
                },
                {% endif %}
                {% if section.settings.left_slide_animation_style == 'fade' %}
                "effect": "fade",
                {% elsif section.settings.left_slide_animation_style == 'coverflow' %}
                "effect": "coverflow",
                "coverflowEffect": {
                  "rotate": 50,
                  "stretch": "50%",
                  "depth": 200,
                  "modifier": 1,
                  "slideShadows": true
                },
                {% elsif section.settings.left_slide_animation_style == 'creative' %}
                "effect": "creative",
                  "creativeEffect": {
                  "prev": {
                    "shadow": true,
                    "translate": [0, 0, -400]
                  },
                  "next": {
                    "translate": ["100%", 0, 0]
                  }
                },
                {% endif %}
                "navigation": {
                  "nextEl": ".swiper-button-next-{{ section.id }}",
                  "prevEl": ".swiper-button-prev-{{ section.id }}"
                }
              }'
              >
                <div class="dual-media-slideshow--wrapper swiper-wrapper">
                  {%- assign index = 0 -%}
                  {%- for block in section.blocks -%}
                    {%- assign rem = forloop.index0 | modulo: 2 -%}
                    {%- if rem == 0 -%}
                      <div class="dual-media-slide swiper-slide scheme-{{ block.settings.color_scheme }} section-{{ block.settings.section_background }}{% if section.settings.enable_animation %} animeslide-slide{% endif %}" id="dual-media-slide-{{ block.id }}" data-swiper-slide-index="{{ index }}" {{ block.shopify_attributes }}>
                        <div class="dual-media-slide--media media-overlay">
                          <div class="media media-fixed">
                            {% liquid
                              if block.settings.slide_video != blank 
                                echo block.settings.slide_video | media_tag: loading: 'lazy', class: 'no-js-hidden dual-media-slide--video', autoplay: true, loop: true, mute: true, controls: false, preload: 'none'
                              elsif block.settings.slide_image != blank                          
                                assign sizes = '100vw'
                                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                
                                if forloop.first
                                  assign fetch_priority = 'high'
                                  echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                                else
                                  echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, loading: 'lazy'
                                endif
                              else
                                echo 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg'
                              endif
                            %}
                          </div>
                        </div> 
                        {%- liquid
                          assign buttonsExists = false
                          if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank
                            assign buttonsExists = true
                          endif
                          if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank
                            assign buttonsExists = true
                          endif

                          if block.settings.description != blank or block.settings.heading != blank or buttonsExists
                            assign contentExists = true
                          endif
                        -%}
                        {%- if contentExists -%}
                          <div class="dual-media-slide--content content-position-{{ block.settings.content_position }} text-{{ block.settings.content_alignment }} {{ block.settings.content_width }}">
                            {%- if block.settings.description != blank or block.settings.heading != blank -%}
                              <div class="dual-media-slide--content-inner">
                                {% if block.settings.description != blank and block.settings.show_description == 'above-heading' %}
                                  <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                    {{ block.settings.description | newline_to_br }}
                                  </p>
                                {% endif %}
                                {% if block.settings.heading != blank %}
                                  {%- capture markersPrefix -%}
                                    <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                                  {%- endcapture -%}
                                  {%- capture markersSuffix -%}
                                    </span>
                                  {%- endcapture -%}
                                  <{{ block.settings.heading_tag }} class="dual-media-slide--heading{% if block.settings.heading_tag == 'div' or block.settings.heading_tag == 'span' or block.settings.heading_tag == 'p' %} heading-font{% endif %}{% if section.settings.enable_animation %} animeslide-heading{% endif %} {{ block.settings.heading_size_slide }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                    {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                                  </{{ block.settings.heading_tag }}> 
                                {% endif %}
                                {% if block.settings.description != blank and block.settings.show_description == 'below-heading' %}
                                  <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                    {{ block.settings.description | newline_to_br }}
                                  </p>
                                {% endif %}
                              </div>
                            {%- endif -%}

                            {%- if buttonsExists -%}
                              <div class="dual-media-slide--buttons">
                                {% if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank %}
                                  {% liquid
                                    if block.settings.primary_button_syle == 'link'
                                      assign primary_button_class = 'text-underline'
                                      assign primary_show_as_link = true
                                    else
                                      assign primary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                      assign primary_show_as_link = false
                                    endif
                                  %}
                                  <div class="slideshow--primary-button{% if section.settings.enable_animation %} animeslide-primary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                    <a href="{{ block.settings.primary_button_url }}" class="{{ primary_button_class }} {{ block.settings.primary_button_syle }}-button">
                                      {% render 'button-appearance', button_text: block.settings.primary_button_text, icon: 'arrow-right', show_as_link: primary_show_as_link %}
                                    </a>
                                  </div>
                                {% endif %}

                                {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank %}
                                  {% liquid
                                    if block.settings.secondary_button_syle == 'link'
                                      assign secondary_button_class = 'text-underline'
                                      assign secondary_show_as_link = true
                                    else
                                      assign secondary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                      assign secondary_show_as_link = false
                                    endif 
                                  %}
                                  <div class="slideshow--secondary-button{% if section.settings.enable_animation %} animeslide-secondary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                    <a href="{{ block.settings.secondary_button_url }}" class="{{ secondary_button_class }}{%  unless block.settings.secondary_button_syle == 'outline' or block.settings.secondary_button_syle == 'link'  %} secondary--button{% endunless %} {{ block.settings.secondary_button_syle }}-button">
                                      {% render 'button-appearance', button_text: block.settings.secondary_button_text, icon: 'arrow-right', show_as_link: secondary_show_as_link %}
                                    </a>
                                  </div>
                                {% endif %}
                              </div> 
                            {%- endif -%}
                          </div>
                        {%- endif -%}

                        {%- if block.settings.backdrop_text != blank -%}
                          <div class="dual-media-slide--backdrop-text heading-font">
                            {{ block.settings.backdrop_text }}
                          </div>
                        {%- endif -%}
                      </div>
                      {%- assign index = index | plus: 1 -%}
                        
                    {%- endif -%}
                  {%- endfor -%}
                  
                </div>
              </div>
          </div>
          {%- if section.blocks.size > 1 -%}
            <div class="dual-media-slideshow dual-media-slideshow--right d-none d-md-block">
                <div class="dual-media-slideshow--outer swiper"
                  data-swiper-right='{
                    "speed": 1500,
                    {% if section.settings.right_slide_animation_style == 'fade' %}
                    "effect": "fade",
                    {% elsif section.settings.right_slide_animation_style == 'coverflow' %}
                    "effect": "coverflow",
                    "coverflowEffect": {
                      "rotate": 50,
                      "stretch": "50%",
                      "depth": 200,
                      "modifier": 1,
                      "slideShadows": true
                    },
                    {% elsif section.settings.right_slide_animation_style == 'creative' %}
                    "effect": "creative",
                      "creativeEffect": {
                      "prev": {
                        "shadow": true,
                        "translate": [0, 0, -400]
                      },
                      "next": {
                        "translate": ["100%", 0, 0]
                      }
                    },
                    {% endif %}
                    "slidesPerView": 1
                  }'
                >
                  <div class="dual-media-slideshow--wrapper swiper-wrapper">
                    {%- assign right_index = 0 -%}
                    {%- for block in section.blocks -%}
                      {%- assign rem = forloop.index0 | modulo: 2 -%}
                      {%- if rem == 1 -%}
                        <div class="dual-media-slide swiper-slide scheme-{{ block.settings.color_scheme }} section-{{ block.settings.section_background }}{% if section.settings.enable_animation %} animeslide-slide{% endif %}" id="dual-media-slide-{{ block.id }}" data-swiper-slide-index="{{ right_index }}" {{ block.shopify_attributes }}>
                          <div class="dual-media-slide--media media-overlay">
                            <div class="media media-fixed">
                              {% liquid
                                if block.settings.slide_video != blank 
                                  echo block.settings.slide_video | media_tag: loading: 'lazy', class: 'no-js-hidden dual-media-slide--video', autoplay: true, loop: true, mute: true, controls: false, preload: 'none'
                                elsif block.settings.slide_image != blank                          
                                  assign sizes = '100vw'
                                  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                  
                                  if forloop.first
                                    assign fetch_priority = 'high'
                                    echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                                  else
                                    echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, loading: 'lazy'
                                  endif
                                else
                                  echo 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg'
                                endif
                              %}
                            </div>
                          </div> 
                          {%- liquid
                            assign buttonsExists = false
                            if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank
                              assign buttonsExists = true
                            endif
                            if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank
                              assign buttonsExists = true
                            endif
    
                            if block.settings.description != blank or block.settings.heading != blank or buttonsExists
                              assign contentExists = true
                            endif
                          -%}
                          {%- if contentExists -%}
                            <div class="dual-media-slide--content content-position-{{ block.settings.content_position }} text-{{ block.settings.content_alignment }} {{ block.settings.content_width }}">
                              {%- if block.settings.description != blank or block.settings.heading != blank -%}
                                <div class="dual-media-slide--content-inner">
                                  {% if block.settings.description != blank and block.settings.show_description == 'above-heading' %}
                                    <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      {{ block.settings.description | newline_to_br }}
                                    </p>
                                  {% endif %}
                                  {% if block.settings.heading != blank %}
                                    {%- capture markersPrefix -%}
                                      <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                                    {%- endcapture -%}
                                    {%- capture markersSuffix -%}
                                      </span>
                                    {%- endcapture -%}
                                    <{{ block.settings.heading_tag }} class="dual-media-slide--heading{% if block.settings.heading_tag == 'div' or block.settings.heading_tag == 'span' or block.settings.heading_tag == 'p' %} heading-font{% endif %}{% if section.settings.enable_animation %} animeslide-heading{% endif %} {{ block.settings.heading_size_slide }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                                    </{{ block.settings.heading_tag }}> 
                                  {% endif %}
                                  {% if block.settings.description != blank and block.settings.show_description == 'below-heading' %}
                                    <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      {{ block.settings.description | newline_to_br }}
                                    </p>
                                  {% endif %}
                                </div>
                              {%- endif -%} 
                              
                              {%- if buttonsExists -%}
                                <div class="dual-media-slide--buttons">
                                  {% if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank %}
                                    {% liquid
                                      if block.settings.primary_button_syle == 'link'
                                        assign primary_button_class = 'text-underline'
                                        assign primary_show_as_link = true
                                      else
                                        assign primary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                        assign primary_show_as_link = false
                                      endif
                                    %}
                                    <div class="slideshow--primary-button{% if section.settings.enable_animation %} animeslide-primary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      <a href="{{ block.settings.primary_button_url }}" class="{{ primary_button_class }} {{ block.settings.primary_button_syle }}-button">
                                        {% render 'button-appearance', button_text: block.settings.primary_button_text, icon: 'arrow-right', show_as_link: primary_show_as_link %}
                                      </a>
                                    </div>
                                  {% endif %}
    
                                  {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank %}
                                    {% liquid
                                      if block.settings.secondary_button_syle == 'link'
                                        assign secondary_button_class = 'text-underline'
                                        assign secondary_show_as_link = true
                                      else
                                        assign secondary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                        assign secondary_show_as_link = false
                                      endif 
                                    %}
                                    <div class="slideshow--secondary-button{% if section.settings.enable_animation %} animeslide-secondary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      <a href="{{ block.settings.secondary_button_url }}" class="{{ secondary_button_class }}{%  unless block.settings.secondary_button_syle == 'outline' or block.settings.secondary_button_syle == 'link'  %} secondary--button{% endunless %} {{ block.settings.secondary_button_syle }}-button">
                                        {% render 'button-appearance', button_text: block.settings.secondary_button_text, icon: 'arrow-right', show_as_link: secondary_show_as_link %}
                                      </a>
                                    </div>
                                  {% endif %}
                                </div> 
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.backdrop_text != blank -%}
                            <div class="dual-media-slide--backdrop-text heading-font">
                              {{ block.settings.backdrop_text }}
                            </div>
                          {%- endif -%}
                        </div>
                        {%- assign right_index = right_index | plus: 1 -%}
                      {%- endif -%}
                    {%- endfor -%}
                    
                  </div>
                </div>
            </div>
          {%- endif -%}

          <div class="dual-media-slideshow dual-media-slideshow--mobile d-block d-md-none">
            <div class="dual-media-slideshow--outer swiper" 
              data-swiper-mobile='{
                "speed": 500,
                "slidesPerView": 1,
                {% if section.settings.carousel_autoplay %}
                "autoplay": {
                  "delay": {{ section.settings.carousel_interval | times:1000 }}
                },
                {% endif %}
                "navigation": {
                  "enabled": false
                },
                "pagination": {
                  "el": ".swiper-pagination-{{ section.id }}",
                  "clickable": true,
                  "dynamicBullets": false
                }
              }'>
              <div class="dual-media-slideshow--wrapper swiper-wrapper">
                {%- for block in section.blocks -%}
                  <div class="dual-media-slide swiper-slide scheme-{{ block.settings.color_scheme }} section-{{ block.settings.section_background }}{% if section.settings.enable_animation %} animeslide-slide{% endif %}" id="dual-media-slide-{{ block.id }}" data-swiper-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                    <div class="dual-media-slide--media media-overlay">
                      <div class="media media-fixed">
                        {% liquid
                          if block.settings.slide_video != blank 
                            echo block.settings.slide_video | media_tag: loading: 'lazy', class: 'no-js-hidden dual-media-slide--video', autoplay: true, loop: true, mute: true, controls: false, preload: 'none'
                          elsif block.settings.slide_image != blank                          
                            assign sizes = '100vw'
                            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            
                            if forloop.first
                              assign fetch_priority = 'high'
                              echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                            else
                              echo block.settings.slide_image | image_url: width: 3840 | image_tag: sizes: sizes, widths: widths, loading: 'lazy'
                            endif
                          else
                            echo 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg'
                          endif
                        %}
                      </div>
                    </div> 
                    {%- liquid
                      assign buttonsExists = false
                      if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank
                        assign buttonsExists = true
                      endif
                      if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank
                        assign buttonsExists = true
                      endif

                      if block.settings.description != blank or block.settings.heading != blank or buttonsExists
                        assign contentExists = true
                      endif
                    -%}
                    {%- if contentExists -%}
                      <div class="dual-media-slide--content content-position-{{ block.settings.content_position }} text-{{ block.settings.content_alignment }} {{ block.settings.content_width }}">
                        {%- if block.settings.description != blank or block.settings.heading != blank -%}
                          <div class="dual-media-slide--content-inner">
                            {% if block.settings.description != blank and block.settings.show_description == 'above-heading' %}
                              <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                {{ block.settings.description | newline_to_br }}
                              </p>
                            {% endif %}
                            {% if block.settings.heading != blank %}
                              {%- capture markersPrefix -%}
                                <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                              {%- endcapture -%}
                              {%- capture markersSuffix -%}
                                </span>
                              {%- endcapture -%}
                              <{{ block.settings.heading_tag }} class="dual-media-slide--heading{% if block.settings.heading_tag == 'div' or block.settings.heading_tag == 'span' or block.settings.heading_tag == 'p' %} heading-font{% endif %}{% if section.settings.enable_animation %} animeslide-heading{% endif %} {{ block.settings.heading_size_slide }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                              </{{ block.settings.heading_tag }}> 
                            {% endif %}
                            {% if block.settings.description != blank and block.settings.show_description == 'below-heading' %}
                              <p class="dual-media-slide--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                {{ block.settings.description | newline_to_br }}
                              </p>
                            {% endif %}
                          </div>
                        {%- endif -%}

                        {%- if buttonsExists -%}
                          <div class="dual-media-slide--buttons">
                            {% if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank %}
                              {% liquid
                                if block.settings.primary_button_syle == 'link'
                                  assign primary_button_class = 'text-underline'
                                  assign primary_show_as_link = true
                                else
                                  assign primary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                  assign primary_show_as_link = false
                                endif
                              %}
                              <div class="slideshow--primary-button{% if section.settings.enable_animation %} animeslide-primary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                <a href="{{ block.settings.primary_button_url }}" class="{{ primary_button_class }} {{ block.settings.primary_button_syle }}-button">
                                  {% render 'button-appearance', button_text: block.settings.primary_button_text, icon: 'arrow-right', show_as_link: primary_show_as_link %}
                                </a>
                              </div>
                            {% endif %}

                            {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank %}
                              {% liquid
                                if block.settings.secondary_button_syle == 'link'
                                  assign secondary_button_class = 'text-underline'
                                  assign secondary_show_as_link = true
                                else
                                  assign secondary_button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                  assign secondary_show_as_link = false
                                endif 
                              %}
                              <div class="slideshow--secondary-button{% if section.settings.enable_animation %} animeslide-secondary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                <a href="{{ block.settings.secondary_button_url }}" class="{{ secondary_button_class }}{%  unless block.settings.secondary_button_syle == 'outline' or block.settings.secondary_button_syle == 'link'  %} secondary--button{% endunless %} {{ block.settings.secondary_button_syle }}-button">
                                  {% render 'button-appearance', button_text: block.settings.secondary_button_text, icon: 'arrow-right', show_as_link: secondary_show_as_link %}
                                </a>
                              </div>
                            {% endif %}
                          </div> 
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.backdrop_text != blank -%}
                      <div class="dual-media-slide--backdrop-text heading-font">
                        {{ block.settings.backdrop_text }}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
        
        {% if section.blocks.size > 1 %}
          <div class="swiper--button-wrapper d-none d-md-block">
            {% liquid 
              if settings.slilder_button_style == 'square'
                assign btnIcon = 'curve-arrow'
              else
                assign btnIcon = 'arrow-icon'
              endif
            %}
            
            <swiper-nav class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }} button-{{ settings.slilder_button_style }}" is="magnet-area">
              {% render 'icons', icon: btnIcon %}
            </swiper-nav>
            <swiper-nav class="swiper-button-next swiper-button swiper-button-next-{{ section.id }} button-{{ settings.slilder_button_style }}" is="magnet-area">
              {% render 'icons', icon: btnIcon %}
            </swiper-nav>
          </div>
        
          <div class="swiper-pagination swiper-pagination-{{ section.id }} d-block d-md-none"></div>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
    #shopify-section-{{ section.id }}{
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --media_height: {% if section.settings.desktop_height == '100vh' %}calc(100vh - var(--announcement_height, 0px)){% else %}{{ section.settings.desktop_custom_height }}px{% endif %};
      --column_gap: {{ section.settings.desktop_grid_gap }}px;
    }

    {%- for block in section.blocks -%}
      #dual-media-slide-{{ block.id }} {
        --image_overlay_opacity: {{ block.settings.overlay_opacity }};
        --backdrop_text_color: {{ block.settings.backdrop_text_color }};
        --backdrop_text_size: {{ block.settings.backdrop_text_size }}px;
        --backdrop_text_position_y: {{ block.settings.backdrop_text_position_y }}%;
      }
    {% endfor %}

    @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}{
          --top_spacing: {{ section.settings.top_space_mobile }}px;
          --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
          --media_height: {% if section.settings.mobile_height == '100vh' %}100vh{% else %}{{ section.settings.mobile_custom_height }}px{% endif %};
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        } 
      }
    {% endif %}
  </style>

