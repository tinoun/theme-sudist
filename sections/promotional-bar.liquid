{% if section.index <= 2 %}
  {{ 'promotional-bar.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'promotional-bar.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} {{ section.settings.radius_selector }} {{ section.settings.mobile_radius_selector }} section-{{ section.settings.section_background }}">
  <promotional-bar>
    <div class="promotional-bar--main" id="slideshow-bottom--content-{{ section.id }}">
      {% if section.settings.background_image != blank %}
        <div class="background--overlay-image {{ section.settings.radius_selector }} {{ section.settings.mobile_radius_selector }}">
          {% render 'lazy-image', image: section.settings.background_image %}
        </div>
      {% endif %}
      <div class="container-fullwidth">
        <div class="promotional-bar--wrapper">
          <div class="promotional-bar--left" {% if settings.is_layout_animation %} data-card-animate {% endif %}>
            <div class="promotional-bar--left-content">
              {% if section.settings.collection_list.count > 0 %}
                <div class="promotional-bar--collection-list">
                  {% for collection in section.settings.collection_list %}
                    <a
                      href="{{ collection.url }}"
                      class="promotional-bar--collection-item d-block tooltip-parent"
                      title="{{ collection.title }}"
                    >
                      <div class="promotional-bar--collection-img media-wrapper rounded border border-width-2">
                        <div class="media" style="--image_ratio:100%;">
                          {% render 'lazy-image', image: collection.featured_image %}
                        </div>
                      </div>
                      <span class="promotional-bar-tooltip tooltip">{{ collection.title }}</span>
                    </a>
                  {% endfor %}
                </div>
              {% endif %}
              <div class="promotional-bar--inner-content">
                {% if section.settings.left_text != blank %}
                  <p class="promotional-bar--title {{ section.settings.left_description_size }}">
                    {{ section.settings.left_text | newline_to_br }}
                  </p>
                {% endif %}

                {% if section.settings.link_text != blank and section.settings.link_url != blank %}
                  <a
                    href="{{ section.settings.link_url }}"
                    class="link-arrow text-underline text-small font-bold"
                    title="{{ section.settings.link_text }}"
                  >
                    {{ section.settings.link_text }}
                    {% unless section.settings.button_syle == 'link' -%}
                      {%- render 'icons', icon: 'arrow-circle' -%}
                    {%- endunless %}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
          {% if section.settings.enable_video or section.settings.right_short_description != blank or section.settings.right_text_heading != blank%}
          <div class="promotional-bar--right" {% if settings.is_layout_animation %} data-card-animate {% endif %}>
            <div class="promotional-bar--video-content">
              {%- liquid
                assign poster = section.settings.video.preview_image
                assign cover_image = section.settings.cover_image
                if cover_image != null
                  assign poster = cover_image
                endif
              -%}
              {% if section.settings.enable_video %}
              <div
                class="promotional-bar--video media-wrapper cursor-pointer"
                promotional-bar-video
                data-id="{{ section.id }}"
              >
                {% if poster != null %}
                  {% render 'lazy-image', image: poster, class: '' %}
                {% else %}
                  {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                {% endif %}

                <deferred-media class="deferred-media">
                  <template>
                    {% if section.settings.video != blank %}
                      <video
                        class="videoBackgroundFile"
                        controls
                        data-video-image-wrapper
                      >
                        <source
                          src="{% if section.settings.video.sources[0].url contains 'mp4' %}{{ section.settings.video.sources[0].url -}}{% else %}{{ section.settings.video.sources[1].url -}}{% endif %}"
                          type="video/mp4"
                        >
                      </video>
                    {% endif %}
                  </template>
                </deferred-media>

                {% if section.settings.video != blank %}
                  <div class="promotional-bar--video-icon">
                    {% render 'icons', icon: 'video-icon' %}
                  </div>
                {% endif %}
              </div>
              {% endif %}

              {% if section.settings.right_short_description != blank or section.settings.right_text_heading != blank %}
                <div class="promotional-bar--video--content-inner">
                  {% if section.settings.right_text_heading != blank %}
                    <p class="promotional-bar--video-heading heading-font text-xlarge">
                      {{ section.settings.right_text_heading }}
                    </p>
                  {% endif %}

                  {% if section.settings.right_short_description != blank %}
                  <p class="promotional-bar--title {{ section.settings.right_description_size }}">
                    {{ section.settings.right_short_description }}
                  </p>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% if poster != null %}
      {% render 'popup',
        modal_name: 'video',
        modal_position: 'center',
        modal_size: section.settings.video_size,
        popup_color_scheme: section.settings.color_scheme,
        section: section
      %}
    {% endif %}
  </promotional-bar>
</div>

<style>
    #shopify-section-{{ section.id }} .section-spacing {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --image_overlay_opacity: {{ section.settings.overlay_opacity }};
      --image_blur_opacity: {{ section.settings.blur_effect }}px;
      {% if section.settings.section_corner_radius == 'custom' %}
        --corner_radius: {{ section.settings.custom_section_corner_radius }}px;
      {% else %}
        --corner_radius: {{ settings.card_radius }}px;
      {% endif %}
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .section-spacing {
        --top_spacing: {{ section.settings.top_space_mobile }}px !important;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
