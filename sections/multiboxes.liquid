{% if section.index <= 2 %}
{{ 'multiboxes.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'multiboxes.css' | asset_url | stylesheet_tag }}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }} overflow-hidden">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <variety-heading class="section--header text-{{ section.settings.heading_alignment }}">
    <div class="section--header-inner">
          {% if section.settings.heading != blank %}
            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}
            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
            {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
            </{{ section.settings.seo_heading }}>
          {% endif %}
          {% if section.settings.description != blank %}
            <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>{{ section.settings.description | newline_to_br }}</p>
          {% endif %}
        </div>
      </variety-heading>
    {% endif %}
  </div>
    {% if section.blocks.size > 0 %} 
    
       <div class="{{ settings.container_width }}{% if section.settings.enable_swipe_mobile %} m-pr-0{% endif %}">
        <div class="multiboxes--wrapper {% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
          {% for block in section.blocks %}
           
            {% liquid 
              assign is_content_added = true
              if block.settings.heading == blank and block.settings.image_description == blank and section.settings.show_count == false
              assign is_content_added = false
              endif
    
              if is_content_added == false 
                if block.settings.btn_text == blank or block.settings.btn_link == blank
                  assign is_content_added = false
                endif
              endif    
              assign image_size = section.settings.image_ratio
              if image_size == 'landscape' 
                  assign imageRatio = '70%'
                elsif image_size == 'square'
                  assign imageRatio = '100%' 
                elsif image_size == 'portrait'
                  assign imageRatio = '130%'
              else
                  if block.settings.image != blank
                      assign imageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | minus: 1 | append: '%'
                  else
                      assign imageRatio = 100 | append: '%'
                  endif
              endif
            %}
          <expand-set class="multiboxes--item animate-hover width-100 pos-relative{% if forloop.index == 1 %} active{% endif %}{% if is_content_added == false %} empty-content{% endif %}" data-column="{{forloop.index}}">
              <div class="multiboxes--image media-wrapper media-overlay width-100 ">
                <div class="media media-{{ section.settings.image_ratio }}" style="--image_ratio:{{ imageRatio }};">
                  {% if block.settings.image != blank %}
                      {% render 'lazy-image', image: block.settings.image, class: 'media-with-collections-item' %}
                  {% else %}
                      {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                {% if section.settings.show_count %}
                  <div class="multiboxes--count heading-font h1">{{ 0 | append: forloop.index }}</div>
                {% endif %}
              </div>         
              
              <div class="multiboxes--content width-100">
                {% if is_content_added == true %}
                <div class="multiboxes--content-inner width-100">
                  <div class="multiboxes--content-inner-box width-100 height-100">
                    {% if block.settings.heading != blank %}
                        <h6 class="multiboxes--heading heading-font {{ section.settings.block_heading_size }}">
                          {{ block.settings.heading }}
                        </h6>
                    {% endif %}
                    {% if block.settings.image_description != blank %}
                        <p class="multiboxes--description {{ section.settings.block_description_size }}">{{ block.settings.image_description }}</p>
                    {% endif %}
                    {% if block.settings.btn_text != blank and block.settings.btn_link != blank %}                      
                        {% liquid
                          if block.settings.button_style == 'link'
                            assign show_as_link = true
                            assign button_class = 'text-underline'
                          else
                            assign button_class = 'button' | append: ' ' | append: settings.button_animation_style
                            assign show_as_link = false
                          endif
                        %}
                        <div class="multiboxes--button">
                            <a href="{{ block.settings.btn_link }}" class="{{ button_class }} {{ block.settings.button_style }}-button">
                              {% render 'button-appearance', button_text: block.settings.btn_text, icon: 'arrow-right', show_as_link: show_as_link %}
                            </a>
                        </div>
                    {% endif %}
                  </div>
                  {% if section.settings.show_count %}
                    <div class="multiboxes--count heading-font h1">{{ 0 | append: forloop.index }}</div>
                  {% endif %}
                </div>
              {% endif %}
              </div>
            </expand-set>
          {% endfor %}
        </div>
       </div>
    {% endif %}
</div>

<style>
  #shopify-section-{{ section.id }}{
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --image_overlay_opacity: {{ section.settings.overlay_opacity }};
  }
  @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}{
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
      }
  }
  {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
          #shopify-section-{{ section.id }}{
              display: none !important;
          }
      }
  {% elsif section.settings.section_visibility == 'small' %}
      @media(min-width: 768px) {
          #shopify-section-{{ section.id }}{
              display: none !important;
          }
      }
  {% endif %}
</style>
    
