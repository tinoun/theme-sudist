{% if section.index <= 2 %}
  {{ 'featured-collection.css' | asset_url | preload_tag: as: 'style' }}
  {{ 'edito-card.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'edito-card.css' | asset_url | stylesheet_tag }}

{% liquid
  if section.settings.collection_style == 'carousel'
    assign is_slider = true
  else
    assign is_slider = false
  endif

  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif

  if section.settings.section_container_width == 'global'
    assign HeadingContainerClass = settings.container_width
  else
    if section.settings.section_container_width  != 'no-container'
      assign HeadingContainerClass = section.settings.section_container_width
    else 
      assign HeadingContainerClass = settings.container_width
    endif
  endif

  comment
    Récupérer les blocs édito triés par position
  endcomment
  assign edito_blocks = section.blocks | where: "type", "edito_card" | sort: "settings.position"
%}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}" id="featured-collection-fullwidth-{{ section.id }}">
  <div class="{{ HeadingContainerClass }} {% if section.settings.mobile_swipe or section.settings.collection_style == 'carousel' %}m-pr-0{% endif %}">
    {% if section.settings.heading != blank or section.settings.description != blank or is_slider %}
      <variety-heading class="section--header{% if is_slider %} with--arrow{% endif %}{% if section.settings.btn_text != blank and section.settings.btn_link != blank %} with-button{% endif %} text-{{ section.settings.heading_alignment}}">
        <div class="section--header-inner">
          {%- if section.settings.heading != blank -%}
            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}

            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
              {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
            </{{ section.settings.seo_heading }}>
          {%- endif -%}

          {% if section.settings.description != blank %}
            <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
              {{ section.settings.description | newline_to_br }}
            </p>
          {% endif %}
        </div>
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
          {% liquid
            if section.settings.button_style == 'link'
              assign button_class = 'text-underline' 
              assign show_as_link = true
            else 
              assign button_class = 'button' | append: ' ' | append: section.settings.button_size | append: ' ' | append: settings.button_animation_style 
              assign show_as_link = false
            endif
          %}
          <div class="section--btn">
            <a href="{{ section.settings.btn_link }}" class="{{ button_class }} {{ section.settings.button_style }}-button">
              {% render 'button-appearance', button_text: section.settings.btn_text, icon: 'arrow-right', show_as_link: show_as_link %}
            </a>
          </div>           
        {% endif %}
        {% if is_slider %} 
          <div class="swiper--custom-buttons d-none d-md-flex">
            {% liquid 
              if settings.slilder_button_style == 'square'
                assign btnIcon = 'curve-arrow'
              else
                assign btnIcon = 'arrow-icon'
              endif
            %}
            <swiper-nav class="swiper-button-prev swiper-button-prev-{{ section.id }} swiper-button button-{{ settings.slilder_button_style }}">
              {% render 'icons', icon: btnIcon %}
            </swiper-nav>
            <swiper-nav class="swiper-button-next swiper-button-next-{{ section.id }} swiper-button button-{{ settings.slilder_button_style }}">
              {% render 'icons', icon: btnIcon %}
            </swiper-nav>
          </div>
        {% endif %}
      </variety-heading>
    {% endif %}
  </div>
  <div class="{{ containerClass }} {% if section.settings.mobile_swipe or section.settings.collection_style == 'carousel' %}m-pr-0{% endif %}">
    {% if is_slider %}
      <swiper-content data-resize="false">
      <div class="featured-collection--outer{% if is_slider %} swiper{% endif %}"
        {% if is_slider %}
          data-swiper='
            {
                "loop": false,
                "speed": 850,
                "slidesPerView": 1.2,
                "scrollbar": {
                  "el": ".swiper-scrollbar-{{ section.id }}",
                  "draggable": true
                },
                "navigation": {
                  "nextEl": ".swiper-button-next-{{ section.id }}",
                  "prevEl": ".swiper-button-prev-{{ section.id }}"
                },
                "breakpoints": {
                    "768": {
                      "slidesPerView": 2.5
                    },
                    "992": {
                      "slidesPerView": 3.5
                    },
                    "1025": {
                      "slidesPerView": 4
                    },
                    "1366": {
                      "slidesPerView": {{ section.settings.desktop_column_count }}
                    }
                }
            }
          '
        {% endif %}
      >
    {% endif %}
      <div class="featured-collection--wrapper{% if is_slider %} swiper-wrapper is-slider{% endif %} {{ section.settings.collection_style }} {% if section.settings.mobile_swipe == true %} mobile-swipe{% endif %} column-count-{{ section.settings.desktop_column_count }}" data-view="{{ section.settings.collection_style }} ">
        {% if section.settings.collection_featured.products != blank %}
          {%- assign grid_position = 0 -%}
          
          {%- for featuredproduct in section.settings.collection_featured.products limit: section.settings.products_to_show -%}
            {%- assign grid_position = grid_position | plus: 1 -%}
            
            {%- comment -%} Vérifier si une carte édito doit s'afficher AVANT ce produit {%- endcomment -%}
            {%- if section.settings.enable_edito_cards -%}
              {%- for edito_block in edito_blocks -%}
                {%- if edito_block.settings.position == grid_position -%}
                  <div 
                    class="product--card edito-card{% if edito_block.settings.card_size == 'double' %} edito-card--double{% endif %}{% if is_slider %} swiper-slide{% endif %}"
                    {% if settings.is_card_animation %}data-card-animate{% endif %}
                    {{ edito_block.shopify_attributes }}
                  >
                    {% render 'edito-card', block: edito_block, cardImageSize: section.settings.image_ratio %}
                  </div>
                  {%- assign grid_position = grid_position | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
            
            <div class="product--card {% if is_slider %} swiper-slide{% endif %}" {% if settings.is_card_animation %} data-card-animate {% endif %}>
              {% render 'product-card', cardproduct: featuredproduct, section: section, cardImageSize: section.settings.image_ratio %}
            </div>
          {%- endfor -%}
        {% else %}
          {% for i in (1..6) %}
            {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
            <div class="product--card {% if is_slider %} swiper-slide{% endif %}" {% if settings.is_card_animation %} data-card-animate {% endif %}>
              {% render 'product-card' section: section, cycleIndex: current, cardImageSize: section.settings.image_ratio %}
            </div>
          {% endfor %}
        {% endif %}
      </div>
      <div class="swiper-scrollbar swiper-scrollbar-{{ section.id }} d-block d-md-none"></div>
    {% if is_slider %}
      </div>
      </swiper-content>
    {% endif %}
  </div>
</div> 

<style>
  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_desktop }}px;
    --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
  }
  @media (min-width:768px) {
    #shopify-section-{{ section.id }}  {
      --column_count: {{ section.settings.desktop_column_count }};
    }
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_mobile }}px;
      --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}

  /* Styles pour les cartes édito dans featured collection */
  #shopify-section-{{ section.id }} .edito-card {
    grid-column: span 1;
  }

  #shopify-section-{{ section.id }} .edito-card--double {
    grid-column: span 2;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .edito-card--double {
      grid-column: span 1;
    }
  }
</style>

