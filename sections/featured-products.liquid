{% if section.index <= 2 %}
  {{ 'featured-products.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
  {{ 'featured-products.css' | asset_url | stylesheet_tag }}
{% liquid
 
  assign is_left_button = false
  assign is_left_side = false
  assign is_element_class = false

  if section.settings.btn_text != blank and section.settings.btn_link != blank
    assign is_left_button = true
  endif
  if section.settings.heading != blank or section.settings.description != blank or is_left_button
    assign is_left_side = true
  endif

  if section.blocks.size > 0 and is_left_side
    assign is_element_class = true
  endif
  
%}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }}" style="--section_height:100vh;">
    <div class="no-container">
        <feature-products class="featured--products-container{% if is_element_class %} d-grid{% else %} d-block{% endif %}{% if request.design_mode %} is-active{%  endif %}">
              {% if is_left_side %}
                <div class="featured--products-col heading-col text-{{ section.settings.heading_alignment}}">
                    {% if section.settings.heading != blank or section.settings.description != blank %}
                        <variety-heading class="section--header">
                          <div class="section--header-inner">   
                            {%- if section.settings.heading != blank -%}
                              {%- capture markersPrefix -%}
                                <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                              {%- endcapture -%}
                              {%- capture markersSuffix -%}
                                </span>
                              {%- endcapture -%}
                              <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                                {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                              </{{ section.settings.seo_heading }}>
                            {%- endif -%}
                            {% if section.settings.description != blank %}
                              <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                                {{ section.settings.description | newline_to_br }}
                              </p>
                            {% endif %}
                          </div>
                        </variety-heading>
                    {% endif %}

                    {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}                      
                      
                      {% liquid
                        if section.settings.button_style == 'link'
                          assign show_as_link = true
                          assign button_class = 'text-underline'
                        else
                          assign button_class = 'button' | append: ' ' | append: section.settings.button_size | append: ' ' | append: settings.button_animation_style
                          assign show_as_link = false
                        endif
                      %}
                      <div class="featured--products--button">
                          <a href="{{ section.settings.btn_link }}" class="{{ button_class }} {{ section.settings.button_style }}-button">
                            {% render 'button-appearance', button_text: section.settings.btn_text, icon: 'arrow-right', show_as_link: show_as_link %}
                          </a>
                      </div>
                  {% endif %}
                </div>
              {% endif %}
              {% if section.blocks.size > 0 %}
              <div class="featured--products-col products-col">
                  <div class="featured--products-list{% if section.blocks.size > 1 %} featured--products-multiple-slides{% endif %}" style="--marque_text_size: 200px; --marquee_speed: 15s;">
                    {% for block in section.blocks %}
                      {% assign product = block.settings.product %}
                      {% if block.settings.marquee_text != blank %}
                        {% assign marquee_title =  block.settings.marquee_text %}
                      {% else %}
                        {% if product != blank %}
                          {% assign marquee_title = product.title %}
                        {% else %}
                          {% assign marquee_title = 'onboarding.product_title' | t %}
                        {% endif %}
                      {% endif %}
                     
                      <div class="featured--product-item" id="featured--product-item-{{ block.id }}">
                        <div class="featured--product-marquee">
                          <div class="marquee--block-node autoplay--infinite rtl-direction">
                              <div class="marquee--block-node-inner">
                                {% if marquee_title.size > 50 %}
                                  {%  assign count = 2 %}
                                {% elsif marquee_title.size < 50 and marquee_title.size > 20 %}
                                  {%  assign count = 6 %}
                                {% else %}
                                  {%  assign count = 8 %}
                                {% endif %}
                                {% for i in (1..count) %}
                                  <div class="marquee--block">
                                      <div class="marquee--block-item text-item">
                                        <p class="marquee-text">
                                          {{ marquee_title }}
                                        </p>
                                      </div>
                                  </div>
                                {% endfor %}
                              </div>
                          </div>
                        </div>
                        <div class="featured--product-mediawrap media-wrapper">
                          
                          <a href="{{ product.url }}" class="featured--product-image media-wrapper d-block" aria-label="{% if product.title != blank %}{{ product.title }}{% else %}{{ 'onboarding.product_title' | t }}{% endif %}">
                            <div class="media" style="--image_ratio: 80%;">
                              {% if product.featured_media != blank %}
                                {% render 'lazy-image', image: product.featured_media.preview_image, class: 'product--card-image' %}
                                {% else %}
                                  {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                                  {% assign placeholder_image = 'product-apparel-' | append: current %}
                                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                            </div>
                          </a>
                        </div>
                        <div class="featured--product-content">
                          <div class="product--card-detail-content">
                            {% if product.title != blank %}
                                <a href="{{ product.url }}" class="product--title text-large" aria-label="{{- product.title -}}">
                                  {{- product.title -}}
                                </a>
                              {% if settings.show_price %}
                                {% render 'product-card-price', product: product, section: section, currentVariant: product.selected_or_first_available_variant.price %}
                              {% endif  %}  
                            {% else %}
                                <span class="product--title text-large">{{ 'onboarding.product_title' | t }}</span>
                                <div class="product--pricing">
                                  <span class="product--actual-price heading-font">{{ 1999 | money_with_currency }}</span>
                                </div>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    {% endfor %}
                  </div> 
              </div>
              {% endif %}
        </feature-products>
    </div>
</div> 
<style>
  {% for block in section.blocks %}
    #featured--product-item-{{ block.id }} {
      {% if block.settings.background_gradient != empty %}
        --card_background: {{ block.settings.background_gradient }};
      {% else %}
        --card_background: {{ block.settings.background_color }};
      {% endif %}

      {% if block.settings.marquee_text_gradient != empty %}
       --marquee_background: {{ block.settings.marquee_text_gradient }};
      {% else %}
        --marquee_background: {{ block.settings.marquee_text_color }};
      {% endif %}
      --marque_text_size: {{ block.settings.desktop_font_size }}px;
      --node_color: {{ block.settings.marquee_text_color }};
      --heading_color: {{ block.settings.text_color }};
      --link_color: {{ block.settings.text_color }};
      --text_color: {{ block.settings.text_color }};
    }
    @media(max-width: 767px) {
      #featured--product-item-{{ block.id }} {
        --marque_text_size: {{ block.settings.mobile_font_size }}px;
      }
    }

  {% endfor %}
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
