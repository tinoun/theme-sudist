{% if section.index <= 2 %}
  {{ 'revealing-text.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'revealing-text.css' | asset_url | stylesheet_tag }}
{% liquid
 
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif
  
%}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}" data-revaling-parallax> 
  {% if section.settings.background_image != blank %}
  {% if section.settings.is_parallax and section.settings.background_image != blank %}<parallax-container>{% endif %}
      <div class="background--overlay-image" data-movement="15%" data-parallax-image="" data-angle="top">
        {% render 'lazy-image', image: section.settings.background_image %}
      </div>
    {% if section.settings.is_parallax and section.settings.background_image != blank %}</parallax-container>{% endif %}
  {% endif %}
  <div class="{{ containerClass }}">
    <div class="revealing-text--wrapper {{ section.settings.revealing_height }} content-{{ section.settings.content_width }} text-{{ section.settings.content_alignment }}">
      {% if section.settings.text_to_reveal != blank %}
        <reveal-text data-reveal-style="{{ section.settings.revealing_style }}">
          <{{ section.settings.seo_heading }}
            class="revealing-text--content {{ section.settings.heading_size }} {{ section.settings.font_type }}"
            data-text-reveal
          >
            {{ section.settings.text_to_reveal | newline_to_br }}
          </{{ section.settings.seo_heading }}>
        </reveal-text>
      {% endif %}

      {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
        {% liquid
          if section.settings.button_style == 'link'
            assign button_class = 'text-underline'
            assign show_as_link = true
          else
            assign button_class = 'button' | append: ' ' | append: section.settings.button_size | append: ' ' | append: settings.button_animation_style
            assign show_as_link = false
          endif
        %}
        <div class="revealing-text--button">
          <a
            href="{{ section.settings.btn_link }}"
            class="{{ button_class }} {{ section.settings.button_style }}-button"
          >
            {% render 'button-appearance',
              button_text: section.settings.btn_text,
              icon: 'arrow-right',
              show_as_link: show_as_link
            %}
          </a>
        </div>
      {% endif %}
    </div>
  </div>

</div>

<style>
    #shopify-section-{{ section.id }} .section-spacing {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --text_color: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }};
      --image_overlay_opacity: {{ section.settings.overlay_opacity }};
    }

    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .section-spacing {
        --top_spacing: {{ section.settings.top_space_mobile }}px !important;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

