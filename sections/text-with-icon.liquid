{% if section.index <= 2 %}
  {{ 'text-with-icon.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'text-with-icon.css' | asset_url | stylesheet_tag }}
{% liquid
  assign columnStyle = section.settings.column_style
  case columnStyle
    when 'border-enabled'
      assign colClasses = 'column-border-enabled'
    when 'border-enabled-with-shadow'
      assign colClasses = 'column-border-enabled column-shadow-enabled'
    when 'background-enabled'
      assign colClasses = 'column-background-enabled'
    when 'background-enabled-with-border'
      assign colClasses = 'column-background-enabled column-border-enabled'
    when 'animate-background'
      assign colClasses = 'animate-background column-background-enabled'
    when 'background-enabled-with-shadow'
      assign colClasses = 'column-background-enabled column-shadow-enabled'
    when 'all_styles_applied'
      assign colClasses = 'column-border-enabled column-shadow-enabled column-background-enabled animate-background'
    when 'none'
      assign colClasses = 'column-no-style'
  endcase

  assign iconStyle = section.settings.icon_style
  case iconStyle
    when 'border-enabled'
      assign iconClasses = 'icon-border-enabled'
    when 'border-enabled-with-shadow'
      assign iconClasses = 'icon-border-enabled icon-shadow-enabled'
    when 'background-enabled'
      assign iconClasses = 'icon-background-enabled'
    when 'background-enabled-with-border'
      assign iconClasses = 'icon-background-enabled icon-border-enabled'
    when 'background-enabled-with-shadow'
      assign iconClasses = 'icon-background-enabled icon-shadow-enabled'
    when 'all_styles_applied'
      assign iconClasses = 'icon-border-enabled icon-shadow-enabled icon-background-enabled'
    when 'none'
      assign iconClasses = 'icon-no-style'
  endcase
  
%}
{% if section.blocks.size > 0 %}
  <div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
    <div class="{{ settings.container_width }} {% if section.settings.enable_swipe_mobile %}m-pr-0{% endif %}">
      {% if section.settings.heading != blank or section.settings.description != blank %}
        <variety-heading class="section--header text-{{ section.settings.text_align }}">
          <div class="section--header-inner">

            {% if section.settings.heading != blank %}
              {%- capture markersPrefix -%}
                <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
              {%- endcapture -%}
              {%- capture markersSuffix -%}
                </span>
              {%- endcapture -%}
              <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
              </{{ section.settings.seo_heading }}>
            {% endif %}

            {% if section.settings.description != blank %}
              <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                {{ section.settings.description | newline_to_br }}
              </p>
            {% endif %}

          </div>
        </variety-heading>
      {% endif %}
      <text-with-icon class="text-with-icon--wrapper{% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
        {%- for block in section.blocks -%}
          <div
            id="textWithIconItem-{{ block.id }}"
            class="text-with-icon--item"
            {% if settings.is_card_animation %} data-card-animate {% endif %}
            {{ block.shopify_attributes }}
          >
          {% liquid
            
            if section.settings.description_style == 'on_hover'
              assign iconPostionClass = 'icon-position-top'
            else
              assign iconPostionClass = 'icon-position-' | append:  section.settings.icon_position
            endif

          %}
            <div class="text-with-icon-item--inner{% if section.settings.description_style == 'on_hover'%} description-hover-enabled{% endif %} {{ colClasses }} {{ iconPostionClass }} text-{{ section.settings.content_alignment }}" data-text-icon-inner>
              {% if section.settings.description_style == 'on_hover'%}
              <div class="text-with-icon-item--inner-box">
              {% endif %}
                <div class="text-with-icon--icon icon-gap-{{ section.settings.icon_gap }} {{ iconClasses }} {{ section.settings.icon_size }}-icon">
                  {% if block.settings.custom_icon != blank %}
                    {% render 'lazy-image', image: block.settings.custom_icon %}
                  {% elsif block.settings.icon != blank %}
                    {% render 'icons', icon: block.settings.icon %}
                  {% endif %}
                </div>
                <div class="text-with-icon--content pos-relative" text-icon-content>
                  {% if block.settings.heading != blank %}
                    <{{ block.settings.seo_heading_tag }} class="text-with-icon--heading {{ block.settings.block_heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ block.settings.seo_heading_tag }}>
                  {% endif %}
                  {% if block.settings.subtext != blank %}
                    <p class="text-with-icon--desc text-medium" data-text-icon-desc>{{ block.settings.subtext | newline_to_br }}</p>
                  {% endif %}
                </div>
                {% if section.settings.description_style == 'on_hover'%}
                </div>
                {% endif %}
            </div>
          </div>
        {% endfor %}
      </text-with-icon>
    </div>
  </div>
{% endif %}
<style>
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --column_count: {{ section.settings.desktop_column_count }};
    }
    {% for block in section.blocks %}
      #textWithIconItem-{{ block.id }}
      .text-with-icon-item--inner.column-background-enabled {
        --card_background: {{ block.settings.column_background_color }}!important;
      }
      #textWithIconItem-{{ block.id }}
      .text-with-icon--heading, #textWithIconItem-{{ block.id }} .animate-background:before {
        --heading_color: {{ block.settings.heading_color }};
      }
      #textWithIconItem-{{ block.id }}
      .text-with-icon--desc {
        --text_color: {{ block.settings.description_color }};
      }
      #textWithIconItem-{{ block.id }}
      .text-with-icon--icon {
        --icon_color: {{ block.settings.icon_color }};
        --icon_background: {{ block.settings.icon_background_color }};
      }
    {% endfor %}
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
        --column_count: {{ section.settings.mobile_column_count }};
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

