{% if section.index <= 2 %}
  {{ 'password.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'password.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper pos-relative scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  {% if section.settings.bg_image != blank %}
    <div class="background--overlay-image">
      {% render 'lazy-image', image: section.settings.bg_image %}
    </div>
  {% endif %}
  <div class="{{ settings.container_width }}">
    <div class="password--wrapper">
      <password-facet class="password-header">
          <button id="password--openPopupButton" type="button" class="button password-button"><span>Entrer le mot de passe</span></button>
      </password-facet>
      <div class="password--content width-100 height-100 text-{{ section.settings.content_position }}">
          <div class="password--content-inner pos-relative">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {% when 'text' %}
                  {% if block.settings.text != blank %}
                    <p class="password-newsletter--text {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                      {{ block.settings.text | newline_to_br }}
                    </p>
                  {% endif %}
                {% when 'heading' %}
                  {% if block.settings.heading != blank %}
                    <variety-heading class="password--heading-box">
                        {%- capture markersPrefix -%}
                          <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                        {%- endcapture -%}
                        {%- capture markersSuffix -%}
                          </span>
                        {%- endcapture -%}
                        <{{ block.settings.seo_heading }} class="password--heading heading-font {{ block.settings.heading_size }}">
                          {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                        </{{ block.settings.seo_heading }}>
                    </variety-heading>
                  {% endif %}
                {% when 'password_message' %}
                    {%- if shop.password_message != blank -%}
                      <div class="password-content {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                        {{ shop.password_message }}
                      </div>
                    {%- endif -%}
                {% when 'newsletter_form' %}
                  {% form 'customer', class: 'newsletter-form pos-relative' %}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="newsletter--form">
                      <div class="form-group">
                        <label class="hidden" for="NewsletterForm--{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          type="email"
                          name="contact[email]"
                          class="form-control"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="{{ block.settings.placeholder_text | default: 'Enter your email' }}"
                          required
                        >
                      </div>
                      {%- if form.errors -%}
                        <div class="form--message error" id="Newsletter-error--{{ section.id }}" tabindex="-1"  autofocus>
                          {{- form.errors.translated_fields.email | capitalize }}
                          {{ form.errors.messages.email -}}

                        </div>
                      {%- endif -%}
                      {%- if form.posted_successfully? -%}
                        <div  class="form--message success" id="Newsletter-success--{{ section.id }}"  tabindex="-1"  autofocus >  
                          {{ 'newsletter.success' | t }}
                        </div>
                      {%- endif -%}
                      <button
                        type="submit"
                        class="button button-block medium-button"
                        name="commit"
                        id="Subscribe"
                        aria-label="{{ 'newsletter.button_label' | t }}"
                      >
                      {{ 'newsletter.button_label' | t }}
                      </button>                    
                    </div>
                 
                  {% endform %}
                {% when 'social_icons' %}
                    <div class="social--icons password-social-icons" {{ block.shopify_attributes }}>
                      {% render 'social-icons' %}
                    </div>
              {% endcase %}
            {%- endfor -%}
          </div>
      </div>
    </div>
  </div>
</div>
{% render 'popup', modal_name: 'password-form', modal_position: 'center', modal_size: 'small', section: section, popup_color_scheme: settings.popup_color_scheme %}
<style>
  #shopify-section-{{ section.id }}{
    --image_overlay_opacity: {{ section.settings.overlay_opacity }};
  }
</style>

{% schema %}
{
  "name": "t:sections.main-password.name",
  "class": "section-password",
  "templates": ["password"],
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "select",
      "id": "section_background",
      "label": "t:sections.all.section_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.section_background.solid.label",
          "value": "solid"
        },
        {
          "label": "t:sections.all.section_background.gradient.label",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "text_alignment",
      "id": "content_position",
      "label": "t:sections.all.content_positions.label",
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "t:sections.all.background_image.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "default": 0.1,
      "label": "t:settings_schema.global.settings.image_overlay_opacity.label",
      "min": 0,
      "max": 1,
      "step": 0.1
  },
  {
    "type": "header",
    "content": "t:sections.all.headers.password-popup"
  },
  {
    "type": "text",
    "id": "popup_heading",
    "label": "t:settings_schema.global.settings.heading.label",
    "default": "Enter Password"
  },
  {
    "type": "textarea",
    "id": "popup_desc",
    "label": "t:settings_schema.global.settings.description.label",
    "default": "Find out when we open"
  }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.main-password.blocks.text.name",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "t:settings_schema.global.settings.text.label",
          "default": "Add text here"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "t:sections.main-password.blocks.text.settings.text_size.label",
          "default": "text",
          "options": [
            {
              "label": "t:sections.all.description_size.text-xsmall.label",
              "value": "text-xsmall"
            },
            {
              "label": "t:sections.all.description_size.text-small.label",
              "value": "text-small"
            },
            {
              "label": "t:sections.all.description_size.text.label",
              "value": "text"
            },
            {
              "label": "t:sections.all.description_size.text-medium.label",
              "value": "text-medium"
            },
            {
              "label": "t:sections.all.description_size.text-large.label",
              "value": "text-large"
            },
            {
              "label": "t:sections.all.description_size.text-xlarge.label",
              "value": "text-xlarge"
            }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "name": "t:sections.main-password.blocks.heading.name",
      "settings": [
        {
            "type": "inline_richtext",
            "id": "heading",
            "label": "t:settings_schema.global.settings.heading.label",
            "default": "Opening Soon",
            "info": "t:settings_schema.global.settings.heading.info"
        },
        {
              "type": "select",
              "id": "markers_font",
              "label": "t:sections.all.markers_font.label",
              "info": "t:sections.all.markers_font.info",
              "default": "accent-font",
              "options": [
                {
                  "label": "t:sections.all.markers_font.accent-font.label",
                  "value": "accent-font"
                },
                {
                  "label": "t:sections.all.markers_font.body-font.label",
                  "value": "body-font"
                },
                {
                  "label": "t:sections.all.markers_font.heading-font.label",
                  "value": "heading-font"
                }
              ]
        },
        {
              "type": "select",
              "id": "markers_text",
              "label": "t:sections.all.markers_text.label",
              "default": "no-markers",
              "options": [
                {
                  "label": "t:sections.all.markers_text.no-markers.label",
                  "value": "no-markers"
                },
                {
                  "label": "t:sections.all.markers_text.highlight-color.label",
                  "value": "highlight-color"
                },
                {
                  "label": "t:sections.all.markers_text.highlight-gradient.label",
                  "value": "highlight-gradient"
                },
                {
                  "label": "t:sections.all.markers_text.outline--text.label",
                  "value": "outline--text"
                },
                {
                  "label": "t:sections.all.markers_text.outline--filled.label",
                  "value": "outline--filled"
                },
                {
                  "label": "t:sections.all.markers_text.text-background-cover.label",
                  "value": "text-background-cover"
                }
              ]
          },
          {
            "type": "select",
            "id": "heading_size",
            "label": "t:sections.all.heading_size.label",
            "default": "h2",
            "options": [
              {
                "value": "h1",
                "label": "t:sections.all.heading_size.h1.label"
              },
              {
                "value": "h2",
                "label": "t:sections.all.heading_size.h2.label"
              },
              {
                "value": "h3",
                "label": "t:sections.all.heading_size.h3.label"
              },
              {
                "value": "h4",
                "label": "t:sections.all.heading_size.h4.label"
              },
              {
                "value": "h5",
                "label": "t:sections.all.heading_size.h5.label"
              },
              {
                "value": "h6",
                "label": "t:sections.all.heading_size.h6.label"
              }
            ]
          },
          {
            "type": "select",
            "id": "seo_heading",
            "label": "t:sections.all.seo_heading.label",
            "info": "t:sections.all.seo_heading.info",
            "default": "h2",
            "options": [
              {
                "value": "h1",
                "label": "H1"
              },
              {
                "value": "h2",
                "label": "H2"
              },
              {
                "value": "h3",
                "label": "H3"
              },
              {
                "value": "h4",
                "label": "H4"
              },
              {
                "value": "h5",
                "label": "H5"
              },
              {
                "value": "h6",
                "label": "H6"
              },
              {
                "value": "div",
                "label": "div"
              },
              {
                "value": "span",
                "label": "span"
              },
              {
                "value": "p",
                "label": "p"
              }
            ]
          }
      ]
    },
    {
      "type": "social_icons",
      "name": "t:sections.main-password.blocks.social_icons.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.all.social-media-icons.info"
        }
      ]
    },
    {
      "type": "password_message",
      "name": "t:sections.main-password.blocks.password_message.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-password.blocks.password_message.settings.pass_msg.content"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "t:sections.main-password.blocks.password_message.settings.text_size.label",
          "default": "text-medium",
          "options": [
            {
              "label": "t:sections.all.description_size.text-xsmall.label",
              "value": "text-xsmall"
            },
            {
              "label": "t:sections.all.description_size.text-small.label",
              "value": "text-small"
            },
            {
              "label": "t:sections.all.description_size.text.label",
              "value": "text"
            },
            {
              "label": "t:sections.all.description_size.text-medium.label",
              "value": "text-medium"
            },
            {
              "label": "t:sections.all.description_size.text-large.label",
              "value": "text-large"
            },
            {
              "label": "t:sections.all.description_size.text-xlarge.label",
              "value": "text-xlarge"
            }
          ]
        }
      ]
    },
    {
      "type": "newsletter_form",
      "name": "t:sections.main-password.blocks.newsletter_form.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "placeholder_text",
          "label": "t:sections.main-password.blocks.newsletter_form.settings.placeholder_text.label",
          "default": "Enter your email"
        }
      ]
    }
  ] 
}
{% endschema %}
