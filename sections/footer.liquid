{{ 'footer.css' | asset_url | stylesheet_tag }}
<div
  class="footer--main {% if section.settings.enable_top_border_rounded %} border-radius-enabled{% endif %}"
  data-show-accordion="{{section.settings.mobile_accordions}}"
>
  {% liquid
    if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_snapchat_link != blank or settings.social_pinterest_link != blank or settings.social_tumblr_link != blank or settings.social_vimeo_link != blank
      assign socialLinks = true
    endif

    if section.settings.enable_social_icons != false and socialLinks == true
      assign enableLinks = true
    else
      assign enableLinks = false
    endif

    if section.settings.image != blank and section.settings.emphasize_logo 
       if section.settings.description != blank or enableLinks != false
        assign footerClass = 'col-lg-8 col-xl-8'
        assign footercolumnclass = 'col-lg-4 col-xl-4'
       else
        assign footerClass = 'col-lg-12 col-xl-12'
        assign footercolumnclass = 'col-lg-3 col-xl-3'
       endif
    else
      if section.settings.image != blank or section.settings.description != blank or enableLinks != false
        assign footerClass = 'col-lg-8 col-xl-8'
        assign footercolumnclass = 'col-lg-4 col-xl-4'
      else
        assign footerClass = 'col-lg-12 col-xl-12'
        assign footercolumnclass = 'col-lg-3 col-xl-3'
      endif
    endif
  %}
  <div class="container-fullwidth">
    <div class="footer--wrapper">
      {% if section.settings.enable_heading
        or section.settings.heading != blank
        or section.blocks.size > 0
        or section.settings.image != blank
        or section.settings.description != blank
        or enableLinks == true
      %}
        <div class="footer--top">
          <div class="row">
            {% if section.settings.image != blank and section.settings.emphasize_logo %}
              <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12">
                <a class="footer--logo footer--emphasize-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
                  {% liquid
                    assign height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio | round
                    assign sizes = '100vw'
                    assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                    echo section.settings.image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                  %}  
                </a>              
              </div>
              {% if section.settings.description != blank or enableLinks == true %}
                <div class="col-12 col-sm-12 col-md-12 col-lg-4 col-xl-4">
                  <div
                    class="footer--left"
                    {% if settings.is_card_animation %}
                      data-card-animate
                    {% endif %}
                  >
                    {% if section.settings.description != blank %}
                      <div class="footer--text">
                        {{ section.settings.description | newline_to_br }}
                      </div>
                    {% endif %}
                    {% if section.settings.enable_social_icons != blank %}
                      <div class="footer--social-links">
                        {% render 'social-icons', section: section %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% else %}
              {% if section.settings.image != blank or section.settings.description != blank or enableLinks == true %}
                <div class="col-12 col-sm-12 col-md-12 col-lg-4 col-xl-4">
                  <div
                    class="footer--left"
                    {% if settings.is_card_animation %}
                      data-card-animate
                    {% endif %}
                  >
                    {%- if section.settings.image != blank -%}
                      <a class="footer--logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
                        {%- assign image_2x_size = section.settings.image_width | times: 2 | at_most: 2560 -%}
                        <img
                          class="footer--logo-img"
                          srcset="{{ section.settings.image | image_url: width: section.settings.image_width }} 1x, {{ section.settings.image | image_url: width: image_2x_size }} 2x"
                          src="{{ section.settings.image | image_url: width: section.settings.image_width }}"
                          loading="lazy"
                          width="{{ section.settings.image_width }}"
                          height="{{ section.settings.image_width | divided_by : section.settings.image.aspect_ratio | round }}"
                          alt="{{ section.settings.image.alt | default: shop.name | escape }}"
                        >
                      </a>
                    {% endif %}
                    {% if section.settings.description != blank %}
                      <div class="footer--text">
                        {{ section.settings.description | newline_to_br }}
                      </div>
                    {% endif %}
                    {% if section.settings.enable_social_icons != blank %}
                      <div class="footer--social-links">
                        {% render 'social-icons', section: section %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endif %}

           
            {% if section.settings.enable_heading or section.settings.heading != blank or section.blocks.size > 0 %}
              <div class="col-12 col-sm-12 col-md-12 {{ footerClass }}">
                <div class="footer--right">
                  {% if section.settings.enable_heading and section.settings.heading != blank %}
                    <div class="footer--right-top">
                      <div class="h6 heading-font footer--heading">
                        {{ section.settings.heading }}
                      </div>
                    </div>
                  {% endif %}
                  {% if section.blocks.size > 0 %}
                    {% if section.settings.enable_heading and section.settings.heading != blank %}
                      <div class="footer--right-bottom">
                    {% endif %}
                    <div class="row">
                      {% for block in section.blocks %}
                        {%- case block.type -%}
                          {% when 'collection_list' %}
                            {% if block.settings.collection_list != blank %}
                              <div class="col-12 col-sm-12 col-md-4 {{ footercolumnclass }}" 
                              {% if settings.is_card_animation %}
                                data-card-animate
                              {% endif %}
                              {{ block.shopify_attributes }}>

                              <details
                                class="footer--menu footer--collection-list{% if section.settings.mobile_accordions %} footer--mb-accordions{% endif %}{% if forloop.index == 1 %} footer--menu-right{% endif %}"
                                open
                                data-accordion
                              >
                                  <summary class="footer--menu-heading heading-font text-xlarge">
                                  {{ block.settings.heading | default: 'Collections' }}
                                    {% if section.settings.mobile_accordions == true %}
                                      <span class="accordion--icon d-lg-none d-md-none" data-accordion-icon>
                                        <svg width="17" height="17" viewBox="0 0 17 17">
                                          <path class="horizontal" d="M0 9L-4.37113e-08 8L17 8L17 9L0 9Z" fill="currentColor"/>
                                          <path class="vertical" d="M8 0L9 0L9 17H8L8 0Z" fill="currentColor"/>
                                        </svg>
                                      </span>
                                    {% endif %}
                                  </summary>
                                  <ul class="footer--menu-list" data-collapsible-content>
                                    {% for collection in block.settings.collection_list %}
                                      <li class="footer--menu-collection-item footer--menu-item">
                                        <a href="{{ collection.url }}" class="footer--menu-link">
                                          {{ collection.title }}
                                        </a>
                                        {%- if collection.featured_image != blank -%}
                                          {{ collection.featured_image | image_url: width: 768 | image_tag: loading: 'lazy', class: 'footer--menu-image', widths: '400, 500, 600, 700, 768', sizes: '100vw', alt: collection.featured_image.alt | default: collection.title | escape }}
                                        {%- endif -%}
                                      </li>
                                    {% endfor %}
                                  </ul>
                                </details>
                              </div>
                            {% endif %}
                          {% when 'menus' %}
                            {% if block.settings.menu != blank %}
                              <div
                                class="col-12 col-sm-12 col-md-4 {{ footercolumnclass }}"
                                {% if settings.is_card_animation %}
                                  data-card-animate
                                {% endif %}
                                {{ block.shopify_attributes }}
                              >
                                <details
                                  class="footer--menu{% if section.settings.mobile_accordions %} footer--mb-accordions{% endif %}"
                                  open
                                  data-accordion
                                >
                                  {% if block.settings.heading != blank or block.settings.menu != blank %}
                                    <summary class="footer--menu-heading heading-font text-xlarge">
                                      {% if block.settings.heading != blank %}
                                        {{ block.settings.heading }}
                                      {% else %}
                                        {{ block.settings.menu.title }}
                                      {% endif %}
                                      {% if section.settings.mobile_accordions == true %}
                                        <span class="accordion--icon d-lg-none d-md-none" data-accordion-icon>
                                          <svg width="17" height="17" viewBox="0 0 17 17">
                                            <path class="horizontal" d="M0 9L-4.37113e-08 8L17 8L17 9L0 9Z" fill="currentColor"/>
                                            <path class="vertical" d="M8 0L9 0L9 17H8L8 0Z" fill="currentColor"/>
                                          </svg>
                                        </span>
                                      {% endif %}
                                    </summary>
                                  {% endif %}
                                  {%- if block.settings.menu != blank -%}
                                    <ul class="footer--menu-list" data-collapsible-content>
                                      {%- for link in block.settings.menu.links -%}
                                        <li class="footer--menu-item">
                                          <a href="{{ link.url }}" class="footer--menu-link">
                                            {{- link.title | escape -}}
                                          </a>
                                        </li>
                                      {% endfor %}
                                    </ul>
                                  {% endif %}
                                </details>
                              </div>
                            {% endif %}
                          {% when 'newsletter' %}
                            {% if block.settings.enable_newsletter %}
                              <div
                                class="col-12 col-sm-12 col-md-12 {{ footercolumnclass }}"
                                {% if settings.is_card_animation %}
                                  data-card-animate
                                {% endif %}
                                {{ block.shopify_attributes }}
                              >
                                <details
                                  class="footer--menu newsletter--menu {% if section.settings.mobile_accordions %} footer--mb-accordions{% endif %}"
                                  open
                                  data-accordion
                                >
                                  <summary class="footer--menu-heading heading-font text-xlarge">
                                    {{ block.settings.heading | default: 'Newsletter' }}

                                    {% if section.settings.mobile_accordions == true %}
                                      <span class="accordion--icon d-lg-none d-md-none">
                                        <svg width="17" height="17" viewBox="0 0 17 17">
                                          <path class="horizontal" d="M0 9L-4.37113e-08 8L17 8L17 9L0 9Z" fill="currentColor"/>
                                          <path class="vertical" d="M8 0L9 0L9 17H8L8 0Z" fill="currentColor"/>
                                        </svg>
                                      </span>
                                    {% endif %}
                                  </summary>

                                  <div class="footer--menu-content" data-collapsible-content>
                                    {% if block.settings.description != blank %}
                                      <p class="footer--menu-desc">{{ block.settings.description }}</p>
                                    {% endif %}
                                    {% if block.settings.enable_newsletter %}
                                      {%- form 'customer', id: 'ContactFooter', class: 'footer-newsletter-form' -%}
                                        {% assign footer_context = form.id %}
                                        <input type="hidden" name="contact[tags]" value="newsletter">
                                        <div class="footer-newsletter-form-box">
                                          <label class="hidden" for="NewsletterForm--footer">
                                            {{- 'newsletter.title' | t -}}
                                          </label>
                                          <input
                                            id="NewsletterForm--footer"
                                            type="email"
                                            name="contact[email]"
                                            class="form-control"
                                            value="{%- if form.context == 'footer' -%}{{ form.email }}{%- endif -%}"
                                            aria-required="true"
                                            autocapitalize="off"
                                            autocomplete="email"
                                            {%- if form.errors -%}
                                              autofocus
                                              aria-invalid="true"
                                              aria-describedby="Newsletter-error-{{ section.id }}"
                                            {%- elsif form.posted_successfully? -%}
                                              aria-describedby="Newsletter-success-{{ section.id }}"
                                            {%- endif -%}
                                            placeholder="{% if  block.settings.placeholder_text != blank %}{{ block.settings.placeholder_text }}{% else %}{{ 'newsletter.placeholder' | t }}{% endif %}"
                                            pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
                                            required
                                          >
                                          <button
                                            type="submit"
                                            class="arrow--btn small-width footer-newsletter-button"
                                            name="commit"
                                            aria-label="{{ 'newsletter.button_label' | t }}"
                                          >
                                            <svg class="arrow--icon" viewBox="0 0 12 13" fill="none">
                                              <path d="M0.82373 6.17769L11.3218 6.42578" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                                              <path d="M5.94873 11.5508L11.3218 6.42578L6.19682 1.05269" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                                            </svg>
                                          </button>
                                        </div>
                                        {%- if form.posted_successfully? and form.id == footer_context -%}
                                          <div
                                            id="Newsletter-success--{{ section.id }}"
                                            class="form--message success"
                                            tabindex="-1"
                                            autofocus
                                            role="status"
                                          >
                                            {{- 'newsletter.success' | t -}}
                                          </div>
                                        {%- endif -%}
                                      {% endform %}
                                    {% endif %}
                                  </div>
                                </details>
                              </div>
                            {% endif %}
                          {% when 'contact_information' %}
                            {% if block.settings.heading != blank
                              or block.settings.address != blank
                              or block.settings.email != blank
                              or block.settings.phone != blank
                            %}
                              <div
                                class="col-12 col-sm-12 col-md-4 {{ footercolumnclass }}"
                                {% if settings.is_card_animation %}
                                  data-card-animate
                                {% endif %}
                                {{ block.shopify_attributes }}
                              >
                                <details
                                  class="footer--menu{% if section.settings.mobile_accordions %} footer--mb-accordions{% endif %}"
                                  open

                                  data-accordion
                                >
                                  <summary class="footer--menu-heading heading-font text-xlarge">
                                    {{ block.settings.heading | default: 'About us' }}
                                    {% if section.settings.mobile_accordions == true %}
                                      <span class="accordion--icon d-lg-none d-md-none">
                                        <svg width="17" height="17" viewBox="0 0 17 17">
                                          <path class="horizontal" d="M0 9L-4.37113e-08 8L17 8L17 9L0 9Z" fill="currentColor"/>
                                          <path class="vertical" d="M8 0L9 0L9 17H8L8 0Z" fill="currentColor"/>
                                        </svg>
                                      </span>
                                    {% endif %}
                                  </summary>

                                  {% if block.settings.phone != blank
                                    or block.settings.email != blank
                                    or block.settings.address != blank
                                    or block.settings.hours != blank
                                  %}
                                    <ul class="footer--menu-info" data-collapsible-content>
                                      {% if block.settings.phone != blank %}
                                        <li class="footer--menu-info-item">
                                          <a
                                            href="tel:{{ block.settings.phone }}"
                                            class="footer--menu-info-link"
                                          >
                                            <svg
                                              viewBox="0 0 24 24"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2"
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                            >
                                              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line>
                                            </svg>
                                            <span class="footer--menu-info-text">{{ block.settings.phone }}</span>
                                          </a>
                                        </li>
                                      {% endif %}
                                      {% if block.settings.email != blank %}
                                        <li class="footer--menu-info-item">
                                          <a
                                            href="mailto:{{ block.settings.email }}"
                                            class="footer--menu-info-link"
                                          >
                                            <svg
                                              viewBox="0 0 24 24"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2"
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                            >
                                              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>
                                            </svg>
                                            <span class="footer--menu-info-text">{{ block.settings.email }}</span>
                                          </a>
                                        </li>
                                      {% endif %}
                                      {% if block.settings.address != blank %}
                                        <li class="footer--menu-info-item">
                                          <span class="footer--menu-info-link">
                                            <svg
                                              viewBox="0 0 24 24"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2"
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                            >
                                              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
                                            </svg>
                                            <span class="">{{ block.settings.address }}</span>
                                          </span>
                                        </li>
                                      {% endif %}
                                      {% if block.settings.hours != blank %}
                                        <li class="footer--menu-info-item">
                                          <span class="footer--menu-info-link">
                                            <svg
                                              viewBox="0 0 24 24"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2"
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                            >
                                              <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                            <span class="">{{ block.settings.hours }}</span>
                                          </span>
                                        </li>
                                      {% endif %}
                                    </ul>
                                  {% endif %}
                                </details>
                              </div>
                            {% endif %}
                        {% endcase %}
                      {% endfor %}
                    </div>
                    {% if section.settings.enable_heading and section.settings.heading != blank %}
                      </div>
                    {% endif %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
      {% if section.settings.show_location_and_language
        or section.settings.enable_policy_links 
        or section.settings.enable_payment_icons
        or section.settings.enable_copyright
        or section.settings.enable_follow_on_shop
      %}
        <div class="footer--bottom"> 
          {% if section.settings.show_location_and_language %}
            <div class="footer--info-block">
              {% if settings.is_country_selector or settings.is_language_selector %}
                <localization-context type="button" is="localization-context" class="localization-form cursor-pointer" data-size="{{ localization.available_countries.size }}">
                  <div class="localization--current-locale">
                    <span class="localization-icon">
                      {% render 'icons', icon: 'globe' %}
                    </span>
                    <span class="text-small">
                      {%- if settings.is_country_selector -%}
                        {{- localization.country.currency.symbol }}
                        {{ localization.country.currency.iso_code -}}  
                      {%- endif -%}
                      {%- if settings.is_language_selector -%}
                        {%- if settings.is_country_selector %} / {% endif -%}
                        {{- localization.language.iso_code | upcase -}}
                      {%- endif -%}
                    </span>
                  </div>
                </localization-context>
              {% endif %}
            </div>
          {% endif %}
          {% if section.settings.enable_policy_links %}
            <div class="footer--info-block">
              <ul class="footer-quick-links list-inline">
                {%- for policy in shop.policies -%}
                  {%- if policy != blank -%}
                    <li>
                      <a href="{{ policy.url }}" class="footer-quick-links-link text-small">{{- policy.title -}}</a>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          {% endif %}
          {% if section.settings.enable_payment_icons
            or section.settings.enable_follow_on_shop
            or section.settings.enable_copyright
          %}
            <div class="footer--info-block">
              {% if section.settings.enable_payment_icons and shop.enabled_payment_types.size > 0 %}
                <div class="footer-payment-icons">
                  {% render 'payment-icons', section: section %}
                </div>
              {% endif %}
              {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                <div class="footer-follow-on-shop">
                  {{ shop | login_button: action: 'follow' }}
                </div>
              {%- endif -%}
              {% if section.settings.enable_copyright %}
                <p class="copyright--text text-small">
                  Copyright&copy; {{ 'now' | date: '%Y' }}
                  {{ shop.name | link_to: routes.root_url }}
                  {{ powered_by_link -}}
                </p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
<style>
    footer {
      --logo_width: {{ section.settings.image_width }}px;
    }
    @media (max-width: 767px) {
     footer{
      --logo_width: {{ section.settings.mb_image_width }}px;
    }
  }
</style>
{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "footer",
  "class": "section-footer",
  "limit": 1,
  "disabled_on": {
    "groups": ["header", "custom.Overlay"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_top_border_rounded",
      "label": "t:sections.footer.settings.enable_top_border_rounded.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.content.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.footer.settings.image.label"
    },
    {
      "type": "checkbox",
      "id": "emphasize_logo",
      "label": "t:sections.footer.settings.emphasize_logo.label",
      "default": false
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.desktop_logo_width.label",
      "default": 100,
      "visible_if": "{{ section.settings.emphasize_logo == false }}"
    },
    {
      "type": "range",
      "id": "mb_image_width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.mobile_logo_width.label",
      "default": 100,
      "visible_if": "{{ section.settings.emphasize_logo == false }}"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.content.label"
    },
    {
      "type": "checkbox",
      "id": "enable_heading",
      "label": "t:sections.all.enable_heading.label",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings_schema.global.settings.heading.label",
      "default": "Add text here"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.footer.settings.description.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.social-media-icons.content",
      "info": "t:sections.all.social-media-icons.info"
    },
    {
      "type": "checkbox",
      "id": "enable_social_icons",
      "label": "t:sections.footer.settings.enable_social_icons.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_accordions",
      "label": "t:sections.footer.settings.mobile_accordions.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.footer_bottom"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.payment-methods.content",
      "info": "t:sections.all.headers.payment-methods.info"
    },
    {
      "type": "checkbox",
      "id": "enable_payment_icons",
      "label": "t:sections.footer.settings.enable_payment_icons.label",
      "info": "t:sections.footer.settings.enable_payment_icons.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.policy-links.content",
      "info": "t:sections.all.policy-links.info"
    },
    {
      "type": "checkbox",
      "id": "enable_policy_links",
      "label": "t:sections.footer.settings.enable_policy_links.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.follow-on-shop.content",
      "info": "t:sections.all.headers.follow-on-shop.info"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "label": "t:sections.footer.settings.enable_follow_on_shop.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.copyright-content"
    },
    {
