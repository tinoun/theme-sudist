{% if section.index <= 2 %}
  {{ 'image-with-text.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'image-with-text.css' | asset_url | stylesheet_tag }}
{% liquid
  assign image_size = section.settings.image_ratio
  if image_size == 'landscape'
    assign imageRatio = '70%'
  elsif image_size == 'square'
    assign imageRatio = '100%'
  elsif image_size == 'portrait'
    assign imageRatio = '130%'
  else
    if section.settings.image != blank
      assign imageRatio = 1 | divided_by: section.settings.image.aspect_ratio | times: 100 | minus: 1 | append: '%'
    else
      assign imageRatio = 70 | append: '%'
    endif
  endif


  if section.blocks.size > 0
    assign col_size = section.settings.desktop_image_size
    if col_size == 'small'
      assign col_image_size = 5
      assign col_text_size = 7
    elsif col_size == 'medium'
      assign col_image_size = 6
      assign col_text_size = 6
    elsif col_size == 'large'
      assign col_image_size = 7
      assign col_text_size = 5
    endif
  else
    assign col_image_size = 12
  endif
%}
{% liquid
  assign containerClass = ''
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif
%}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ containerClass }}">
    <div class="image-with-text--outer">
      <div class="row no-gutters image-with-text--wrapper image--position-{{ section.settings.desktop_image_postition }}{% if section.settings.is_background_enabled %} content-background-enabled{% endif %} {% if section.settings.image_ratio == 'adapt-to-content' %} adapt-to-align{% endif %}">
        <div class="col-lg-{{ col_image_size }} col-md-{{ col_image_size }} col-sm-12 col-12">
          <div class="image-with-text--image media-wrapper width-100 height-100">
            <div class="media{% if section.settings.image_ratio == 'adapt-to-content' %} d-media-fixed{% endif %}" style="--image_ratio: {{ imageRatio }}">
              {%- if section.settings.image != blank -%}
                {% render 'lazy-image'
                  , image: section.settings.image
                  , source: 'image-with-text' %}
              {%- else -%}
                {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
        </div>
        {% if section.blocks.size > 0 %}
          <div class="col-lg-{{ col_text_size }} col-md-{{ col_text_size }} col-sm-12 col-12">
            <div class="image-with-text--content {{ section.settings.content_padding }}-padding">

              {%- for block in section.blocks -%}
                {% case block.type %}
                  {%- when 'heading' -%}


                    {% if block.settings.heading != blank %}
                      <variety-heading {{ block.shopify_attributes }}>
                        {%- capture markersPrefix -%}
                        <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                      {%- endcapture -%}
                        {%- capture markersSuffix -%}
                        </span>
                      {%- endcapture -%}
                        <{{ block.settings.seo_heading }} class="image-with-text--heading {{ block.settings.heading_size }}"  {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %} {{ block.shopify_attributes }} >
                          {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                          </{{ block.settings.seo_heading }}>
                        </variety-heading>
                      {% endif %}

                    {%- when 'text' -%}
                      <div class="image-with-text--desc rte {{ block.settings.description_size }}" {{ block.shopify_attributes }} {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                        {{ block.settings.text | replace: '<p></p>', '<br>' }}
                      </div>
                    {%- when 'button' -%}
                      {% if block.settings.btn_url != blank and block.settings.btn_text != blank %}
                        {% liquid
                          if block.settings.button_style == 'link'
                            assign button_class = 'text-underline'
                            assign show_as_link = true
                          else
                            assign button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                            assign show_as_link = false
                          endif
                        %}
                        <div class="image-with-text--button" {{ block.shopify_attributes }} {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                          <a href="{{ block.settings.btn_url }}" class="{{ button_class }} {{ block.settings.button_style }}-button">
                            {% render 'button-appearance'
                              , button_text: block.settings.btn_text
                              , icon: 'arrow-right'
                              , show_as_link: show_as_link %}
                          </a>
                        </div>
                      {% endif %}
                  {%- endcase -%}
                {% endfor %}

              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  <style>

    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --text_alignment: {{ section.settings.alignment }};
      --content_position: {{ section.settings.content_position }};


      /*
   --text_alignment1: {{ text_alignment[0] }};
   --text_alignment2: {{ text_alignment[1] }};
   --text_alignment3: {{ section.settings.content_position }};
*/

    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
  </style>
