{% if section.index <= 2 %}
  {{ 'slideshow.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'slideshow.css' | asset_url | stylesheet_tag }} 

{% liquid
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif

  assign isMarqueeOverlaycontent = false
  if section.settings.marquee_overlay_heading != blank or section.settings.marquee_overlay_description
    assign isMarqueeOverlaycontent = true
  endif

  assign isHeight100vh = false
  if section.settings.desktop_height == '100vh'
  assign isHeight100vh = true
  endif

  assign clone_limit = 10
%}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}" data-slider-wrapper>
  <div class="{{ containerClass }}">
   
      {% if section.blocks.size > 1 %}
        <swiper-content data-resize="false">
      {% endif %}
      
        <div class="slideshow--outer {{ section.settings.mobile_radius_selector }} {{ section.settings.desktop_radius_selector }} {% if section.blocks.size > 1 %} swiper navigation-{{ section.settings.carousel_navigation }}{% endif %}"
          {% if section.blocks.size > 1 %}
          data-swiper='
              {
                  "loop": true,
                  {% if section.settings.animation_style == 'fade' %}
                  "effect": "fade",
                  {% elsif section.settings.animation_style == 'coverflow' %}
                  "effect": "coverflow",
                  "coverflowEffect": {
                      "rotate": 50,
                      "stretch": "50%",
                      "depth": 200,
                      "modifier": 1,
                      "slideShadows": true
                  },
                  {% elsif section.settings.animation_style == 'creative' %}
                  "effect": "creative",
                      "creativeEffect": {
                      "prev": {
                          "shadow": true,
                          "translate": [0, 0, -400]
                      },
                      "next": {
                          "translate": ["100%", 0, 0]
                      }
                      },
                  {% endif %}
                  "navigation": {
                      "enabled": false,
                      "nextEl": ".swiper-button-next-{{ section.id }}",
                      "prevEl": ".swiper-button-prev-{{ section.id }}"
                    },
                  {%- if section.settings.carousel_autoplay -%}
                  "autoplay": {
                      "delay": {{ section.settings.carousel_interval | times:1000 }}
                  },
                  {%- endif -%}
                  "pagination": {
                      "el": ".swiper-pagination-{{ section.id }}",
                      "type": "bullets",
                      "clickable":true
                  },
                
                  "speed": 300,
                  "slidesPerView": 1,
                  "grabCursor": true,
                  "breakpoints": {
                  "768": {    
                    "navigation": {
                      "enabled": true,
                      "nextEl": ".swiper-button-next-{{ section.id }}",
                      "prevEl": ".swiper-button-prev-{{ section.id }}"
                    },
                    "pagination": {
                      "enabled": true,
                      "el": ".swiper-pagination-{{ section.id }}",
                      "type": "bullets",
                      "clickable":true
                    }
                  }
                }
              }'
          {% endif %}>
          <div class="slideshow--wrapper{% if section.blocks.size > 1 %} is-slider swiper-wrapper{% endif %} ">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {% when 'slide_grid' %}
                  <div
                    id="slideshowItem-{{ block.id }}"
                    class="slideshow--item{% if section.settings.enable_animation %} animeslide-slide{% endif %} scheme-{{ block.settings.color_scheme }}{% if section.blocks.size > 1 %} swiper-slide{% endif %}"
                    {{ block.shopify_attributes }}>
                    {%- if block.settings.mobile_slide_image != blank and block.settings.slide_video == blank -%}
                      <div class="slideshow--media media-wrapper media-overlay d-block d-md-none">
                        <div class="media{% if section.settings.desktop_height == 'auto' %} d-media-adapt{% else %} d-media-fixed{% endif %}{% if section.settings.mobile_height == 'auto' %} m-media-adapt{% else %} m-media-fixed{% endif %}">
                          {% comment %} {% render 'lazy-image', image: block.settings.mobile_slide_image %} {% endcomment %}
                          {% liquid
                            if block.settings.mobile_slide_image != blank                         
                              assign height = block.settings.mobile_slide_image.width | divided_by: block.settings.mobile_slide_image.aspect_ratio | round
                              assign sizes = '100vw'
                              assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                              if section.index == 1
                                assign fetch_priority = 'high'
                              endif
                              if forloop.first
                                echo block.settings.mobile_slide_image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                              else
                                echo block.settings.mobile_slide_image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                              endif
                            endif
                          %}

                        </div>
                      </div>
                    {% endif %}
                    <div class="slideshow--media media-wrapper media-overlay{% if block.settings.mobile_slide_image != blank and block.settings.slide_video == blank %} d-none d-md-block{% endif %}">
                      <div class="media {% if section.settings.desktop_height == 'auto' %} d-media-adapt{% else %} d-media-fixed{% endif %}{% if section.settings.mobile_height == 'auto' %} m-media-adapt{% else %} m-media-fixed{% endif %}">
                        {%- if block.settings.slide_video != blank -%}
                          {{
                            block.settings.slide_video | media_tag: loading: 'lazy', class: 'no-js-hidden slide-video', autoplay: true, loop: true, mute: true, controls: false, preload: 'none'
                          }}
                          {%- elsif block.settings.desktop_slide_image != blank -%}
                          {% liquid
                            if block.settings.desktop_slide_image != blank                          
                              assign height = block.settings.desktop_slide_image.width | divided_by: block.settings.desktop_slide_image.aspect_ratio | round
                              assign sizes = '100vw'
                              assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                              if section.index == 1
                                assign fetch_priority = 'high'
                              endif
                              if forloop.first
                                echo block.settings.desktop_slide_image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                              else
                                echo block.settings.desktop_slide_image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                              endif
                            endif
                          %}
                          
                        {% comment %} {% render 'lazy-image', image: block.settings.desktop_slide_image %} {% endcomment %}

                        {%- else -%}
                          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                      </div>
                    </div>
                    {% liquid
                      assign contentExists = false
                      assign buttonsExists = false
                      if block.settings.heading != blank or block.settings.description != blank
                        assign contentExists = true
                      endif
                      if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank
                        assign contentExists = true
                        assign buttonsExists = true
                      endif
                      if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank
                        assign contentExists = true
                        assign buttonsExists = true
                      endif
                    %}
                    {% if contentExists %}
                      <div class="slideshow--content-wrapper container-fullwidth">
                        <div class="slideshow--content {{ block.settings.desktop_content_position }} {{ block.settings.mobile_content_position }} {{ block.settings.content_width }}-width d-text-{{ block.settings.desktop_text_alignment }} m-text-{{ block.settings.mobile_text_alignment }}" data-no-cursor="">
                          {% if block.settings.heading != blank or block.settings.description != blank %}
                            {% if block.settings.description != blank and block.settings.show_description == 'above-heading' %}
                              <p class="slideshow--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                {{ block.settings.description | newline_to_br }}
                              </p>
                            {% endif %}
                            {% if block.settings.heading != blank %}
                              {%- capture markersPrefix -%}
                                <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                              {%- endcapture -%}
                              {%- capture markersSuffix -%}
                                </span>
                              {%- endcapture -%}
                              <{{ block.settings.heading_tag }} class="slideshow--heading{% if block.settings.heading_tag == 'div' or block.settings.heading_tag == 'span' or block.settings.heading_tag == 'p' %} heading-font{% endif %}{% if section.settings.enable_animation %} animeslide-heading{% endif %} {{ block.settings.heading_size_slide }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                              </{{ block.settings.heading_tag }}> 
                              {% endif %}
                              {% if block.settings.description != blank and block.settings.show_description == 'below-heading' %}
                                <p class="slideshow--desc{% if section.settings.enable_animation %} animeslide-desc{% endif %} {{ block.settings.description_size }}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                  {{ block.settings.description | newline_to_br }}
                                </p>
                              {% endif %}
                              {% if buttonsExists %}
                                <div class="slideshow--button-box">
                                  {% if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank %}
                                    {% liquid
                                      if block.settings.primary_button_syle == 'link'
                                        assign button_class = 'text-underline'
                                        assign show_as_link = true
                                      else
                                        assign button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                        assign show_as_link = false
                                      endif
                                    %}
                                    <div class="slideshow--button slideshow--primary-button{% if section.settings.enable_animation %} animeslide-primary-btn{% endif %}"{% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      <a href="{{ block.settings.primary_button_url }}" class="{{ button_class }} {{ block.settings.primary_button_syle }}-button">
                                        {% render 'button-appearance', button_text: block.settings.primary_button_text, icon: 'arrow-right' show_as_link: show_as_link
                                        %}
                                      </a>
                                    </div>
                                  {% endif %}
                                  {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank %}
                                    {% liquid
                                      if block.settings.secondary_button_syle == 'link'
                                        assign button_class = 'text-underline'
                                      else
                                        assign button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                                      endif
                                    %}
                                    <div class="slideshow--button slideshow--secondary-button{% if section.settings.enable_animation %} animeslide-secondary-btn{% endif %}" {% if section.settings.enable_animation %} data-animate="bottom"{% endif %}>
                                      <a href="{{ block.settings.secondary_button_url }}" class="{{ button_class }}{%  unless block.settings.secondary_button_syle == 'outline' or block.settings.secondary_button_syle == 'link'  %} secondary--button{% endunless %} {{ block.settings.secondary_button_syle }}-button">
                                        {% render 'button-appearance', button_text: block.settings.secondary_button_text, icon: 'arrow-right' %}
                                      </a>
                                    </div>
                                  {% endif %}
                                </div>
                              {% endif %}
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                {% endcase %}
              {%- endfor -%}
            </div>

            

            {% if section.blocks.size > 1 %}
              <div class="swiper--button-wrapper right-position">
                
                {% liquid 
                  if settings.slilder_button_style == 'square'
                    assign btnIcon = 'curve-arrow'
                  else
                    assign btnIcon = 'arrow-icon'
                  endif
                %}
                
                <swiper-nav class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }} button-{{ settings.slilder_button_style }}" is="magnet-area">
                  {% render 'icons', icon: btnIcon %}
                </swiper-nav>
                <swiper-nav class="swiper-button-next swiper-button swiper-button-next-{{ section.id }} button-{{ settings.slilder_button_style }}" is="magnet-area">
                  {% render 'icons', icon: btnIcon %}
                </swiper-nav>
              </div>

              <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
            {% endif %}

        </div>
        
        {% if section.blocks.size > 1 %}
          </swiper-content>
        {% endif %}
      
  </div>
  

</div>
  <style>
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --marquee_font_size: {{ section.settings.desktop_marquee_size }}px;
    }
    {%- for block in section.blocks -%}
      #slideshowItem-{{ block.id }} {
        --image_overlay_opacity: {{ block.settings.overlay_opacity }};
      }
    {% endfor %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        

        --media_height: {% if section.settings.desktop_height == '100vh' %}calc(100vh - var(--announcement_height, 0px)){% else %}{{ section.settings.desktop_custom_height }}px{% endif %};
    
      }
      #shopify-section-{{ section.id }} {
        {% if section.blocks.first.settings.slide_video != blank %}
          --image_ratio: {{- 1 | divided_by : section.blocks.first.settings.slide_video.aspect_ratio | times: 100 -}}%;
        {% elsif section.blocks.first.settings.desktop_slide_image != blank %}
          --image_ratio: {{- 1 | divided_by : section.blocks.first.settings.desktop_slide_image.aspect_ratio | times: 100 -}}%;
        {%- else -%}
          --image_ratio: 50%;
        {% endif %}
      }
    }
@media (max-width: 767px) {
  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_mobile }}px;
    --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
  }
  #shopify-section-{{ section.id }} {
    --marquee_font_size: {{ section.settings.mobile_marquee_size }}px;
    --media_height: {% if section.settings.mobile_height == '100vh' %}100vh{% else %}{{ section.settings.mobile_custom_height }}px{% endif %};
}
#shopify-section-{{ section.id }} {
  {% if section.blocks.first.settings.slide_video != blank %}
    --image_ratio: {{- 1 | divided_by : section.blocks.first.settings.slide_video.aspect_ratio | times: 100 -}}%;
  {% elsif section.blocks.first.settings.mobile_slide_image != blank %}
    --image_ratio: {{- 1 | divided_by : section.blocks.first.settings.mobile_slide_image.aspect_ratio | times: 100 -}}%;
  {% elsif section.blocks.first.settings.desktop_slide_image != blank %}
    --image_ratio: {{- 1 | divided_by : section.blocks.first.settings.desktop_slide_image.aspect_ratio | times: 100 -}}%;
  {%- else -%}
    --image_ratio: 100%;
  {% endif %}
}
}

{% if section.settings.section_visibility == 'large' %}
  @media(max-width: 767px) {
    #shopify-section-{{ section.id }} {
      display: none !important;
    }
  }
{% elsif section.settings.section_visibility == 'small' %}
@media(min-width: 768px) {
  #shopify-section-{{ section.id }} {
    display: none !important;
  }
}
{% endif %}
  </style>

  {%- schema -%}
    {
      "name": "t:sections.slideshow.name",
      "tag": "section",
      "class": "section-slideshow",
      "disabled_on": {
        "groups": ["header", "footer", "custom.Overlay"]
      },
      "settings": [
        {
          "type": "select",
          "id": "section_visibility",
          "label": "t:sections.all.section_visibility.label",
          "default": "always",
          "options": [
            {
              "label": "t:sections.all.section_visibility.always.label",
              "value": "always"
            },
            {
              "label": "t:sections.all.section_visibility.small.label",
              "value": "small"
            },
            {
              "label": "t:sections.all.section_visibility.large.label",
              "value": "large"
            }
          ]
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "secondary",
          "label": "t:sections.all.colors.label"
        },
        {
          "type": "select",
          "id": "section_background",
          "label": "t:sections.all.section_background.label",
          "default": "solid",
          "options": [
            {
              "label": "t:sections.all.section_background.solid.label",
              "value": "solid"
            },
            {
              "label": "t:sections.all.section_background.gradient.label",
              "value": "gradient"
            }
          ]
        },
        {
          "type": "select",
          "id": "section_container_width",
          "label": "t:sections.all.section_container_width.label",
          "default": "no-container",
          "options": [
            {
              "label": "t:sections.all.section_container_width.global.label",
              "value": "global"
            },
            {
              "label": "t:sections.all.section_container_width.container-sm.label",
              "value": "container-sm"
            },
            {
              "label": "t:sections.all.section_container_width.container.label",
              "value": "container"
            },
            {
              "label": "t:sections.all.section_container_width.container-md.label",
              "value": "container-md"
            },
            {
              "label": "t:sections.all.section_container_width.container-fullwidth.label",
              "value": "container-fullwidth"
            },
            {
              "label": "t:sections.all.section_container_width.no-container.label",
              "value": "no-container"
            }
          ]
        },
        {
          "type": "select",
          "id": "animation_style",
          "label": "t:sections.slideshow.settings.animation_style.label",
          "default": "slide",
          "options": [
            {
              "label": "t:sections.slideshow.settings.animation_style.coverflow.label",
              "value": "coverflow"
            },
            {
              "label": "t:sections.slideshow.settings.animation_style.creative.label",
              "value": "creative"
            },

            {
              "label": "t:sections.slideshow.settings.animation_style.fade.label",
              "value": "fade"
            },

            {
              "label": "t:sections.slideshow.settings.animation_style.slide.label",
              "value": "slide"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "carousel_autoplay",
          "label": "t:sections.all.carousel_autoplay.label",
          "default": false
        },
        {
          "type": "range",
          "id": "carousel_interval",
          "label": "t:sections.all.carousel_interval.label",
          "default": 3,
          "min": 1,
          "max": 9,
          "step": 1,
          "unit": "s"
        },
        {
          "type": "checkbox",
          "id": "enable_animation",
          "label": "t:sections.slideshow.settings.enable_animation.label",
          "default": false
        },
        {
          "type": "select",
          "id": "carousel_navigation",
          "label": "t:sections.slideshow.settings.carousel_navigation.label",
          "default": "arrows",
          "options": [
            {
              "label": "t:sections.slideshow.settings.carousel_navigation.arrows.label",
              "value": "arrows"
            },
            {
              "label": "t:sections.slideshow.settings.carousel_navigation.dots.label",
              "value": "dots"
            },
            {
              "label": "t:sections.slideshow.settings.carousel_navigation.both.label",
              "value": "both"
            },
            {
              "label": "t:sections.slideshow.settings.carousel_navigation.none.label",
              "value": "none"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:sections.all.headers.slides_height"
        },
        {
          "type": "paragraph",
          "content": "t:settings_schema.global.settings.desktop.label"
        },
        {
          "type": "select",
          "id": "desktop_height",
          "label": "t:sections.all.slide_heights.label",
          "default": "100vh",
          "options": [
            {
              "label": "t:sections.all.slide_heights.auto.label",
              "value": "auto"
            },
            {
              "label": "t:sections.all.slide_heights.100vh.label",
              "value": "100vh"
            },
            {
              "label": "t:sections.all.slide_heights.custom.label",
              "value": "custom"
            }
          ]
        },
        {
          "type": "range",
          "id": "desktop_custom_height",
          "label": "t:sections.all.custom_height.label",
          "default": 750,
          "step": 10,
          "min": 500,
          "max": 1000,
          "unit": "px"
        },
        {
          "type": "paragraph",
          "content": "t:settings_schema.global.settings.mobile.label"
        },
        {
          "type": "select",
          "id": "mobile_height",
          "label": "t:sections.all.slide_heights.label",
          "default": "100vh",
          "options": [
            {
              "label": "t:sections.all.slide_heights.auto.label",
              "value": "auto"
            },
            {
              "label": "t:sections.all.slide_heights.100vh.label",
              "value": "100vh"
            },
            {
              "label": "t:sections.all.slide_heights.custom.label",
              "value": "custom"
            }
          ]
        },
        {
          "type": "range",
          "id": "mobile_custom_height",
          "label": "t:sections.all.custom_height.label",
          "default": 800,
          "step": 10,
          "min": 300,
          "max": 800,
          "unit": "px"
        },
        {
          "type": "header",
          "content": "t:settings_schema.global.settings.corner_radius.label"
        },
        {
          "type": "select",
          "id": "desktop_radius_selector",
          "label": "t:sections.all.desktop_radius_selector.label",
          "default": "d-border-radius-none",
          "options": [
            {
              "label": "t:sections.all.desktop_radius_selector.d-border-radius-none.label",
              "value": "d-border-radius-none"
            },
            {
              "label": "t:sections.all.desktop_radius_selector.d-border-radius-top.label",
              "value": "d-border-radius-top"
            },
            {
              "label": "t:sections.all.desktop_radius_selector.d-border-radius-bottom.label",
              "value": "d-border-radius-bottom"
            },
            {
              "label": "t:sections.all.desktop_radius_selector.d-border-radius-all.label",
              "value": "d-border-radius-all"
            }
          ]
        },
        {
          "type": "select",
          "id": "mobile_radius_selector",
          "label": "t:sections.all.mobile_radius_selector.label",
          "default": "m-border-radius-none",
          "options": [
            {
              "label": "t:sections.all.mobile_radius_selector.m-border-radius-none.label",
              "value": "m-border-radius-none"
            },
            {
              "label": "t:sections.all.mobile_radius_selector.m-border-radius-top.label",
              "value": "m-border-radius-top"
            },
            {
              "label": "t:sections.all.mobile_radius_selector.m-border-radius-bottom.label",
              "value": "m-border-radius-bottom"
            },
            {
              "label": "t:sections.all.mobile_radius_selector.m-border-radius-all.label",
              "value": "m-border-radius-all"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:sections.all.spacing.section_spacing_heading"
        },
        {
          "type": "range",
          "id": "top_space_desktop",
          "label": "t:sections.all.spacing.top_space_desktop",
          "default": 0,
          "min": 0,
          "max": 150,
          "step": 5
        },
        {
          "type": "range",
          "id": "bottom_space_desktop",
          "label": "t:sections.all.spacing.bottom_space_desktop",
          "default": 0,
          "min": 0,
          "max": 150,
          "step": 5
        },
        {
          "type": "range",
          "id": "top_space_mobile",
          "label": "t:sections.all.spacing.top_space_mobile",
          "default": 0,
          "min": 0,
          "max": 100,
          "step": 5
        },
        {
          "type": "range",
          "id": "bottom_space_mobile",
          "label": "t:sections.all.spacing.bottom_space_mobile",
          "default": 0,
          "min": 0,
          "max": 100,
          "step": 5
        }
      ],
      "blocks": [
        {
          "type": "slide_grid",
          "name": "t:sections.slideshow.blocks.slide_grid.name",
          "limit": 6,
