{% if section.index <= 2 %}
  {{ 'contact-form.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'contact-form.css' | asset_url | stylesheet_tag }}
{%  liquid  
    if section.settings.section_container_width == 'global'
        assign containerClass = settings.container_width
    else 
        assign containerClass = section.settings.section_container_width
    endif

    assign show_map = false
    assign show_map_form = false

    if section.settings.section_layout == 'map' 
      assign show_map = true 
    elsif section.settings.section_layout == 'contact-form'
      assign show_map = false 
    elsif section.settings.section_layout == 'both'
      assign show_map_form = true
    endif

    if section.settings.desktop_height == 'adapt'
    assign mediaDesktopClass = "d-media-adapt"
    else
    assign mediaDesktopClass = "d-media-fixed"
    endif
 
    if section.settings.mobile_height == 'adapt'
     assign mediaMobileClass = "m-media-adapt"
     else
    assign mediaMobileClass = "m-media-fixed"
    endif

%}
<div class="section-spacing section-wrapper scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ containerClass }}">
    <div class="alert alert--error gmap--error hidden" data-gmap-error>No results for that address</div>
    <div class="contact-form--wrapper style-{{ section.settings.section_layout }}">
      {% capture mediaContent %}
        {% if show_map == true or show_map_form == true %}
          <div class="contact-form--map-box width-100 media-wrapper">
            <map-element class="d-block width-100 height-100 contact-form--map"  data-location="{{ section.settings.map_address }}"
              data-map-style="{{ section.settings.map_style }}"
                {% if section.settings.map_address != blank %}
                  data-map-container
                {% endif %}>
                <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }}" >
                  {% unless section.settings.map_address != blank %}
                  {%- if section.settings.image != blank -%}
                    {{ section.settings.image | image_url: width: null | image_tag }}
                  {% else %}
                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                {% endunless %}
                </div>
            </map-element>
           {% if section.settings.map_heading != blank or section.settings.map_description != blank %}
            <div class="contact-form--map-content">
              {% if section.settings.map_heading != blank %}
                <h6 class="contact-form--map-heading heading-font h6">{{ section.settings.map_heading }}</h6>
              {% endif %}
              {% if section.settings.map_description != blank %}
                <div class="contact-form--map-desc rte">{{ section.settings.map_description }}</div>
              {% endif %}
            </div> 
           {% endif %}
          </div>
         
      {% endif %}
      {% endcapture %}
      {% liquid
        if section.settings.image_position == 'left'
          echo mediaContent
        endif
      %}
      {% if show_map == false or show_map_form == true %}
        <div class="contact-form--content">
          <div class="contact-form--content-inner">
            {% if section.settings.heading != blank or section.settings.description != blank %}
              <variety-heading class="section--header text-{{ section.settings.heading_alignment}}">
                <div class="section--header-inner" >
                  {% if section.settings.heading != blank %}
                  {%- capture markersPrefix -%}
                    <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                  {%- endcapture -%}
                  {%- capture markersSuffix -%}
                    </span>
                  {%- endcapture -%}
                  <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                    {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                  </{{ section.settings.seo_heading }}>
                  {% endif %}
                  
                  {% if section.settings.description != blank %}
                    <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                      {{ section.settings.description | newline_to_br }}
                    </p>
                  {% endif %}
                </div>
              </variety-heading>
            {% endif %}
            {%- form 'contact', id: 'ContactForm', class: 'contact--form', data-shopify-captcha: "true"-%}
              <div class="contact-form--box">
                <div class="input-form--fields">
                  <div class="form-group">
                    <label class="hidden" for="ContactFistName-{{ section.id }}">{{ 'templates.contact.form.first_name' | t }}</label>
                    <input
                      type="text"
                      class="form-control"
                      name="contact[first_name]"
                      id="ContactFirstName-{{ section.id }}"
                      autocomplete="first_name"
                      autocapitalize="off"
                      placeholder="{{ 'templates.contact.form.first_name' | t }}"
                      required=""
                    >
                  </div>
                  <div class="form-group">
                    <label class="hidden" for="ContactLastName-{{ section.id }}">{{ 'templates.contact.form.last_name' | t }}</label>
                    <input
                      type="text"
                      class="form-control"
                      name="contact[last_name]"
                      id="ContactLastName-{{ section.id }}"
                      autocomplete="last_name"
                      autocapitalize="off"
                      placeholder="{{ 'templates.contact.form.last_name' | t }}"
                    >
                  </div>
                </div>
                <div class="input-form--fields">
                  <div class="form-group">
                    <label class="hidden" for="ContactEmail-{{ section.id }}">{{ 'templates.contact.form.email' | t }}</label>
                    <input
                      type="email"
                      class="form-control"
                      name="contact[email]"
                      autocomplete="email"
                      autocapitalize="off"
                      value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                      aria-required="true"
                      spellcheck="false"
                      {% if form.errors contains 'email' %}
                        aria-invalid="true"
                        aria-describedby="ContactForm-email-error"
                      {% endif %}
                      placeholder="email@example.com"
                      pattern="^([a-zA-Z0-9_\\-\\.]+)@((\\[[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.)|(([a-zA-Z0-9\\-]+\\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\\]?)$"
                      required=""
                    >
                  </div>
                  <div class="form-group">
                    <label class="hidden" for="ContactPhone-{{ section.id }}">{{ 'templates.contact.form.phone' | t }}</label>
                    <input
                      type="tel"
                      class="form-control "
                      name="contact[phone]"
                      id="ContactPhone"
                      autocomplete="phone"
                      autocapitalize="off"
                      value=""
                      aria-required="true"
                      spellcheck="false"
                      placeholder="{{ 'templates.contact.form.phone' | t }}"
                      pattern="^([a-zA-Z0-9_\\-\\.]+)@((\\[[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.)|(([a-zA-Z0-9\\-]+\\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\\]?)$"
                         
                    > 
                  </div>
                </div>
                <div class="form-group">
                  <label class="hidden" for="ContactForm-body-{{ section.id }}">{{ 'templates.contact.form.comment' | t }}</label>
                  <textarea
                    id="ContactForm-body-{{ section.id }}"
                    name="contact[Message]"  
                    rows="6"
                    placeholder="Votre message"
                    class="form-control"
                    required=""
                  ></textarea>
                </div>
                
                {%- if form.posted_successfully? -%}
                  <div class="form-group">
                  <p
                    class="form--message success"
                    id="form-message__success-{{ section.id }}"  
                    tabindex="-1"
                    role="status"
                    autofocus
                  >
                    {{- 'templates.contact.form.post_success' | t -}}
                  </p>
                  </div>
                {%- endif -%}
                {%- if form.errors -%}
                  <div class="form-group">
                    <p class="form--message error" id="form-message__error-{{ section.id }}" autofocus>
                      {{ form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email }}
                    </p>
                  </div>
                {%- endif -%}

                
                  <button type="submit" name="commit" id="send-{{ section.id }}" class="button normal-button animated" aria-label="{{ 'templates.contact.form.title' | t }}">
                    {%  assign button_text = 'templates.contact.form.send' | t %} 
                    {% render 'button-appearance', button_text: button_text, icon: 'arrow-right' %}
                  </button>
            
              </div>
              <div class="contact-form--spam-detection">
                {{ 'shopify.online_store.spam_detection.disclaimer_html' | t }}
              </div>
            {% endform %}
          </div>
        </div>
      {% endif %}
      {% liquid
        if section.settings.image_position == 'right'
          echo mediaContent
        endif
      %}
    </div>
  </div>
</div>
<style>
    .contact-form--wrapper.style {
      height: 600px !important;
    }
    .contact-form--map {
      position: relative;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }}{
      --top_spacing:{{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --media_height:{{ section.settings.desktop_height }};
    }
      
      {% if section.settings.map_heading != blank or section.settings.map_description != blank or section.settings.image != blank or section.settings.map_address != blank %}
        #shopify-section-{{ section.id }}{
        --image_overlay_opacity: {{ section.settings.overlay_opacity }};
      }
      {% endif %}
   
      @media only screen and (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          --top_spacing: {{ section.settings.top_space_mobile }}px;
          --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
          --media_height:{{ section.settings.mobile_height }};
        }
      }

      {% if section.settings.section_visibility == 'large' %}
        @media (max-width: 767px) {
          #shopify-section-{{ section.id }} {
            display: none !important;
          }
        }
      {% elsif section.settings.section_visibility == 'small' %}
        @media (min-width: 768px) {
          #shopify-section-{{ section.id }} {
            display: none !important;
          }
        }
    {% endif %}
</style>

