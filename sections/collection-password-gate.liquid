{{ 'collection-password-gate.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable -%}
  <collection-password-gate
    data-section-id="{{ section.id }}"
    data-password="{{ section.settings.password }}"
    data-session-key="{{ section.settings.session_key | default: 'collection_access' }}"
    data-persistence-mode="{{ section.settings.persistence_mode }}"
    data-persistence-duration="{{ section.settings.persistence_duration }}"
  ></collection-password-gate>

  {% render 'popup',
    modal_name: 'collection-password',
    modal_position: 'center',
    modal_size: 'small',
    section: section,
    popup_color_scheme: section.settings.color_scheme
  %}

  <script src="{{ 'collection-password-gate.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collection_password_gate.name",
  "tag": "section",
  "class": "collection-password-gate-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collection_password_gate.settings.header_general"
    },
    {
      "type": "checkbox",
      "id": "enable",
      "label": "t:sections.collection_password_gate.settings.enable_label",
      "default": true
    },
    {
      "type": "text",
      "id": "password",
      "label": "t:sections.collection_password_gate.settings.password_label",
      "default": "sudist2026"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.collection_password_gate.settings.color_scheme_label",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:sections.collection_password_gate.settings.header_content"
    },
    {
      "type": "image_picker",
      "id": "gate_image",
      "label": "t:sections.collection_password_gate.settings.image_label"
    },
    {
      "type": "text",
      "id": "gate_heading",
      "label": "t:sections.collection_password_gate.settings.heading_label",
      "default": "Vente Privee"
    },
    {
      "type": "textarea",
      "id": "welcome_text",
      "label": "t:sections.collection_password_gate.settings.welcome_text_label",
      "default": "Bienvenue dans notre espace exclusif.\nCette vente est reservee a nos membres privilegies."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "t:sections.collection_password_gate.settings.placeholder_label",
      "default": "Entrez le mot de passe"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.collection_password_gate.settings.button_text_label",
      "default": "Acceder a la vente"
    },
    {
      "type": "text",
      "id": "error_text",
      "label": "t:sections.collection_password_gate.settings.error_text_label",
      "default": "Mot de passe incorrect"
    },
    {
      "type": "checkbox",
      "id": "enable_show_password",
      "label": "t:sections.collection_password_gate.settings.enable_show_password_label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.collection_password_gate.settings.header_countdown"
    },
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "label": "t:sections.collection_password_gate.settings.enable_countdown_label",
      "default": false
    },
    {
      "type": "text",
      "id": "countdown_date",
      "label": "t:sections.collection_password_gate.settings.countdown_date_label",
      "info": "t:sections.collection_password_gate.settings.countdown_date_info"
    },
    {
      "type": "text",
      "id": "countdown_label",
      "label": "t:sections.collection_password_gate.settings.countdown_label_label",
      "default": "La vente commence dans"
    },
    {
      "type": "header",
      "content": "t:sections.collection_password_gate.settings.header_persistence"
    },
    {
      "type": "select",
      "id": "persistence_mode",
      "label": "t:sections.collection_password_gate.settings.persistence_mode_label",
      "default": "session",
      "options": [
        {
          "label": "t:sections.collection_password_gate.settings.persistence_session",
          "value": "session"
        },
        {
          "label": "t:sections.collection_password_gate.settings.persistence_duration",
          "value": "duration"
        }
      ]
    },
    {
      "type": "range",
      "id": "persistence_duration",
      "label": "t:sections.collection_password_gate.settings.persistence_duration_label",
      "default": 24,
      "min": 1,
      "max": 72,
      "step": 1,
      "unit": "h"
    },
    {
      "type": "text",
      "id": "session_key",
      "label": "t:sections.collection_password_gate.settings.session_key_label",
      "info": "t:sections.collection_password_gate.settings.session_key_info",
      "default": "collection_access"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_password_gate.name"
    }
  ]
}
{% endschema %}
