{% if section.index <= 2 %}
  {{ 'multicolumn.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'multicolumn.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <variety-heading class="section--header text-{{ section.settings.heading_alignment }}">
        <div class="section--header-inner">
          {% if section.settings.heading != blank %}
            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}
            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
            {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
            </{{ section.settings.seo_heading }}>
          {% endif %}
          {% if section.settings.description != blank %}
            <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>{{ section.settings.description | newline_to_br }}</p>
          {% endif %}
        </div>
      </variety-heading>
    {% endif %}
  </div>
  <div class="{{ settings.container_width }} {% if section.settings.enable_swipe_mobile %}m-pr-0{% endif %}">
    <div class="multicolumn--wrapper{% if section.settings.enable_swipe_mobile == true %} mobile-swipe{% endif %} {% if section.settings.column_background %} column-background-enabled{% endif %}">
        {% for block in section.blocks %}
          {% liquid
            if section.settings.image_ratio == 'landscape'
              assign imageRatio = 75
            elsif section.settings.image_ratio == 'square'
              assign imageRatio = 100
            elsif section.settings.image_ratio == 'portrait'
              assign imageRatio = 125
            else
              if block.settings.image != blank
                assign imageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | plus: 1
              elsif collection.featured_image
                assign imageRatio = 1 | divided_by: collection.featured_image.aspect_ratio | times: 100 | plus: 1
              else
                assign imageRatio = 100
              endif
            endif

            if section.settings.rounded == true
                assign imageRatio = 100
            endif
          -%}
            <div id="block-{{ block.id }}" class="multicolumn--item scheme-{{ block.settings.column_color_scheme }}" {% if settings.is_card_animation %} data-card-animate {% endif %}>
              {% if block.settings.image != blank %}
                {% if section.settings.rounded %}
                  {%  assign roundClass = ' rounded' %}
                {% endif %}
                {%  assign className = 'multicolumn--img media-wrapper width-100' %}
                {% if block.settings.link_url != blank %}
                  <a href="{{ block.settings.link_url }}" class="{{className}}{{roundClass}}">
                  {% else %} 
                  <div class="{{className}}{{roundClass }}">
                  {% endif %} 
                  <div class="media" style="--image_ratio:{{ imageRatio }}%">
                    {% render 'lazy-image', image: block.settings.image %}
                  </div>
                  {% if block.settings.link_url != blank %}
                    </a>
                  {% else %}
                  </div>
                  {% endif %}
              {% endif %}
              {% if block.settings.heading != blank
                or block.settings.description != blank
                or block.settings.link_label != blank
                %}
                <div class="multicolumn--content text-{{ section.settings.card_content_alignment }} ">
                  {% if block.settings.heading != blank %}
                    <{{ section.settings.card_seo_heading }} class="heading-font multicolumn--content-heading {{ section.settings.card_heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ section.settings.card_seo_heading }}>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="multicolumn--content-desc">
                      {{ block.settings.description | newline_to_br }}
                    </p>
                  {% endif %}
                  {% if block.settings.link_url != blank and block.settings.link_label != blank %}
                    <a
                      {% if block.settings.link_url != blank %}
                        href="{{block.settings.link_url}}"
                      {% endif %}
                      class="multicolumn--content-link text-underline"
                    >
                      {{- block.settings.link_label -}}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
        {% endfor %}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --column_count: {{ section.settings.desktop_column_count }};
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
        --column_count: {{ section.settings.mobile_column_count }};
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

