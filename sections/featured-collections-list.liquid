<style>
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --animation_speed: {{ section.settings.marquee_speed }}s;
      --media_height:{{ section.settings.desktop_height }}px;
      --image_overlay_opacity: {{ section.settings.overlay_opacity }};
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
        --media_height:{{ section.settings.mobile_height }}px;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
      
  {% endif %}
</style>

{%- schema -%}
{
  "name": "t:sections.featured-collections-list.name",
  "tag": "section",
  "class": "section-featured-collections-list",
  "disabled_on": {
    "groups": ["header", "footer", "custom.Overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:sections.all.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:sections.all.section_visibility.always.label",
          "value": "always"
        },
        {
          "label": "t:sections.all.section_visibility.small.label",
          "value": "small"
        },
        {
          "label": "t:sections.all.section_visibility.large.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "select",
      "id": "section_background",
      "label": "t:sections.all.section_background.label",
      "default": "solid",
      "options": [
          {
              "label": "t:sections.all.section_background.solid.label",
              "value": "solid"
          },
          {
              "label": "t:sections.all.section_background.gradient.label",
              "value": "gradient"
          }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:sections.featured-collections-list.settings.direction.label",
      "default": "rtl",
      "options": [
        {
          "value": "rtl",
          "label": "t:sections.featured-collections-list.settings.direction.rtl.label"
        },
        {
          "value": "ltr",
          "label": "t:sections.featured-collections-list.settings.direction.ltr.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "t:sections.featured-collections-list.settings.marquee_speed.label",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "t:sections.all.video_height.label",
      "default": 800,
      "step": 10,
      "min": 500,
      "max": 1000,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "t:sections.all.mobile_video_height.label",
      "default": 500,
      "step": 10,
      "min": 300,
      "max": 800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "default": 0.3,
      "label": "t:settings_schema.global.settings.image_overlay_opacity.label",
      "min": 0,
      "max": 1,
      "step": 0.1
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing.section_spacing_heading"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:sections.all.spacing.top_space_desktop",
      "default": 0,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:sections.all.spacing.bottom_space_desktop",
      "default": 0,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:sections.all.spacing.top_space_mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:sections.all.spacing.bottom_space_mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "name": "t:sections.featured-collections-list.blocks.collection-image.name",
      "type": "collection-image",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.all.headers.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings_schema.global.settings.image.label"
        },
        {
          "type": "text",
          "label": "t:settings_schema.global.settings.title.label",
          "id": "title",
          "default": "Collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collections-list.presets.name",
      "blocks": [
        {
          "type": "collection-image"
        },
        {
          "type": "collection-image"
        },
        {
          "type": "collection-image"
        },
        {
          "type": "collection-image"
        },
        {
          "type": "collection-image"
