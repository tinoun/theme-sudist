                  </svg>
                </{% if block.settings.collection.url != blank %}a{% else %}span{% endif %}>
                <div class="featured-collections-list--marque" data-marquee-speed="{{ section.settings.marquee_speed }}" data-marquee>  
                  <div class="featured-collections-list--marque-text-wrapper {{ section.settings.direction }}-direction">
                    {% for i in (1..24) %}
                      <div class="featured-collections-list--marque--text--node" data-marquee-node>
                        <div class="featured-collections-list--marque-text--item heading-font">
                          {% if coll_title != blank %}
                            {{- coll_title -}}
                          {% else %}
                            {{- 'onboarding.collection_title' | t -}}
                        {% endif %}
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                </div>
            
            </image-overlay-text>            
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="featured-collections-list--item" data-content-wrapper>
      <div class="featured-collections-list--image media-overlay width-100 height-100 pos-relative overflow-hidden">
        {% for block in section.blocks %}
          {% assign mod = forloop.index | modulo: 2 %}
          {% if mod == 0 %}
            <div class="featured-collections-list--image-inner media-wrapper{% if forloop.index == 2 %} active{% endif %}" data-image-id="{{ block.id }}">
              <div class="media media-fixed">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: null | image_tag }}
                  {% elsif block.settings.collection != blank %}
                  {{ block.settings.collection.featured_image | image_url: width: null | image_tag }}
                {%- else -%}
                {%  liquid 
