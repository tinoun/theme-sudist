{% if section.index <= 2 %}
  {{ 'featured-collections-list.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'featured-collections-list.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="featured-collections-list--wrapper">
    <div class="featured-collections-list--item active" data-content-wrapper>
      <div class="featured-collections-list--image media-overlay width-100 height-100 pos-relative overflow-hidden">
        {% for block in section.blocks %}
          {% assign mod = forloop.index | modulo: 2 %}
          {% if forloop.first or mod == 1 %} 
            <div class="featured-collections-list--image-inner media-wrapper{% if forloop.first %} active{% endif %}" data-image-id="{{ block.id }}">
              <div class="media media-fixed">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: null | image_tag }}
                  {% elsif block.settings.collection != blank %}
                  {{ block.settings.collection.featured_image | image_url: width: null | image_tag }} 
                {%- else -%}
                {%  liquid 
                capture current
                  cycle section.id: 1, 2, 3, 4
                endcapture
                %}
                  {{ 'collection-apparel-' |  append: current | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="featured-collections-list--content width-100 height-100">
        {% for block in section.blocks %}
          {% assign mod = forloop.index | modulo: 2 %}
          {% if forloop.first or mod == 1 %}           
            <image-overlay-text
              class="featured-collections-list--content-inner {% if forloop.first %} active{% endif %}"
              data-id="{{ block.id }}"
            >
              {%- assign coll_title = block.settings.title | default: block.settings.collection.title -%}
              <{% if block.settings.collection.url != blank %}a href="{{ block.settings.collection.url  }}"{% else %}span{% endif %} class="featured-collections-list--link heading-font h5" >
                {% if coll_title != blank %}
                  <span>{{- coll_title -}}</span>
                {% else %}
                  <span>{{- 'onboarding.collection_title' | t -}}</span>
                {% endif %}
                  <svg class="icon icon-circle" viewBox="0 0 800 350" stroke="currentColor" fill="none" role="presentation" preserveAspectRatio="none">
                    <path transform="matrix(0.9791300296783447,0,0,0.9791300296783447,400,179)" stroke-linejoin="miter" stroke-miterlimit="4" stroke-width="10" pathLength="1" d=" M253,-161 C253,-161 -284.78900146484375,-201.4600067138672 -376,-21 C-469,163 67.62300109863281,174.2100067138672 256,121 C564,34 250.82899475097656,-141.6929931640625 19.10700035095215,-116.93599700927734"></path>
