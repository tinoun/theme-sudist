{% if section.index <= 2 %}
  {{ 'before-after.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'before-after.css' | asset_url | stylesheet_tag }}
{% liquid
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif

  if section.settings.desktop_height == 'adapt_to_first'
    assign mediaDesktopClass = "d-media-adapt"
  else
    assign mediaDesktopClass = "d-media-fixed"
  endif

  if section.settings.mobile_height == 'adapt_to_first'
    assign mediaMobileClass = "m-media-adapt"
  else
    assign mediaMobileClass = "m-media-fixed"
  endif
%}

{% capture beforeAftercontent %}
  {% if section.blocks.size > 0 %}
    <div
      class="before-after--wrapper"
      data-layout="horizontal"
      data-parent-wrapper=""
      data-percentage-value="{{ section.settings.percentage_value }}"
      >
      {% for block in section.blocks %}
        <div class="media-wrapper media-overlay width-100 height-100 {% if forloop.first %}before-after--main image-effect-{{ block.settings.image_effect }}{% else %} before-after--overlay image-effect-{{ block.settings.image_effect }} {% endif %}" id="imageItem-{{ block.id }}">
          <div class="before-after--content position-{{ block.settings.content_position }}">
            {% if block.settings.image_text %}
              <p class="before-after--subheading">{{ block.settings.image_text }}</p>
            {% endif %}
            {% if block.settings.image_heading %}
              <div class="h5 heading-font before-after--heading" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>{{ block.settings.image_heading }}</div>
            {% endif %}
          </div>
          {%- if block.settings.image != blank -%}
          <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }} d-none d-md-block">
              {%- render 'lazy-image', image: block.settings.image -%}
            </div>
          {%- else -%}
            <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }} d-none d-md-block">
              {{ 'hero-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if block.settings.mb_image != blank -%}
            <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }} d-block d-md-none">
                {%- render 'lazy-image', image: block.settings.mb_image -%}
              </div>
            {%  elsif block.settings.image != blank %} 
              <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }} d-block d-md-none">
                {%- render 'lazy-image', image: block.settings.image -%}
              </div>
            {%- else -%}
              <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }} d-block d-md-none">
                {{ 'hero-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
          {%- endif -%}

        </div>
      {% endfor %}

      <drag-element class="before-after--drag">
        <div class="before-after--drag-cursor" data-cursor>
          {% render 'icons', icon: 'drag-icon' %}
        </div>
      </drag-element>
    </div>
  {% endif %}
{% endcapture %}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <variety-heading class="section--header text-{{ section.settings.text_align }}">
        <div class="section--header-inner" >
          {% if section.settings.heading != blank %}
            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}

            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
              {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
            </{{ section.settings.seo_heading }}>
          {% endif %}

          {% if section.settings.description != blank %}
            <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
              {{ section.settings.description | newline_to_br }}
            </p>
          {% endif %}
        </div>
      </variety-heading>
    {% endif %}
    </div>

    <div class="{{ containerClass }}">
    {{ beforeAftercontent }}
    </div>
</div>
<style>
    #shopify-section-{{ section.id }} .section-spacing {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      {% if section.blocks.first.settings.image != blank and section.settings.desktop_height == 'adapt_to_first' %}
        --image_ratio: {{- 1 | divided_by: section.blocks.first.settings.image.aspect_ratio  | times: 100 | plus: 1 -}}%;
      {%- elsif section.blocks.first.settings.image == blank and section.settings.desktop_height == 'adapt_to_first' -%}
        --image_ratio: 50%;
      {% else %}
        --media_height: {{ section.settings.desktop_height }};
      {% endif %}
    }
    {%- for block in section.blocks -%}
      #imageItem-{{ block.id }} {
          --image_overlay_opacity: {{ block.settings.overlay_opacity }};
          {% if block.settings.image_effect != 'blur' %}
          --filter_amount: {{ block.settings.filter_amount | divided_by: 100.0 }}
          {% else %}
          --filter_amount: {{ block.settings.filter_amount | divided_by: 10.0 }}px;
          {% endif %}
      } 
    {% endfor %}
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .section-spacing {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
        {% if section.blocks.first.settings.mb_image != blank and section.settings.mobile_height == 'adapt_to_first' %}
          --image_ratio: {{- 1 | divided_by: section.blocks.first.settings.mb_image.aspect_ratio  | times: 100 | plus: 1 -}}%;
        {%- elsif section.blocks.first.settings.mb_image == blank and section.settings.mobile_height == 'adapt_to_first' -%}
          --image_ratio: 50%;
        {% else %}
          --media_height: {{ section.settings.mobile_height }};
        {% endif %}
        
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
