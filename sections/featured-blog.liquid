{% if section.index <= 2 %}
  {{ 'featured-blog.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'featured-blog.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ settings.container_width }}{% if section.settings.mobile_swipe %} m-pr-0{% endif %}">
    <div class="featured-blog--outer">
        <div class="featured-blog--intro text-{{ section.settings.heading_alignment}}">
          {% if section.settings.heading != blank or section.settings.description != blank %}
            <variety-heading class="section--header text-{{ section.settings.heading_alignment}}">
              <div class="section--header-inner">
                {%- if section.settings.heading != blank -%}
                  {%- capture markersPrefix -%}
                    <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                  {%- endcapture -%}
                  {%- capture markersSuffix -%}
                    </span>
                  {%- endcapture -%}
    
                  <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                    {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                  </{{ section.settings.seo_heading }}>
                {%- endif -%}
    
                {% if section.settings.description != blank %}
                  <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                    {{ section.settings.description | newline_to_br }}
                  </p>
                {% endif %}
              </div>
            </variety-heading>            
          {% endif %}
            
            {% if section.settings.button_text != blank and section.settings.btn_link != blank %}
              {% liquid
                if section.settings.button_style == 'link'
                  assign button_class = 'text-underline' 
                  assign show_as_link = true
                else 
                  assign button_class = 'button' | append: ' ' | append: section.settings.button_size | append: ' ' | append: settings.button_animation_style 
                  assign show_as_link = false
                endif
              %}
          
              <div class="section--btn">
                <a href="{{ section.settings.btn_link }}" class="{{ button_class }} {{ section.settings.button_style }}-button">
                    {% render 'button-appearance', button_text: section.settings.button_text, icon: 'arrow-right', show_as_link: show_as_link %}
                </a>
              </div>           
          {% endif %}
       
        </div>
        {%- if section.blocks.size > 0 -%}
          {% if section.settings.blog_style == 'collage' %}
            <div class="main-blog--wrapper featured-blog--wrapper hidden d-md-grid style-{{ section.settings.blog_style }}{% if section.settings.mobile_swipe == true %} mobile-swipe{% endif %}">
                
                  <div class="blog-items-column left-column" >
                    {%- for block in section.blocks -%}
                      {%- assign mod = forloop.index0 | modulo: 3 -%}
                      {%- if mod == 0 -%}
                        {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                        {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
                        {% render 'blog-card', section: section, article: block.settings.article, placeholder_image: placeholder_image, cardImageSize: section.settings.image_ratio, showReadmoreButton: section.settings.show_readmore_button %}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {% assign block_count = section.blocks.size %}
                  {% if block_count > 1 %}
                    <div class="blog-items-column center-column" >
                      {%- for block in section.blocks -%}
                        {%- assign mod = forloop.index0 | modulo: 3 -%}
                        {%- if mod == 1 -%}
                          {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                          {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
                          {% render 'blog-card', section: section, article: block.settings.article, placeholder_image: placeholder_image, cardImageSize: section.settings.image_ratio, showReadmoreButton: section.settings.show_readmore_button %}
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {% endif %}
                  {% if block_count > 2 %}
                    <div class="blog-items-column right-column" >
                      {%- for block in section.blocks -%}
                        {%- assign mod = forloop.index0 | modulo: 3 -%}
                        {%- if mod == 2 -%}
                          {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                          {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
                          {% render 'blog-card', section: section, article: block.settings.article, placeholder_image: placeholder_image, cardImageSize: section.settings.image_ratio, showReadmoreButton: section.settings.show_readmore_button %}
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {% endif %}
              </div>

              <div class="main-blog--wrapper featured-blog--wrapper d-grid d-md-none style-{{ section.settings.blog_style }}{% if section.settings.mobile_swipe == true %} mobile-swipe{% endif %}">
                {%- for block in section.blocks -%}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                  {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
                  {% render 'blog-card', section: section, article: block.settings.article, placeholder_image: placeholder_image, cardImageSize: section.settings.image_ratio, showReadmoreButton: section.settings.show_readmore_button %}
                {%- endfor -%}
              </div>

            {% else %}
              <div class="main-blog--wrapper featured-blog--wrapper style-{{ section.settings.blog_style }}{% if section.settings.mobile_swipe == true %} mobile-swipe{% endif %}">
                {%- for block in section.blocks -%}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                  {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
                  {% render 'blog-card', section: section, article: block.settings.article, placeholder_image: placeholder_image, cardImageSize: section.settings.image_ratio, showReadmoreButton: section.settings.show_readmore_button %}
                {%- endfor -%}
              </div>
            {% endif %}
          
        {%- endif -%}
  </div>
  <style>
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_mobile }}px ;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px ;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
  </style>

