        </div>
      </div>

      <!-- T-SHIRT PREMIUM -->
      <div class="comp-card-{{ section.id }} comp-card--premium-{{ section.id }}" data-card="2">
        <span class="comp-ribbon-{{ section.id }}">{{ section.settings.premium_ribbon }}</span>
        
        <div class="comp-card__header-{{ section.id }}">
          <div class="comp-card__icon-{{ section.id }}">
            <svg viewBox="0 0 24 24">
              <path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.47a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.47a2 2 0 00-1.34-2.23z"/>
            </svg>
          </div>
          <h3 class="comp-card__title-{{ section.id }}">{{ section.settings.premium_title }}</h3>
          <p class="comp-card__price-{{ section.id }}">{{ section.settings.premium_price }}</p>
        </div>
        
        <ul class="comp-features-{{ section.id }}">
          {% assign premium_features = section.settings.premium_features | split: '|' %}
          {% for feature in premium_features %}
            <li class="comp-feature-{{ section.id }}">
              <span class="comp-feature__icon-{{ section.id }} comp-feature__icon--good-{{ section.id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="comp-feature__text-{{ section.id }}"><strong>{{ feature | strip }}</strong></span>
            </li>
          {% endfor %}
        </ul>

        <div class="comp-durability-{{ section.id }}">
          <div class="comp-durability__header-{{ section.id }}">
            <span class="comp-durability__label-{{ section.id }}">{{ section.settings.durability_label }}</span>
            <span class="comp-durability__value-{{ section.id }}">{{ section.settings.premium_durability }}%</span>
          </div>
          <div class="comp-durability__bar-{{ section.id }}">
            <div class="comp-durability__fill-{{ section.id }}" data-width="{{ section.settings.premium_durability }}"></div>
          </div>
        </div>

        {% if section.settings.show_cta %}
        {% if section.settings.cta_url != blank %}
          <a href="{{ section.settings.cta_url }}" class="comp-cta-{{ section.id }}">
        {% else %}
          <a href="#product-form" class="comp-cta-{{ section.id }}">
