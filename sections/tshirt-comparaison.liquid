              <svg viewBox="0 0 24 24">
                <path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.47a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.47a2 2 0 00-1.34-2.23z"/>
              </svg>
            </div>
            <span class="comp-washing__count-{{ section.id }}">{{ section.settings.standard_washings }}</span>
          </div>
          <p class="comp-washing__label-{{ section.id }}">{{ section.settings.standard_title }}</p>
          <p class="comp-washing__desc-{{ section.id }}">{{ section.settings.standard_wash_desc }}</p>
        </div>
        
        <div class="comp-washing-{{ section.id }} comp-washing--premium-{{ section.id }}">
          <div class="comp-washing__visual-{{ section.id }}">
            <div class="comp-washing__tshirt-{{ section.id }} comp-washing__tshirt--perfect-{{ section.id }}">
              <svg viewBox="0 0 24 24">
                <path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.47a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.47a2 2 0 00-1.34-2.23z"/>
              </svg>
