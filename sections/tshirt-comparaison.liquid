<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const section = document.getElementById('comparison-' + sectionId);
    if (!section) return;

    const carousel = document.getElementById('comp-carousel-' + sectionId);
    const dots = section.querySelectorAll('.comp-dot-' + sectionId);
    const cards = section.querySelectorAll('.comp-card-' + sectionId);

    // Animation au scroll (Intersection Observer)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Animer les cartes
          cards.forEach(card => card.classList.add('is-visible'));
          
          // Animer les barres de progression
          setTimeout(() => {
            const fills = section.querySelectorAll('.comp-durability__fill-' + sectionId);
            fills.forEach(fill => {
              fill.style.width = fill.dataset.width + '%';
            });
          }, 600);
          
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    observer.observe(section);

    // Carrousel mobile
    if (carousel && dots.length) {
      carousel.addEventListener('scroll', () => {
        const card = carousel.querySelector('.comp-card-' + sectionId);
        if (!card) return;
        const cardWidth = card.offsetWidth + 16;
        const index = Math.round(carousel.scrollLeft / cardWidth);
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const card = carousel.querySelector('.comp-card-' + sectionId);
          if (!card) return;
          const cardWidth = card.offsetWidth + 16;
          carousel.scrollTo({ left: i * cardWidth, behavior: 'smooth' });
        });
      });
    }
  })();
</script>

