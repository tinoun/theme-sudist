{% if section.index <= 2 %}
  {{ 'images-with-text-carousel.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'images-with-text-carousel.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-solid">
  {% if section.blocks.size > 0 %}
    <clipped-image class="d-block images-with-text-carousel--main" data-items-count="{{ section.blocks.size }}" data-section="{{ section.id }}">
      <div class="images-with-text-carousel--wrapper" data-clipped-items>
        {% for block in section.blocks %}
          <div
            class="images-with-text-carousel--item scheme-{{ block.settings.color_scheme }} {% unless forloop.index == 1 %} clipped{% endunless %}"
            id="images-with-text-carousel--item-{{ block.id }}"
            {% unless forloop.index == 1 %}
            data-clipped-item{% endunless %}
            {{ block.shopify_attributes }}>
            <div class="images-with-text-carousel--item-inner height-100">
              <div class="images-with-text-carousel--item-right">
                <div class="images-with-text-carousel--image media-wrapper width-100 height-100">
                  <div class="media media-fixed">
                    {% if block.settings.image != blank %}
                      {%- render 'lazy-image'
                        , image: block.settings.image -%}
                    {% else %}
                      {% liquid
                        capture placeholderIndex
                          cycle image_placeholder: 1, 2
                        endcapture
                      %}
                      {{ 'hero-apparel-' | append: placeholderIndex | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>
                </div>
              </div>
              <div class="images-with-text-carousel--item-left container-fullwidth">
                <div class="images-with-text-carousel--item-content">
                  {% if block.settings.heading != blank or block.settings.description != blank %}
                    <variety-heading class="section--header">
                      <div class="section--header-inner">
                        {%- if block.settings.heading != blank -%}
                          {%- capture markersPrefix -%}
                        <span class="markers-text {{ block.settings.markers_font }} {{ block.settings.markers_text }}">
                      {%- endcapture -%}
                          {%- capture markersSuffix -%}
                        </span>
                      {%- endcapture -%}
                          <{{ block.settings.seo_heading }} class="section--heading heading-font {{ block.settings.heading_size }}" >
                            {{ block.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                            </{{ block.settings.seo_heading }}>
                          {%- endif -%}

                          {% if block.settings.description != blank %}
                            <p class="section--description {{ block.settings.description_size }}">
                              {{ block.settings.description | newline_to_br }}
                            </p>
                          {% endif %}
                        </div>
                      </variety-heading>
                    {% endif %}
                    {% if block.settings.btn_text != blank and block.settings.btn_link != blank %}
                        {% liquid
                          if block.settings.button_style == 'link'
                            assign button_class = 'text-underline'
                            assign show_as_link = true
                          else
                            assign button_class = 'button' | append: ' ' | append: block.settings.button_size | append: ' ' | append: settings.button_animation_style
                            assign show_as_link = false
                          endif
                        %}
                        <div class="section--btn">
                          <a href="{{ block.settings.btn_link }}" class="{{ button_class }} {{ block.settings.button_style }}-button">
                            {% render 'button-appearance'
                              , button_text: block.settings.btn_text
                              , icon: 'arrow-right'
                              , show_as_link: show_as_link %}
                          </a>
                        </div>
                      {% endif %}
                  </div>
                  {% if section.settings.marquee_text != blank %}
                    <div class="images-with-text-carousel--marquee">
                      <div class="images-with-text-carousel--marquee-content {{ section.settings.marquee_direction | default: 'rtl' }}-direction">
                        {% for i in (1..5) %}
                          <div
                            class="images-with-text-carousel--marquee-item"
                            id="images-with-text-carousel--marquee-item-{{ forloop.index }}"
                            data-index="{{ forloop.index }}">
                            <div class="images-with-text-carousel--marquee-node">
                              {%- capture marqueeMarkersPrefix -%}
                          <span class="markers-text {{ section.settings.marquee_markers_font }} {{ section.settings.marquee_markers_text }}">
                        {%- endcapture -%}
                              {%- capture marqueeMarkersSuffix -%}
                          </span>
                        {%- endcapture -%}
                              <p class="marquee-text ">{{ section.settings.marquee_text | replace: "[", marqueeMarkersPrefix | replace: "]", marqueeMarkersSuffix | replace: "++", "<br>" }}</p>
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}

                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </clipped-image>
    {% endif %}
  </div>
  <style>
    #shopify-section-{{ section.id }} .images-with-text-carousel--marquee-content {
      --marque_text_size: {{ section.settings.desktop_font_size }}px;
      --marquee_speed: {{ section.settings.marquee_speed_desktop }}s;
      --marquee_gap: {{ section.settings.sapce_between }}px;
    }
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} .images-with-text-carousel--marquee-content {
        --marque_text_size: {{ section.settings.mobile_font_size }}px !important;
        --marquee_speed: {{ section.settings.marquee_speed_mobile }}s !important;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
  </style>

