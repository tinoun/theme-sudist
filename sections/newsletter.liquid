{% if section.index <= 2 %}
	{{ 'newsletter.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'newsletter.css' | asset_url | stylesheet_tag }}
{% liquid
	assign image_size = section.settings.image_ratio
	if image_size == 'landscape'
		assign imageRatio = '70%'
	elsif image_size == 'square'
		assign imageRatio = '100%'
	elsif image_size == 'portrait'
		assign imageRatio = '130%'
	else
		if section.settings.image != blank
		assign imageRatio = 1 | divided_by: section.settings.image.aspect_ratio | times: 100 | minus: 1 | append: '%'
		else
		assign imageRatio = 50 | append: '%'
		endif
  endif	
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else 
    assign containerClass = section.settings.section_container_width
  endif
%}
<div class="section-wrapper scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
	<div class="{{ containerClass }}">
		<div class="newsletter--wrapper">
			{%- if section.settings.image != blank -%}
				<div class="newsletter--image">
					<div class="media-wrapper media-overlay width-100 height-100">
						<div class="media media-fixed">
							{% render 'lazy-image', image: section.settings.image %}							
						</div>
					</div>
				</div>
			{%- endif -%}
			<div class="newsletter--content-box pos-relative text-{{ section.settings.alignment }} ">
				<div class="newsletter--content">
					<div class="newsletter--content-inner background-{{ section.settings.background_style }}">
						{% if section.settings.heading != blank or section.settings.description != blank %}
							<variety-heading class="pos-relative section--header text-{{ section.settings.alignment}}">
								<div class="section--header-inner">
									{%- if section.settings.heading != blank -%}
									{%- capture markersPrefix -%}
										<span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
									{%- endcapture -%}
									{%- capture markersSuffix -%}
										</span>
									{%- endcapture -%}
						
									<{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
										{{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
									</{{ section.settings.seo_heading }}>
									{%- endif -%}
						
									{% if section.settings.description != blank %}
									<p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
										{{ section.settings.description | newline_to_br }}
									</p>
									{% endif %}
								</div>
													
							</variety-heading>
						{% endif %}

						{%- form 'customer', class: 'newsletter-form pos-relative', id:'contact-form-{{ section.id }}' -%}
							<input type="hidden" name="contact[tags]" value="newsletter">
							<div class="newsletter--form" {% if settings.is_card_animation %} data-card-animate {% endif %}>
								<div class="form-group">
									<label class="hidden" for="Email-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
									<input
										id="Email-{{ section.id }}"
										type="email"
										name="contact[email]"
										class="form-control"
										value="{{ form.email }}"
										aria-required="true"
										autocorrect="off"
										autocapitalize="off"
										autocomplete="email"
										{% if form.errors %}
											autofocus
											aria-invalid="true"
											aria-describedby="Newsletter-error-{{ section.id }}"
										{% elsif form.posted_successfully? %}
											aria-describedby="Newsletter-success-{{ section.id }}"
										{% endif %}
										placeholder="{% if section.settings.placeholder != blank %}{{ section.settings.placeholder }}{% else %}{{ 'newsletter.label' | t }}{% endif %}"
										pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
										required>
								</div>
								{%- if form.errors -%}
									<div
									class="form--message error"
									id="Newsletter-error-{{ section.id }}"
									tabindex="-1">
									{{- form.errors.translated_fields.email | capitalize }}
									{{ form.errors.messages.email -}}
		  
									</div>
								{%- endif -%}
	
								{%- if form.posted_successfully? -%}
									<p
									class="form--message success"
									id="Newsletter-success-{{ section.id }}"
									tabindex="-1">{{ 'newsletter.success' | t }}</p>
								{%- endif -%}
								<button
									type="submit" name="commit" id="Subscribe-{{ section.id }}"
									class="button medium-button button-block {{ settings.button_animation_style }}"
									aria-label="Newsletter">               
									<span class="Newsletter--hover-btn">
									{% assign button_text = section.settings.button_text | default : 'Subscribe' %} 
									{% render 'button-appearance', button_text: button_text, icon: 'arrow-right' %}
									</span>
								</button>
							</div>
							
						{% endform %}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_desktop }}px;
    --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
		--image_overlay_opacity: {{ section.settings.overlay_opacity }};
		--content_alignment: {{ section.settings.content_alignment }};
  }

  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_mobile }}px;
      --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
    }
  }

  {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
