{% if section.index <= 2 %}
    {{ 'hero-banner.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="hero-banner--wrapper hero-active" data-hero-wrapper>
    {% if section.blocks.size > 1 %}<swiper-content data-resize="false">{% endif %}
    <div class="hero-banner--main-images{% if section.blocks.size > 1 %} swiper{% endif %}"
    {% if section.blocks.size > 1 %}
        data-swiper='
          {
            "autoplay": {
                "delay": 2000, 
                "disableOnInteraction": false
            },
            "effect": "fade",
            "speed": 1000
          }
        ' 
      {% endif %}
      data-section="{{ section.id }}"
    >
      <div class="hero-banner--wrapper{% if section.blocks.size > 1 %} is-slider swiper-wrapper{% endif %}">
        {% for block in section.blocks %}
        <div class="hero-banner--item{% if section.blocks.size > 1 %} swiper-slide{% endif %}" data-index="{{ forloop.index }}" {% if block.settings.running_text != blank %}data-running-content="{{ block.settings.running_text | truncate: 10, "" }}"{% endif %}>
                    <div class="media d-media-fixed m-media-fixed media-overlay">
                        {% if block.settings.image != blank %}
                            {% liquid
                                if block.settings.image != blank                          
                                    assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                                    assign sizes = '100vw'
                                    assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                    if section.index == 1
                                        assign fetch_priority = 'high'
                                    endif
                                    if forloop.first
                                        echo block.settings.image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                                    else
                                        echo block.settings.image | image_url: width: 3840 | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                                    endif
                                endif
                            %}
                        {% else %}
                            {%- capture current -%}{% cycle 1, 2 %}{%- endcapture -%}
                            {% assign placeholder_image = 'hero-apparel-' | append: current %}
                            {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }} 
                        {% endif %}
                    </div>
                </div>
        {% endfor %}

      </div>
    </div>
    {% if section.blocks.size > 1 %}</swiper-content>{% endif %}

    {% if section.settings.heading != blank %}
      <variety-heading>
        <div class="hero-banner--content">
          <div class="hero-banner--content-inner">

            {%- assign block_images = '' -%}
            {% assign is_running_text = false %}
            {%- for block in section.blocks -%}
                
              {%- if block.settings.image != blank -%}
                {%- assign imgurl =  block.settings.image | image_url : width: 200 | image_tag -%}
                {%- assign imgid =  'data-hero-item="' | append: forloop.index0 | append: '"' -%}
                {%- assign image_tag = '<span class="hero-inline--image cursor-pointer"'| append: imgid | append: '>' | append: imgurl | append: '</span>' -%}
                {%- assign block_images = block_images | append: image_tag | append: ',' -%}
              {% else %}
                {%- capture current -%}{% cycle 1, 2 %}{%- endcapture -%}
                {% assign placeholder_image = 'hero-apparel-' | append: current %}
                {% assign placeholdersvg =  placeholder_image | placeholder_svg_tag: 'placeholder-svg' %} 
                {%- assign imgid =  'data-hero-item="' | append: forloop.index0 | append: '"' -%}
                {%- assign image_tag = '<span class="hero-inline--image cursor-pointer"'| append: imgid | append: '>' | append: placeholdersvg | append: '</span>' -%}
                {%- assign block_images = block_images | append: image_tag | append: ',' -%}
              {%- endif -%}
                
            {%- endfor -%}

            {%- for block in section.blocks -%}
                {%- if block.settings.running_text != blank -%}
                    {% assign is_running_text = true %}
                    {%- break -%}  
                {%- endif -%}
            {%- endfor -%}

            {%- assign block_images_array = block_images | split: ',' -%}

            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}

            {%- assign heading_text = section.settings.heading -%}

            {%- for i in (1..block_images_array.size) -%}
              {%- assign img_placeholder = '[img' | append: i | append: ']' -%}
              {%- assign img_tag = block_images_array[forloop.index0] -%} 
              {%- assign heading_text = heading_text | replace: img_placeholder, img_tag -%}
            {%- endfor -%}
            
            {%- assign heading_text = heading_text | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" -%}
            {%- if is_running_text -%}
                {% assign running_text_wrapper = '<br><span class="hero-banner--running-text" data-running-text></span>' %}
                {%- assign heading_text = heading_text | append: ' ' | append: running_text_wrapper -%}
            {%- endif -%}
            
            {% if block_images_array.size > 0 %}<hero-context>{% endif %}
                <h4 class="hero-banner--title heading-font text-{{ section.settings.content_alignment }}">
                {{ heading_text }}
                </h4>
            {% if block_images_array.size > 0 %}</hero-context>{% endif %}
          </div>

        </div>
      </variety-heading>
    {% endif %}

  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_desktop }}px;
        --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    }
    #shopify-section-{{ section.id }} .media-overlay{
    --image_overlay_opacity: {{ section.settings.bg_image_opacity }};
  }
    @media only screen and (max-width: 767px) {
        #shopify-section-{{ section.id }}  {
            --top_spacing: {{ section.settings.top_space_mobile }}px !important;
            --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
        }
    }
    {% if section.settings.section_visibility == 'large' %}
        @media(max-width: 767px) {
            #shopify-section-{{ section.id }} {
                display: none !important;
            }
        }
    {% elsif section.settings.section_visibility == 'small' %}
        @media(min-width: 768px) {
            #shopify-section-{{ section.id }}  {
                display: none !important;
            }
        }
    {% endif %}

    @media(min-width: 768px) {
        #shopify-section-{{ section.id }}  {
            --media_height: {% if section.settings.desktop_height == '100vh' %}calc(100vh - var(--dynamic_announcement_height, 0px)){% else %}{{ section.settings.desktop_custom_height }}px{% endif %};
        }
    }

    @media(max-width: 767px) {
        #shopify-section-{{ section.id }}  {
            --media_height: {% if section.settings.mobile_height == '100vh' %}calc(100vh - var(--dynamic_announcement_height, 0px)){% else %}{{ section.settings.mobile_custom_height }}px{% endif %};
        }
    }


</style>

{% schema %}
{
    "name": "t:sections.hero-banner.name",
    "tag": "section",
    "class": "section-hero-banner",
    "disabled_on": {
        "groups": [
            "header",
            "footer",
            "custom.Overlay"
        ]
    },
    "settings": [
        {
            "type": "select",
            "id": "section_visibility",
            "label": "t:sections.all.section_visibility.label",
            "default": "always",
            "options": [
                {
                    "label": "t:sections.all.section_visibility.always.label",
                    "value": "always"
                },
                {
                    "label": "t:sections.all.section_visibility.small.label",
                    "value": "small"
                },
                {
                    "label": "t:sections.all.section_visibility.large.label",
                    "value": "large"
                }
            ]
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "default": "primary",
            "label": "t:sections.all.colors.label"
        },
        {
            "type": "select",
            "id": "section_background",
            "label": "t:sections.all.section_background.label",
            "default": "solid",
            "options": [
                {
                    "label": "t:sections.all.section_background.solid.label",
                    "value": "solid"
                },
                {
                    "label": "t:sections.all.section_background.gradient.label",
                    "value": "gradient"
                }
            ]
        },
        {
            "type": "header",
            "content": "t:settings_schema.global.settings.content.label"
        },
        {
            "type": "inline_richtext",
            "id": "heading",
            "label": "t:settings_schema.global.settings.heading.label",
            "default": "Show products [img1] feature a collection [img2] or include images with a brand message [img3].",
            "info": "t:settings_schema.global.settings.heading.info"
        },
        {
            "type": "paragraph",
            "content": "Use the format [imgX] to show where you want the image. Replace X with the number of the image. For example, [img1] will be swapped with the first slide's image."
        },
        {
            "type": "select",
            "id": "markers_font",
            "label": "t:sections.all.markers_font.label",
            "info": "t:sections.all.markers_font.info",
            "default": "heading-font",
            "options": [
                {
                    "label": "t:sections.all.markers_font.accent-font.label",
                    "value": "accent-font"
                },
                {
                    "label": "t:sections.all.markers_font.body-font.label",
                    "value": "body-font"
                },
                {
                    "label": "t:sections.all.markers_font.heading-font.label",
                    "value": "heading-font"
                }
            ]
        },
        {
            "type": "select",
            "id": "markers_text",
            "label": "t:sections.all.markers_text.label",
            "default": "outline--text",
            "options": [
                {
                    "label": "t:sections.all.markers_text.no-markers.label",
                    "value": "no-markers"
                },
                {
                    "label": "t:sections.all.markers_text.highlight-color.label",
                    "value": "highlight-color"
                },
                {
                    "label": "t:sections.all.markers_text.highlight-gradient.label",
                    "value": "highlight-gradient"
                },
                {
                    "label": "t:sections.all.markers_text.outline--text.label",
                    "value": "outline--text"
                },
                {
                    "label": "t:sections.all.markers_text.outline--filled.label",
                    "value": "outline--filled"
                },
                {
                    "label": "t:sections.all.markers_text.text-background-cover.label",
                    "value": "text-background-cover"
                }
            ]
        },
        {
            "type": "text_alignment",
            "id": "content_alignment",
            "label": "t:sections.all.heading_alignment.label",
            "default": "left"
        },
        {
            "type": "header",
            "content": "t:sections.all.headers.slides_height"
            },
            {
                "type": "paragraph",
                "content": "t:settings_schema.global.settings.desktop.label"
            },
            {
                "type": "select",
                "id": "desktop_height",
                "label": "t:sections.all.slide_heights.label",
                "default": "100vh",
                "options": [
                    {
                    "label": "t:sections.all.slide_heights.100vh.label",
                    "value": "100vh"
                    },
                    {
                    "label": "t:sections.all.slide_heights.custom.label",
                    "value": "custom"
                    }
                ]
            },
            {
                "type": "range",
                "id": "desktop_custom_height",
                "label": "t:sections.all.custom_height.label",
                "default": 750,
                "step": 10,
                "min": 500,
                "max": 1000,
                "unit": "px"
            },
            {
                "type": "paragraph",
                "content": "t:settings_schema.global.settings.mobile.label"
            },
            {
                "type": "select",
                "id": "mobile_height",
                "label": "t:sections.all.slide_heights.label",
                "default": "100vh",
                "options": [
                    {
                    "label": "t:sections.all.slide_heights.100vh.label",
                    "value": "100vh"
                    },
                    {
                    "label": "t:sections.all.slide_heights.custom.label",
                    "value": "custom"
                    }
                ]
            },
            {
                "type": "range",
                "id": "mobile_custom_height",
                "label": "t:sections.all.custom_height.label",
                "default": 800,
                "step": 10,
                "min": 300,
                "max": 800,
                "unit": "px"
            },
            {
            "type": "header",
            "content": "Background image"
            },
            {
            "type": "range",
            "id": "bg_image_opacity",
            "default": 0,
            "label": "t:sections.all.image_opacity.label",
            "min": 0,
            "max": 1,
            "step": 0.1
            },
        {
            "type": "header",
            "content": "t:sections.all.spacing.section_spacing_heading"
        },
        {
            "type": "range",
            "id": "top_space_desktop",
            "label": "t:sections.all.spacing.top_space_desktop",
            "default": 0,
            "min": 0,
            "max": 150,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_desktop",
            "label": "t:sections.all.spacing.bottom_space_desktop",
            "default": 0,
            "min": 0,
            "max": 150,
            "step": 5
        },
        {
            "type": "range",
            "id": "top_space_mobile",
            "label": "t:sections.all.spacing.top_space_mobile",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_mobile",
            "label": "t:sections.all.spacing.bottom_space_mobile",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 5
        }
    ],
    "blocks": [
        {
            "type": "slide",
            "name": "t:sections.hero-banner.blocks.slide.name",
            "settings": [
              {
                "type": "image_picker",
                "id": "image",
                "label": "t:sections.hero-banner.blocks.slide.settings.image.label"
              },
              {
                "type": "text",
                "id": "running_text",
                "label": "t:sections.hero-banner.blocks.slide.settings.text.label",
                "info": "t:sections.hero-banner.blocks.slide.settings.text.info"
              }
            ]
        }
    ],
    "presets": [
    {
        "name": "t:sections.hero-banner.presets.name",
        "blocks": [
            {
                "type": "slide"
            },
            {
                "type": "slide"
            },
            {
                "type": "slide"
            }
        ]
    }
    ]
}
{% endschema %}
