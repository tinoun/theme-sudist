{% if section.index <= 2 %}
  {{ 'collapsible.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'collapsible.css' | asset_url | stylesheet_tag }}
{% liquid
 
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif
  
%}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ containerClass }}">
    <div class="collapsible-content--wrapper layout-{{ section.settings.layout_style }}">
      <div class="collapsible-content--info">
        {% if section.settings.heading != blank or section.settings.description != blank %}
         
          <variety-heading class="section--header{% if section.settings.layout_style == 'vertical' %} text-{{ section.settings.content_alignment }}{% else %} text-left{% endif %}">
            <div class="section--header-inner" >
              {% if section.settings.heading != blank %}
                {%- capture markersPrefix -%}
                  <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                {%- endcapture -%}
                {%- capture markersSuffix -%}
                  </span>
                {%- endcapture -%}
                <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                  {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                </{{ section.settings.seo_heading }}>
              {% endif %}
              {% if section.settings.description != blank %}
                <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                  {{ section.settings.description | newline_to_br }}
                </p>
              {% endif %}
              </div>
            </variety-heading>
          {% endif %}
          {% if section.settings.button_text != blank and section.settings.button_link != blank %}
            {% liquid
              if section.settings.button_style == 'link'
                assign show_as_link = true 
                assign button_class = 'text-underline'
              else
                assign button_class = 'button' | append: ' ' | append: section.settings.button_size | append: ' ' | append: settings.button_animation_style
                assign show_as_link = false
              endif
            %}
            <div class="section--btn{% if section.settings.layout_style == 'vertical' %} text-{{ section.settings.content_alignment }}{% endif %}">
              <a href="{{ section.settings.button_link }}" aria-label="{{ section.settings.button_text }}" class="{{ button_class }} {{ section.settings.button_style }}-button">
                {% render 'button-appearance'
                  , button_text: section.settings.button_text
                  , icon: 'arrow-right' show_as_link: show_as_link
                %}
              </a>
            </div>
          {% endif %}
        </div>
        {% if section.blocks.size > 0 %}
          <collapsible-contents class="collapsible-content--list">
            {%- for block in section.blocks -%}
              {% if block.settings.collapsible_content_heading != blank %}
                <details
                  class="collapsible-content--block collapsible-style-{{ section.settings.collapse_style }}{% if section.settings.collapse_style == 'card' %} border border-width-1{% endif %}"
                  data-collapsible-heading
                  is="accordion-details"
                  {% if forloop.first %}
                    open
                  {% endif %}
                  >
                  <summary class="collapsible--heading" data-collapsible-summary>
                    <h6 class="collapsible--text heading-font h6">
                      {{ block.settings.collapsible_content_heading }}
                    </h6>
                    <span class="collapsible--icon">
                      {% render 'icons'
                        , icon: 'plus-icon' %}
                    </span>
                  </summary>
                  <div class="collapsible--content" data-collapsible-content>
                    <div class="collapsible--content-body rte">
                      {{ block.settings.collapsible_content_description }}
                    </div>
                  </div>
                </details>
              {% endif %}
            {%- endfor -%}
          </collapsible-contents>
        {% endif %}
      </div>
    </div>
  </div>
  <style>
    #shopify-section-{{ section.id }} .section-spacing {
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;

    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .section-spacing {
        --top_spacing: {{ section.settings.top_space_mobile }}px;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
  </style>
  {%- schema -%}
