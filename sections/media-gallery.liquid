{% if section.index <= 2 %}
  {{ 'media-gallery.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'media-gallery.css' | asset_url | stylesheet_tag }}
{% liquid
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif
%}
<div class="section-wrapper {{ section.settings.radius_selector }} {{ section.settings.mobile_radius_selector }} section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <variety-heading class="section--header text-{{ section.settings.content_alignment }}">
        <div class="section--header-inner">
          {% if section.settings.heading != blank %}
            {%- capture markersPrefix -%}
              <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
            {%- endcapture -%}
            {%- capture markersSuffix -%}
              </span>
            {%- endcapture -%}
            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
              {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
              </{{ section.settings.seo_heading }}>
            {% endif %}

            {% if section.settings.description != blank %}
              <p class="section--description  {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                {{ section.settings.description | newline_to_br }}
              </p>
            {% endif %}
          </div>
        </variety-heading>
      {% endif %}
    </div>

    <div class="{{ containerClass }}{% if section.settings.mobile_swipe %} m-pr-0{% endif %}">
      <div class="media-gallery--wrapper {{ section.settings.hover_style }} {{ section.settings.media_style }}-style {% if section.settings.mobile_swipe == true %}mobile-swipe{% endif %} media-gallery-text-visibility-{{ section.settings.media_text_visibility }}" data-media-gallery data-delay-duration="{{ section.settings.delay_duration }}" data-disappear-duration="{{ section.settings.disappear_duration }}">
        {% for block in section.blocks %}
          <div class="media-gallery--item animate-hover" data-media-item {% if settings.is_card_animation %} data-card-animate {% endif %}>
            <div class="media-gallery--item-inner">
              <div class="media-gallery--image media-wrapper width-100">
                {% liquid
                  capture current
                    cycle section.id: 1, 2, 3, 4
                  endcapture
                  assign image_size = section.settings.image_ratio
                  if image_size == 'landscape'
                    assign imageRatio = '70%'
                  elsif image_size == 'square'
                    assign imageRatio = '100%'
                  elsif image_size == 'portrait'
                    assign imageRatio = '150%'
                  else
                    if block.settings.gallery_img != blank
                      assign imageRatio = 1 | divided_by: block.settings.gallery_img.aspect_ratio | times: 100 | minus: 1 | append: '%'
                    else
                      assign imageRatio = 120 | append: '%'
                    endif
                  endif
                %}
                <div class="media" style="--image_ratio:{{ imageRatio }};">
                  {% if block.settings.video != blank %}
                    {{ block.settings.video | video_tag: image_size: '1100x', class: 'media-gallery--video', autoplay: true, loop: true, mute: true, controls: false, preload: 'none' }}
                  {% elsif block.settings.gallery_img != blank %}
                    {{ block.settings.gallery_img | image_url: width: null | image_tag }}
                  {% else %}
                    {{ 'product-apparel-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                {% if block.settings.video != blank or block.settings.gallery_img != blank %}
                  {% if block.settings.product != blank %}
                    {% render 'product-layout', product:  block.settings.product, image_ratio: '100%' %}
                  {% endif %}
                {% endif %}
                {% if block.settings.video != blank %}
                  <custom-controls class="media-gallery--video-controls">
                    <span class="media-gallery--icon-play cursor-pointer hidden" data-video-play>
                      {% render 'icons', icon: 'custom-play' %}
                    </span>
                    <span class="media-gallery--icon-pause cursor-pointer" data-video-pause>
                      {% render 'icons', icon: 'pause' %}
                    </span>
                  </custom-controls>
                {% endif %}
                {% if block.settings.video != blank or block.settings.gallery_img != blank %}
                  {% if block.settings.text != blank %}
                    <div class="media-gallery--text heading-font {{ block.settings.text_size }}">{{ block.settings.text }}</div>
                  {% endif %}
                {% endif %} 
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_desktop }}px;
    --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    --column_gap: {{ section.settings.media_columns_gap }}px;
    --animating_border_color: {{ section.settings.animated_border_color }};
    {% if section.settings.section_corner_radius == 'custom' %}
      --corner_radius: {{ section.settings.custom_section_corner_radius }}px;
    {% else %}
      --corner_radius: {{ settings.card_radius }}px;
    {% endif %}
  }
  #shopify-section-{{ section.id }} .media-gallery--item{
    --card_radius: {{ settings.card_radius }}px;
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_mobile }}px;
      --bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
  @media(min-width: 768px) {
    #shopify-section-{{ section.id }} {
      display: none !important;
    }
  }
{% endif %}
</style>
