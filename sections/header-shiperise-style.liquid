{{ 'header.css' | asset_url | preload_tag: as: 'style' }}
{{ 'header.css' | asset_url | stylesheet_tag }}

{% liquid
  assign isHeaderTransparentHomepage = false
  assign isHeaderTransparentOtherPage = false
  assign isHeaderTransparent = ''
  assign isTransparentBlur = false
  assign transparent_spacing_zero = false

  assign otherTemplates = section.settings.transparent_other_page | split: ','
 
  if template == 'index' and section.settings.transparent_home_page
    assign isHeaderTransparentHomepage = true
  endif

  if section.settings.transparent_other_page contains request.page_type  
    assign isHeaderTransparentOtherPage = true
  endif

  if isHeaderTransparentOtherPage or isHeaderTransparentHomepage
    assign isTransparentBlur = true
    assign transparent_spacing_zero = true
    assign isHeaderTransparent = section.settings.transparent_header
    if isHeaderTransparent == 'both-transparent' 
      assign isHeaderTransparent = 'desktop-transparent mobile-transparent'
    endif
  endif
%}

<div class="{{ section.settings.section_container_width }}">
  <{% if section.settings.sticky_header_type == 'sticky-scroll-up' %}sticky-on-scroll{% elsif section.settings.sticky_header_type == 'sticky-always' %}sticky-always{% else %}div{% endif %}
    class="header style-shiperise-centered header-height-{{ section.settings.header_height }} {{ section.settings.sticky_header_type }}{% if section.settings.seaperate_line %} border-enabled{% endif %}{% if section.settings.header_shadow %} shadow-enabled{% endif %}{% if isHeaderTransparent != blank %} {{ isHeaderTransparent }}{% endif %}{% if isTransparentBlur and section.settings.is_transparent_blur %} has-transparent-blur{% endif %}"
    id="{{ section.id }}"
    data-logo="{{ section.settings.hide_logo }}"
    data-header-view="shiperise-centered"
    data-header-sticky-type="{{ section.settings.sticky_header_type }}"
    data-top-spacing-desktop="{{ section.settings.top_space_desktop }}" 
    data-bottom-spacing-desktop="{{ section.settings.bottom_space_desktop }}" 
    data-top-spacing-mobile="{{ section.settings.top_space_mobile }}" 
    data-bottom-spacing-mobile="{{ section.settings.bottom_space_mobile }}"
    data-header-section
  >
    <div class="{% if section.settings.section_container_width == 'no-container' %}container-fullwidth{% else %}custom-container{% endif %}">
      
      {%- comment -%} SHIPERISE STYLE: Navigation divisée avec logo au centre {%- endcomment -%}
      <div class="header--wrapper shiperise-centered" data-header-navigation data-header-wrapper>
        
        {%- comment -%} Mobile menu toggler {%- endcomment -%}
        {% if section.settings.menu != blank %}
          <button
            class="mobile-toggler hamburger--toggler"
            aria-label="Toggle mobile menu"
            data-mobile-toggler>
            <div class="hamburger--toggler-icon">
              <span class="line line-1"></span>
              <span class="line line-2"></span>
              <span class="line line-3"></span>
            </div>
          </button>
        {% endif %}

        {%- comment -%} Navigation gauche (première moitié des liens) {%- endcomment -%}
        <nav class="header--nav-left" aria-label="Main navigation left">
          {% if section.settings.menu != blank %}
            {% assign menu_links = section.settings.menu.links %}
            {% assign total_links = menu_links.size %}
            {% assign half_links = total_links | divided_by: 2 %}
            
            <ul class="header--menu-list">
              {% for link in menu_links limit: half_links %}
                <li class="header--menu-item{% if link.active %} is-active{% endif %}">
                  <a 
                    class="header--menu-link" 
                    href="{{ link.url }}"
                    {% if link.current %} aria-current="page"{% endif %}
                  >
                    {{ link.title }}
                  </a>
                  
                  {%- comment -%} Dropdown pour sous-menus {%- endcomment -%}
                  {% if link.links != blank %}
                    <div class="header--dropdown">
                      <ul class="header--dropdown-list">
                        {% for childlink in link.links %}
                          <li class="header--dropdown-item">
                            <a class="header--dropdown-link" href="{{ childlink.url }}">
                              {{ childlink.title }}
                            </a>
                            
                            {% if childlink.links != blank %}
                              <ul class="header--dropdown-sublist">
                                {% for grandchildlink in childlink.links %}
                                  <li class="header--dropdown-subitem">
                                    <a class="header--dropdown-sublink" href="{{ grandchildlink.url }}">
                                      {{ grandchildlink.title }}
                                    </a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </nav>

        {%- comment -%} Logo centré {%- endcomment -%}
        <a class="header--logo header--logo-centered" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            {%- assign image_2x_size = section.settings.desktop_logo_width | times: 2 | at_most: 2560 -%}
            <img
              class="header--logo-img"
              srcset="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }} 1x, {{ section.settings.logo | image_url: width: image_2x_size }} 2x"
              src="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }}"
              width="{{ section.settings.desktop_logo_width }}"
              height="{{ section.settings.desktop_logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
              alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
              loading="eager"
            >
            
            {% if isHeaderTransparent != blank %}
              {% liquid
                if section.settings.alternate_logo != blank
                  assign transparent_image = section.settings.alternate_logo
                else
                  assign transparent_image = section.settings.logo
                endif
              %}
              {%- assign image_2x_size = section.settings.desktop_logo_width | times: 2 | at_most: 2560 -%}
              <link rel="preload" as="image" href="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }}" />
              <img
                class="header--logo-img transparent-logo-img"
                srcset="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }} 1x, {{ transparent_image | image_url: width: image_2x_size }} 2x"
                src="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }}"
                width="{{ section.settings.desktop_logo_width }}"
                height="{{ section.settings.desktop_logo_width | divided_by: transparent_image.aspect_ratio | round }}"
                alt="{{ transparent_image.alt | default: shop.name | escape }}"
                loading="eager"
              >
            {% endif %}
          {% else %}
            <span class="header--logo-text text-medium">{{ shop.name }}</span>
          {% endif %}
        </a>

        {%- comment -%} Navigation droite (deuxième moitié des liens) {%- endcomment -%}
        <nav class="header--nav-right" aria-label="Main navigation right">
          {% if section.settings.menu != blank %}
            <ul class="header--menu-list">
              {% for link in menu_links offset: half_links %}
                <li class="header--menu-item{% if link.active %} is-active{% endif %}">
                  <a 
                    class="header--menu-link" 
                    href="{{ link.url }}"
                    {% if link.current %} aria-current="page"{% endif %}
                  >
                    {{ link.title }}
                  </a>
                  
                  {%- comment -%} Dropdown pour sous-menus {%- endcomment -%}
                  {% if link.links != blank %}
                    <div class="header--dropdown">
                      <ul class="header--dropdown-list">
                        {% for childlink in link.links %}
                          <li class="header--dropdown-item">
                            <a class="header--dropdown-link" href="{{ childlink.url }}">
                              {{ childlink.title }}
                            </a>
                            
                            {% if childlink.links != blank %}
                              <ul class="header--dropdown-sublist">
                                {% for grandchildlink in childlink.links %}
                                  <li class="header--dropdown-subitem">
                                    <a class="header--dropdown-sublink" href="{{ grandchildlink.url }}">
                                      {{ grandchildlink.title }}
                                    </a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </nav>

        {%- comment -%} Icônes header (recherche, compte, panier) - optionnel sur mobile {%- endcomment -%}
        <div class="header--icons-mobile">
          {% render 'header-icons', section: section %}
        </div>
      </div>
      
      {%- comment -%} No-JS fallback menu {%- endcomment -%}
      <noscript>
        <nav class="no-js-menu">
          <ul>
            {% for link in section.settings.menu.links %}
              <li>
                <a class="header--menu-link" href="{{ link.url }}">{{ link.title }}</a>
              </li>
              {% if link.links != blank %}
                {% for childlink in link.links %}
                  <li class="child-link">
                    <a class="header--menu-link" href="{{ childlink.url }}">{{ childlink.title }}</a>
                  </li>
                  {% if childlink.links != blank %}
                    {% for grandchildlink in childlink.links %}
                      <li class="grandchild-link">
                        <a class="header--menu-link" href="{{ grandchildlink.url }}">{{ grandchildlink.title }}</a>
                      </li>
                    {% endfor %}
                  {% endif %}
                {% endfor %}
              {% endif %}
            {% endfor %}
          </ul>
        </nav>
      </noscript>
    </div>
  </{% if section.settings.sticky_header_type == 'sticky-scroll-up' %}sticky-on-scroll{% elsif section.settings.sticky_header_type == 'sticky-always' %}sticky-always{% else %}div{% endif %}>
</div>

{% liquid
  if request.page_type != 'cart' and settings.cart_behaviour == 'drawer'
    render 'cart-drawer'
  endif
  render 'search-drawer'

  assign isAccountDrawer = true
  if request.page_type contains 'customers'
    assign isAccountDrawer = false
  endif
  if customer and settings.account_behaviour == 'drawer'
    assign isAccountDrawer = false
  endif
  if isAccountDrawer
    render 'account-drawer'
  endif

  render 'mobile-menu-drawer', section: section
%}

<style>
  /* =====================================================
     SHIPERISE STYLE HEADER - CENTERED TRANSPARENT
     ===================================================== */
  
  .section-header {
    --logo_width: {{ section.settings.desktop_logo_width }}px;
    --transparent_color: {{ section.settings.transparent_color }};
    --transparent_opacity: {{ section.settings.overlay_opacity }};
    --transparent_border_color: {{ section.settings.transparent_border_color.red }}, {{ section.settings.transparent_border_color.green }}, {{ section.settings.transparent_border_color.blue }};
    --transparent_background: {{ section.settings.overlay_background.red }}, {{ section.settings.overlay_background.green }}, {{ section.settings.overlay_background.blue }};
    
    {% if transparent_spacing_zero and section.settings.transparent_header == 'desktop-transparent' or section.settings.transparent_header == 'both-transparent' %}
      --header_top_spacing: 0px;
      --header_bottom_spacing: 0px;
    {% else %}
      --header_top_spacing: {{ section.settings.top_space_desktop }}px;
      --header_bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    {% endif %}

    {% unless section.settings.section_container_width == 'no-container' %}
      --header_radius: {{ section.settings.corner_radius }}px;  
    {% endunless %}
  }

  /* Base header styles */
  .header.style-shiperise-centered {
    position: relative;
    width: 100%;
    z-index: 1000;
    padding: var(--header_top_spacing, 20px) 0 var(--header_bottom_spacing, 20px);
    transition: all 0.3s ease;
  }

  /* Transparent header states */
  .header.style-shiperise-centered.desktop-transparent,
  .header.style-shiperise-centered.mobile-transparent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
  }

  .header.style-shiperise-centered.desktop-transparent:not(.is-scrolled) .header--menu-link,
  .header.style-shiperise-centered.desktop-transparent:not(.is-scrolled) .header--logo-text {
    color: var(--transparent_color, #fff);
  }

  .header.style-shiperise-centered.has-transparent-blur {
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    background: rgba(var(--transparent_background), var(--transparent_opacity, 0));
  }

  /* Main wrapper - Shiperise centered layout */
  .header--wrapper.shiperise-centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 40px;
    padding: 0 20px;
  }

  /* Navigation sections */
  .header--nav-left,
  .header--nav-right {
    display: flex;
  }

  .header--nav-left {
    justify-content: flex-end;
  }

  .header--nav-right {
    justify-content: flex-start;
  }

  /* Menu list */
  .header--menu-list {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Menu items */
  .header--menu-item {
    position: relative;
  }

  /* Menu links - Shiperise style */
  .header--menu-link {
    display: inline-block;
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.main_menu_font_size | default: '14' }}px;
    font-weight: {{ section.settings.menu_font_style | default: '500' }};
    text-transform: none;
    letter-spacing: 0;
    color: inherit;
    text-decoration: none;
    padding: 8px 0;
    position: relative;
    transition: opacity 0.2s ease;
  }

  .header--menu-link:hover {
    opacity: 0.7;
  }

  /* Active state underline */
  .header--menu-item.is-active .header--menu-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
  }

  /* Centered logo */
  .header--logo.header--logo-centered {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header--logo-img {
    max-width: var(--logo_width, 120px);
    height: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  /* Transparent logo switching */
  .header.style-shiperise-centered .transparent-logo-img {
    display: none;
  }

  .header.style-shiperise-centered.desktop-transparent:not(.is-scrolled) .header--logo-img:not(.transparent-logo-img) {
    display: none;
  }

  .header.style-shiperise-centered.desktop-transparent:not(.is-scrolled) .transparent-logo-img {
    display: block;
  }

  .header--logo-text {
    font-family: var(--font-heading-family, inherit);
    font-size: 24px;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
  }

  /* Dropdown menus */
  .header--dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: var(--color-background, #fff);
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.25s ease;
    padding: 12px 0;
    margin-top: 8px;
  }

  .header--menu-item:hover .header--dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .header--dropdown-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header--dropdown-item {
    position: relative;
  }

  .header--dropdown-link {
    display: block;
    padding: 10px 20px;
    font-size: 14px;
    color: var(--color-foreground, #000);
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .header--dropdown-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  /* Mobile icons container */
  .header--icons-mobile {
    display: none;
  }

  /* Mobile toggler */
  .mobile-toggler {
    display: none;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
  }

  .hamburger--toggler-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;
  }

  .hamburger--toggler-icon .line {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: all 0.3s ease;
  }

  /* Border and shadow options */
  .header.style-shiperise-centered.border-enabled {
    border-bottom: 1px solid rgba(var(--transparent_border_color, 0, 0, 0), 0.1);
  }

  .header.style-shiperise-centered.shadow-enabled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
  }

  /* Height variations */
  .header.style-shiperise-centered.header-height-small .header--wrapper {
    min-height: 60px;
  }

  .header.style-shiperise-centered.header-height-medium .header--wrapper {
    min-height: 72px;
  }

  .header.style-shiperise-centered.header-height-large .header--wrapper {
    min-height: 88px;
  }

  /* No-JS fallback */
  .no-js-menu {
    display: none;
  }

  noscript .no-js-menu {
    display: block;
    text-align: center;
    padding: 20px;
  }

  noscript .no-js-menu ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* =====================================================
     RESPONSIVE - TABLET & MOBILE
     ===================================================== */
  
  @media (max-width: 1024px) {
    .header--wrapper.shiperise-centered {
      gap: 24px;
    }

    .header--menu-list {
      gap: 20px;
    }

    .header--menu-link {
      font-size: 13px;
    }
  }

  @media (max-width: 767px) {
    .section-header {
      --logo_width: {{ section.settings.mobile_logo_width }}px;
      
      {% if transparent_spacing_zero and section.settings.transparent_header == 'mobile-transparent' or section.settings.transparent_header == 'both-transparent' %}
        --header_top_spacing: 0px;
        --header_bottom_spacing: 0px;
      {% else %}
        --header_top_spacing: {{ section.settings.top_space_mobile }}px;
        --header_bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
      {% endif %}

      {% unless section.settings.section_container_width == 'no-container' %}
        {% if section.settings.corner_radius > 20 %}
          --header_radius: {{ section.settings.corner_radius | divided_by: 2 }}px;  
        {% else %}
          --header_radius: {{ section.settings.corner_radius }}px;  
        {% endif %}
      {% endunless %}
    }

    .header--wrapper.shiperise-centered {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 16px;
    }

    .header--nav-left,
    .header--nav-right {
      display: none;
    }

    .mobile-toggler {
      display: flex;
      order: 1;
    }

    .header--logo.header--logo-centered {
      order: 2;
      flex: 1;
      justify-content: center;
    }

    .header--icons-mobile {
      display: flex;
      order: 3;
    }

    /* Transparent mobile */
    .header.style-shiperise-centered.mobile-transparent:not(.is-scrolled) .header--menu-link,
    .header.style-shiperise-centered.mobile-transparent:not(.is-scrolled) .header--logo-text,
    .header.style-shiperise-centered.mobile-transparent:not(.is-scrolled) .mobile-toggler {
      color: var(--transparent_color, #fff);
    }

    .header.style-shiperise-centered.mobile-transparent:not(.is-scrolled) .header--logo-img:not(.transparent-logo-img) {
      display: none;
    }

    .header.style-shiperise-centered.mobile-transparent:not(.is-scrolled) .transparent-logo-img {
      display: block;
    }
  }
</style>

<script src="{{ 'header.js' | asset_url }}" defer></script>

{% unless settings.seo_microdata %} 
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      {% if section.settings.logo %}
        "logo": {{ section.settings.logo | image_url: width: 500 | prepend: "https:" | json }},
      {% endif %}
      "sameAs": [
        {{ settings.social_twitter_link | json }},
        {{ settings.social_facebook_link | json }},
        {{ settings.social_pinterest_link | json }},
        {{ settings.social_instagram_link | json }},
        {{ settings.social_tiktok_link | json }},
        {{ settings.social_tumblr_link | json }},
        {{ settings.social_snapchat_link | json }},
        {{ settings.social_youtube_link | json }},
        {{ settings.social_vimeo_link | json }}
      ],
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>

  {%- if request.page_type == 'index' -%}
    {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ potential_action_target | json }},
          "query-input": "required name=search_term_string"
        },
        "url": {{ request.origin | append: page.url | json }}
      }
    </script>
  {%- endif -%}
{% endunless %}

{% schema %}
{
  "name": "Header Shiperise Style",
  "class": "section-header section-spacing",
  "tag": "header",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_container_width",
      "label": "Container width",
      "default": "no-container",
      "options": [
        { "label": "Small", "value": "container-sm" },
        { "label": "Default", "value": "container" },
        { "label": "Medium", "value": "container-md" },
        { "label": "Full width", "value": "container-fullwidth" },
        { "label": "Narrow", "value": "container-narrow" },
        { "label": "No container", "value": "no-container" }
      ]
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "default": 0,
      "min": 0,
      "max": 40,
      "unit": "px",
      "step": 1
    },
    {
      "type": "select",
      "id": "header_height",
      "default": "medium",
      "label": "Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "label": "Sticky behavior",
      "default": "sticky-scroll-up",
      "options": [
        { "label": "None", "value": "sticky-none" },
        { "label": "On scroll up", "value": "sticky-scroll-up" },
        { "label": "Always", "value": "sticky-always" }
      ]
    },
    {
      "type": "checkbox",
      "id": "seaperate_line",
      "default": false,
      "label": "Show border"
    },
    {
      "type": "checkbox",
      "id": "header_shadow",
      "default": false,
      "label": "Show shadow"
    },
    {
      "type": "checkbox",
      "id": "hide_logo",
      "default": false,
      "label": "Hide logo on scroll"
    },
    {
      "type": "header",
      "content": "Transparent header"
    },
    {
      "type": "checkbox",
      "id": "transparent_home_page",
      "label": "Enable on homepage",
      "default": true
    },
    {
      "type": "textarea",
      "id": "transparent_other_page",
      "label": "Enable on other pages",
      "placeholder": "article, blog, collection, product, page",
      "info": "Enter page types separated by commas"
    },
    {
      "type": "select",
      "id": "transparent_header",
      "label": "Transparent on",
      "default": "both-transparent",
      "options": [
        { "label": "Desktop only", "value": "desktop-transparent" },
        { "label": "Mobile only", "value": "mobile-transparent" },
        { "label": "Both", "value": "both-transparent" }
      ]
    },
