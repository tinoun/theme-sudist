{% if section.index <= 2 %}
  {{ 'collection-list.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'collection-list.css' | asset_url | stylesheet_tag }}
{% liquid
  if section.settings.collection_style == 'carousel'
    assign is_slider = true
  else
    assign is_slider = false
  endif
  
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif
  
%}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
   

    {% if section.settings.heading != blank or section.settings.description != blank or is_slider %}
      <div class="{{ settings.container_width }}"> 
        <variety-heading class="section--header{% if is_slider %} with--arrow{% endif %} text-{{ section.settings.heading_alignment}}">
          <div class="section--header-inner">
            {%- if section.settings.heading != blank -%}
              {%- capture markersPrefix -%}
                <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
              {%- endcapture -%}
              {%- capture markersSuffix -%}
                </span>
              {%- endcapture -%}
              <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
              </{{ section.settings.seo_heading }}>
            {%- endif -%}
            {% if section.settings.description != blank %}
              <p class="section--description {{ section.settings.description_size }}" {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                {{ section.settings.description | newline_to_br }}
              </p>
            {% endif %}
          </div>
          {% if is_slider %}
            <div class="swiper--custom-buttons d-none d-md-flex">
              {% liquid 
                if settings.slilder_button_style == 'square'
                  assign btnIcon = 'curve-arrow'
                else
                  assign btnIcon = 'arrow-icon'
                endif
              %}
              <swiper-nav class="swiper-button-prev swiper-button-prev-{{ section.id }} swiper-button button-{{ settings.slilder_button_style }}">
                {% render 'icons', icon: btnIcon %}
              </swiper-nav>
              <swiper-nav class="swiper-button-next swiper-button-next-{{ section.id }} swiper-button button-{{ settings.slilder_button_style }}">
                {% render 'icons', icon: btnIcon %}
              </swiper-nav>
            </div>
          {% endif %}        
        </variety-heading>
      </div>
    {% endif %}

    <div class="{{ containerClass }}"> 
      {% if is_slider or section.blocks.size > 1 %}
        <swiper-content data-resize="true">
        <div class="collection-list--outer{% if is_slider or section.blocks.size > 1%} swiper{% endif %}"
          {% if is_slider or section.blocks.size > 1 %}
            data-swiper='
              {
                {% if section.blocks.size > 4 %}
                  "loop": true,
                {% endif %}
                  "slidesPerView": 1.2,
                  "speed": 900,
                  "centeredSlides": false,
                  "freeMode": {
                    "enabled": true,
                    "momentum": true,
                    "momentumRatio": 2,
                    "momentumBounceRatio": 0,
                    "sticky": false
                  },
                  "scrollbar": {
                      "el": ".swiper-scrollbar-{{ section.id }}",
                      "draggable": true
                  },
                  "navigation": {
                    "nextEl": ".swiper-button-next-{{ section.id }}",
                    "prevEl": ".swiper-button-prev-{{ section.id }}"
                  },
                  "breakpoints": {
                      "768": {
                          "speed": 1000,
                          "slidesPerView": 2.5,
                          "freeMode": {
                            "enabled": true,
                            "momentum": true,
                            "momentumRatio": 3,
                            "momentumBounceRatio": 0,
                            "sticky": false
                          },
                          "grabCursor": false,
                          "scrollbar": false
                      },
                      "992": {
                          "slidesPerView": 3.5
                      },
                      "1025": {
                          "slidesPerView": {{ section.settings.column_count }}
                      }
                  }
              }
            ' 
          {% endif %}
        >
      {% endif %}
        <div
          class="collection-list--wrapper {% if is_slider or section.blocks.size > 1 %}is-slider swiper-wrapper {% endif %} {{ section.settings.collection_style }} {% if section.settings.mobile_swipe == true %}mobile-swipe{% endif %} {% if section.settings.enable_sezane_layout %}sezane-layout{% endif %} column-count-{{ section.settings.column_count }} border-{{ section.settings.border_style }}"
          data-view="{{ section.settings.collection_style }}" >
          {% liquid
            assign image_size = section.settings.image_ratio
            for block in section.blocks
              capture current
                cycle section.id: 1, 2, 3, 4
              endcapture
              assign placeholder_image = 'collection-apparel-' | append: current
              assign featuredCollection = block.settings.collection
              render 'collection-grid', collection: featuredCollection, image_size: image_size, section: section, block: block, is_slider: is_slider, placeholder_image: placeholder_image, index: forloop.index0
            else
              for i in (1..8)
                capture current
                  cycle section.id: 1, 2, 3, 4
                endcapture
                assign placeholder_image = 'collection-apparel-' | append: current
                assign featuredCollection = block.settings.collection
                render 'collection-grid', section: section, image_size: image_size, is_slider: is_slider, placeholder_image: placeholder_image, index: forloop.index0
              endfor
            endfor
          %}
        </div>
        <div class="swiper-scrollbar swiper-scrollbar-{{ section.id }} d-block d-md-none"></div>
      {% if is_slider or section.blocks.size > 1 %}
        </div>
        </swiper-content>
      {% endif %}
    </div>
</div>
<style>

  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_desktop }}px;
    --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    --image_overlay_opacity: {{ section.settings.overlay_opacity }};
    --column_gap: {{ section.settings.columns_gap }}px;
  }
  @media (min-width:768px) {
    #shopify-section-{{ section.id }}  {
      --column_count: {{ section.settings.column_count }}
    }
  }

  @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }}  {
        --top_spacing: {{ section.settings.top_space_mobile }}px !important;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
      }
  }
  {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
          #shopify-section-{{ section.id }} {
            display: none !important;
          }
      }
  {% elsif section.settings.section_visibility == 'small' %}
      @media(min-width: 768px) {
          #shopify-section-{{ section.id }}  {
            display: none !important;
          }
      }
  {% endif %}
</style>
