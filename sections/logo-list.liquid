{% if section.index <= 2 %}
  {{ 'logo-list.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'logo-list.css' | asset_url | stylesheet_tag }}
{%  liquid  
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else 
    assign containerClass = section.settings.section_container_width
  endif
%}
{% capture loopedContent %}
  {% for block in section.blocks %}
    {% capture logo %}
    <div class="logo-item--inner{% if section.settings.card_bg %} bg-enable{% endif %}" id="block-{{ block.id }}">
      {%- if block.settings.logo != blank -%}
        {% render 'lazy-image', image: block.settings.logo %}
      {%- else -%}
        <svg class="placeholder-svg" viewBox="0 0 158.3 158.3">
          <path d="M50.7 83.8H43v-17c0-.3-.3-.6-.6-.6h-2.8c-.3 0-.6.3-.6.6v20.1c0 .3.2.6.6.6h11.1c.3 0 .6-.3.6-.6v-2.5c-.1-.4-.3-.6-.6-.6zm12.7-17.9c-6.1 0-10.9 4.9-10.9 10.9 0 6.1 4.8 10.9 10.9 10.9 6.1 0 10.9-4.8 10.9-10.9 0-6-4.8-10.9-10.9-10.9zm0 17.9c-3.8 0-6.9-3.1-6.9-6.9 0-3.8 3.1-7 6.9-7s7 3.2 7 7c0 3.7-3.2 6.9-7 6.9zm31.7-6.9h-5.8c-.3 0-.6.2-.6.6v2.4c0 .3.2.5.6.5h2.4V83c-.6.2-1.9.8-3.6.8-3.8 0-6.8-3.2-6.8-6.9 0-3.8 3-7 6.8-7 1.7 0 3.3.6 4.6 1.8.3.2.5.2.8 0l1.9-2c.2-.2.2-.6 0-.8-2.1-1.8-4.7-2.8-7.4-2.8-6 0-10.9 4.9-10.9 10.9 0 6.1 4.8 10.8 10.9 10.8 4.4 0 7.5-2 7.5-2 .1-.1.2-.2.2-.5v-7.8c-.1-.3-.3-.6-.6-.6zm14.5-11c-6.1 0-10.9 4.9-10.9 10.9 0 6.1 4.8 10.9 10.9 10.9 6.1 0 10.9-4.8 10.9-10.9 0-6-4.8-10.9-10.9-10.9zm0 17.9c-3.8 0-6.9-3.1-6.9-6.9 0-3.8 3.1-7 6.9-7s7 3.2 7 7c0 3.7-3.2 6.9-7 6.9z"></path>
        </svg>
      {%- endif -%}
        </div>
    {% endcapture %}

    <{% if block.settings.link != blank %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="logo--item" {{ block.shopify_attributes }} >
      {{ logo }}
    </{% if block.settings.link != blank %}a{% else %}div{% endif %}>

  {% endfor %}
{% endcapture %}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ containerClass }}">
    <div class="logo-list--main {{ section.settings.bg_layout }}-background">
      {%- if section.settings.heading != blank or section.settings.svg_text != blank -%}
        <div class="logo-list--header">
          <variety-heading class="section--header text-{{ section.settings.content_alignment }}">
            <div class="section--header-inner">
              {%- if section.settings.heading != blank -%}
                {%- capture markersPrefix -%}
                  <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                {%- endcapture -%}
                {%- capture markersSuffix -%}
                  </span>
                {%- endcapture -%}
              <{{ section.settings.seo_heading }} class="section--heading {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
              </{{ section.settings.seo_heading }}>
              {% endif %}
            </div>
          </variety-heading>
          {% if section.settings.svg_text != blank %}
          <div class="logo-list--right-icon">
            <div class="logo-list--right-icon-outer">
              <div class="logo-list--right-icon-inner">
                <svg class="badge__emoji" width="86" height="86" viewBox="0 0 86 86" fill="none">
                  <path d="M85.9974 27.7066L78.4547 15.2934L50.56 30.5869V0H35.44V30.5869L7.54534 15.2934L0 27.7066L27.9018 43L0.00212688 58.2934L7.5451 70.7066L35.44 55.4131V86H50.56V55.4131L78.4544 70.7066L86 58.2934L58.0982 43L85.9974 27.7066Z" fill="currentColor"></path>
                </svg>
                {% assign rotate_text = section.settings.svg_text %}
                {% assign text_length = rotate_text | size %}
                {% for i in (0..text_length) %}
                  <span class="text--char" style="--char_rotate: {{ i | times: 360 | divided_by: text_length }}deg">
                    {{- rotate_text | slice: i, 1 -}}
                  </span>
                {% endfor %}
              </div> 
            </div>
          </div>
          {% endif %}
        </div>
      {% endif %}
      <div
        class="logo-list--wrapper {{ section.settings.style }}{% if section.settings.card_height %} images-equal-height{% endif %}{% if section.settings.style == 'marquee' %} {{ section.settings.marquee_direction }}-direction{% endif %}{% if section.settings.style == 'stacked' and section.settings.mobile_swipe == true %} mobile-swipe{% endif %}"
        {% if section.settings.style == 'marquee' %}
          data-marquee-speed="{{ section.settings.scrolling_speed }}"
          data-marquee-speed-mobile="{{ section.settings.scrolling_speed_mobile }}"
        {% endif %}
        >
        {% capture logo_wrapper %}
          {% liquid 
            if section.blocks.size >= 10 
            assign limit = section.blocks.size | divided_by : section.blocks.size | times : 5
            elsif  section.blocks.size == 1
            assign limit = section.blocks.size | times : 9
            else
            assign limit = section.blocks.size | times : 4 
            endif
          %}
          {% for i in (1..limit) %}
            <div class="logo-list--wrapper-inner">
              {{ loopedContent }}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if section.settings.style == 'marquee' %}
          {{ logo_wrapper }}
        {% else %}
          {{ loopedContent }}
        {% endif %}
      </div>
      {% unless section.settings.style == 'stacked' %}
        {% if section.settings.duplicate_marque %}
          {%- liquid
            if section.settings.marquee_direction == 'ltr'
              assign marquee_direction = 'rtl'
            elsif section.settings.marquee_direction == 'rtl'
              assign marquee_direction = 'ltr'
            endif
          %}
          <div
            class="logo-list--wrapper {% if section.settings.card_height %}images-equal-height {% endif %} {{ section.settings.style }} {{ marquee_direction }}-direction {% if section.settings.style == 'stacked' and section.settings.mobile_swipe == true %} logo-list--mobile-swipe{% endif %}"
            {% if section.settings.style == 'marquee' %}
              data-marquee-speed="{{ section.settings.scrolling_speed }}"
              data-marquee-speed-mobile="{{ section.settings.scrolling_speed_mobile }}"
            {% endif %}
            >
            {{ logo_wrapper }}
          </div>
        {% endif %}
      {% endunless %}
    </div>
  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
      --animation_speed: {{ section.settings.scrolling_speed }}s;
      --column_gap: {{ section.settings.column_gap }}px;
      --column-count:{{ section.settings.column_count_desktop }};
      --top_spacing: {{ section.settings.top_space_desktop }}px;
      --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
      --image_overlay_heading: {{ section.settings.heading_color }};
      --text_color: {{ section.settings.description_color }};
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --animation_speed: {{ section.settings.scrolling_speed_mobile }}s;
        --column-count:{{ section.settings.column_count_mobile }};
        --top_spacing: {{ section.settings.top_space_mobile }}px !important;
        --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
  {% for block in section.blocks %}
    #block-{{ block.id }}{
      --logo_width: {{ block.settings.image_width }}%;
    }
  {% endfor %}
</style>

