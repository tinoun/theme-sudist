{% if section.index <= 2 %}
  {{ 'main-product.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'main-product.css' | asset_url | stylesheet_tag }}
{% liquid
  assign currentVariant = product.selected_or_first_available_variant
  assign product_form_id = 'main-product-form-' | append: section.id | append: '-' | append: product.id
  assign pdp_layout_style = section.settings.layout_style
  if pdp_layout_style == 'layout_3' and product.gift_card?
    assign pdp_layout_style = 'layout_2'
  endif
%}

{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{% render 'product-media-zoom', product: product, section: section, currentVariant: currentVariant %}

<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }}">
  {% render 'product-details',
    section: section,
    product: product,
    pdp_layout_style: pdp_layout_style,
    currentVariant: currentVariant,
    product_form_id: product_form_id,
    source: 'main-product'
  %}
</div>

{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
{%- endif -%}

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

{%- comment -%}
  =====================================================
  STRUCTURED DATA / JSON-LD POUR GOOGLE RICH RESULTS
  Corrigé avec priceValidUntil et aggregateRating
  =====================================================
{%- endcomment -%}
{% unless settings.seo_microdata %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 500 | json }},
      "url": "{{ shop.url }}{{ product.url }}",
      "productID": {{ product.id | json }},
      {% if currentVariant.sku != blank %}
      "sku": {{ currentVariant.sku | json }},
      {% endif %}
      {% if product.barcode != blank %}
      "gtin": {{ product.barcode | json }},
      {% elsif currentVariant.barcode != blank %}
      "gtin": {{ currentVariant.barcode | json }},
      {% endif %}
      "image": [
        {% for image in product.images limit: 5 %}
          "https:{{ image | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | default: shop.name | json }}
      },
      {% if product.variants.size > 1 %}
      "offers": {
        "@type": "AggregateOffer",
        "url": "{{ shop.url }}{{ product.url }}",
        "priceCurrency": "{{ shop.currency }}",
        "lowPrice": "{{ product.price_min | divided_by: 100.0 }}",
        "highPrice": "{{ product.price_max | divided_by: 100.0 }}",
        "offerCount": {{ product.variants.size }},
        "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
      }
      {% else %}
      "offers": {
        "@type": "Offer",
        "url": "{{ shop.url }}{{ product.url }}",
        "priceCurrency": "{{ shop.currency }}",
        "price": "{{ currentVariant.price | divided_by: 100.0 }}",
        "priceValidUntil": "{% assign next_year = 'now' | date: '%Y' | plus: 1 %}{{ next_year }}-12-31",
        "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition",
        "seller": {
          "@type": "Organization",
          "name": {{ shop.name | json }}
        }
      }
      {% endif %}
      {% comment %} Judge.me Reviews Integration {% endcomment %}
      {% if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value != blank %}
      ,"aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ product.metafields.reviews.rating.value | round: 1 }}",
        "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
        "bestRating": "5",
        "worstRating": "1"
      }
      {% elsif product.metafields.judgeme.rating != blank %}
      ,"aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ product.metafields.judgeme.rating | round: 1 }}",
        "reviewCount": "{{ product.metafields.judgeme.review_count | default: 1 }}",
        "bestRating": "5",
        "worstRating": "1"
      }
      {% endif %}
    }
  </script>
{% endunless %}

<style>
  #shopify-section-{{ section.id }} {
    --top_spacing: {{ section.settings.top_space_desktop }}px;
    --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    --card_radius: {{ section.settings.sticky_option_radius }}px;
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --top_spacing: {{ section.settings.top_space_mobile }}px !important;
      --bottom_spacing: {{ section.settings.bottom_space_mobile }}px !important;
    }
  }
</style>
 {% render 'product-structured-data', product: product %}

{% comment %} ATC POPUP {% endcomment %}
{% for block in section.blocks %}
  {% if block.type == 'atc_popup' %}
    {% render 'add-to-cart-popup', block: block, section: section, product: product %}
  {% endif %}
{% endfor %}
<script src="{{ 'atc-popup-interceptor.js' | asset_url }}" defer></script>

