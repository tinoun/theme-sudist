      },
      {
        "type": "select",
        "id": "transparent_header",
        "label": "t:sections.header.settings.transparent_header.label",
        "default": "both-transparent",
        "options": [
          {
            "label": "t:sections.header.settings.transparent_header.desktop-transparent.label",
            "value": "desktop-transparent"
          },
          {
            "label": "t:sections.header.settings.transparent_header.mobile-transparent.label",
