      {
        "type": "select",
        "id": "header_height",
        "default": "large",
        "label": "Height",
        "options": [
          {
            "value": "small",
            "label": "t:sections.header.settings.main_menu_font_size.small.label"
          },
          {
            "value": "medium",
            "label": "t:sections.header.settings.main_menu_font_size.medium.label"
          },
          {
            "value": "large",
            "label": "t:sections.header.settings.main_menu_font_size.large.label"
          }
        ]
      },
      {
        "type": "select",
        "id": "sticky_header_type",
        "label": "t:sections.header.settings.sticky_header_type.label",
        "default": "sticky-scroll-up",
        "options": [
          {
            "label": "t:sections.header.settings.sticky_header_type.sticky-none.label",
            "value": "sticky-none"
          },
          {
            "label": "t:sections.header.settings.sticky_header_type.sticky-scroll-up.label",
            "value": "sticky-scroll-up"
          },
