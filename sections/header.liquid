{{ 'header.css' | asset_url | preload_tag: as: 'style' }}
{{ 'header.css' | asset_url | stylesheet_tag }}
{% liquid
  assign isHeaderTransparentHomepage = false
  assign isHeaderTransparentOtherPage = false
  assign isHeaderTransparent = ''
  assign isTransparentBlur = false
  assign transparent_spacing_zero = false

  assign otherTemplates = section.settings.transparent_other_page | split: ','
 
  if template == 'index' and section.settings.transparent_home_page
    assign isHeaderTransparentHomepage = true
  endif

  if section.settings.transparent_other_page contains request.page_type  
    assign isHeaderTransparentOtherPage = true
  endif

  if isHeaderTransparentOtherPage or isHeaderTransparentHomepage
    assign isTransparentBlur = true
    assign transparent_spacing_zero = true
    assign isHeaderTransparent = section.settings.transparent_header
    if isHeaderTransparent == 'both-transparent' 
      assign isHeaderTransparent = 'desktop-transparent mobile-transparent'
    endif
  endif
  

%}

{% capture menusListBox %} 
  <div class="header--navigation-main" data-menus-container>
    {% liquid
      if section.settings.menu != blank
        render 'header-navigation', section: section
      endif
    %}
  </div>
  {% capture noJsLinks %}
      {% for link in section.settings.menu.links %}
        <li class="">
          <a class="header--menu-link" href="{{ link.url }}">{{ link.title }}</a>
        </li>
        
        {% if link.links != blank %}
          {% for childlink in link.links %}
            <li class="child-link">
              <a class="header--menu-link" href="{{ childlink.url }}">{{ childlink.title }}</a>
            </li>
    
            {% if childlink.links != blank %}
              {% for grandchildlink in childlink.links %}
                <li class="grandchild-link">
                  <a class="header--menu-link" href="{{ grandchildlink.url }}">{{ grandchildlink.title }}</a>
                </li>
              {% endfor %}
            {% endif %}
            
          {% endfor %}
        {% endif %}
      {% endfor %}
    {% endcapture %}
    
    <div class="no-js-menu">
      <nav>
        <ul class="">
          {{ noJsLinks }}
        </ul>
      </nav>
    </div> 
{% endcapture %}

<div class="{{ section.settings.section_container_width }}">
<{% if section.settings.sticky_header_type == 'sticky-scroll-up' %}sticky-on-scroll{% elsif section.settings.sticky_header_type == 'sticky-always' %}sticky-always{% else %}div{% endif %}
      class="header style-{{ section.settings.header_style }} header-height-{{ section.settings.header_height }} {{ section.settings.sticky_header_type }}{% unless section.settings.header_style == 'half-width-menu' %} border-{{ section.settings.seaperate_line }}{% endunless %}{% if section.settings.header_style != 'half-width-menu' %} shadow-{{ section.settings.header_shadow }}{% endif %}{% if isHeaderTransparent != blank %} {{ isHeaderTransparent }}{% endif %}{% if isTransparentBlur and section.settings.is_transparent_blur %} has-transparent-blur{% endif %}"
      id="{{ section.id }}"
      data-logo={{ section.settings.hide_logo }}
      data-header-view="{{ section.settings.header_style }}"
      data-header-sticky-type="{{ section.settings.sticky_header_type }}"
      data-top-spacing-desktop="{{ section.settings.top_space_desktop }}" 
      data-bottom-spacing-desktop="{{ section.settings.bottom_space_desktop }}" 
      data-top-spacing-mobile="{{ section.settings.top_space_mobile }}" 
      data-bottom-spacing-mobile="{{ section.settings.bottom_space_mobile }}"
      data-header-section
  >
  <div class="{% if section.settings.section_container_width == 'no-container' %}container-fullwidth{% else %}custom-container{% endif %}"> 
    <div
      class="header--wrapper {{ section.settings.header_style }}"
      data-header-navigation
      {% unless section.settings.header_style == 'half-width-menu' %}
      data-header-wrapper{% endunless %}>
      {% if section.settings.menu != blank and section.settings.header_style contains 'hamburger-menu' %}
        <button
          class="hamburger--toggler hamburger-icon"
          aria-label="Toggle hamburger menu"
          data-hamburger-toggler>
          <div class="hamburger--toggler-icon">
            <span class="line line-1"></span>
            <span class="line line-2"></span>
            <span class="line line-3"></span>
          </div>
        </button>
      {% endif %}
      {% if section.settings.menu != blank %}
        <button
          class="mobile-toggler hamburger--toggler"
          aria-label="Toggle mobile menu"
          data-mobile-toggler>
          <div class="hamburger--toggler-icon">
            <span class="line line-1"></span>
            <span class="line line-2"></span>
            <span class="line line-3"></span>
          </div>
        </button>
      {% endif %}
      <a
        class="header--logo"
        href="{{ routes.root_url }}"
        aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {%- assign image_2x_size = section.settings.desktop_logo_width | times: 2 | at_most: 2560 -%}
          <img
            class="header--logo-img"
            srcset="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }} 1x, {{ section.settings.logo | image_url: width: image_2x_size }} 2x"
            src="{{ section.settings.logo | image_url: width: section.settings.desktop_logo_width }}"
            width="{{ section.settings.desktop_logo_width }}"
            height="{{ section.settings.desktop_logo_width | divided_by : section.settings.logo.aspect_ratio | round }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}">
          {% if section.settings.transparent_header %}
            {% liquid
              if section.settings.alternate_logo != blank
                assign transparent_image = section.settings.alternate_logo
              else
                assign transparent_image = section.settings.logo
              endif
            %}
            {%- assign image_2x_size = section.settings.desktop_logo_width | times: 2 | at_most: 2560 -%}
            {% comment %} <img
              class="header--logo-img transparent-logo-img"
              srcset="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }} 1x, {{ transparent_image | image_url: width: image_2x_size }} 2x"
              src="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }}"
              width="{{ section.settings.desktop_logo_width }}"
              height="{{ section.settings.desktop_logo_width | divided_by : transparent_image.aspect_ratio | round }}"
              alt="{{ transparent_image.alt | default: shop.name | escape }}"> {% endcomment %}
              <link rel="preload" as="image" href="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }}" />
            <img
              class="header--logo-img transparent-logo-img"
              srcset="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }} 1x, {{ transparent_image | image_url: width: image_2x_size }} 2x"
              src="{{ transparent_image | image_url: width: section.settings.desktop_logo_width }}"
              width="{{ section.settings.desktop_logo_width }}"
              height="{{ section.settings.desktop_logo_width | divided_by : transparent_image.aspect_ratio | round }}"
              alt="{{ transparent_image.alt | default: shop.name | escape }}"
              loading="eager"
            >

          {% endif %}

        {% else %}
          <span class="header--logo-text text-medium">{{ shop.name }}</span>
        {% endif %}
      </a>
      {% unless section.settings.header_style == 'half-width-menu' or section.settings.header_style contains 'hamburger-menu' %}
        {{ menusListBox }}
      {% endunless %}
      <div class="header--right" data-header-right>
        {% if section.settings.header_style == 'half-width-menu' %}
          {{ menusListBox }}
        {% endif %}
        {% render 'header-icons'
          , section: section %}
        {% liquid
 

          assign isAccountDrawer = true

          if request.page_type contains 'customers'
            assign isAccountDrawer = false
          endif

          if customer and settings.account_behaviour == 'drawer'
            assign isAccountDrawer = false
          endif


          if section.settings.header_style == 'half-width-menu'
            if request.page_type != 'cart' and settings.cart_behaviour == 'drawer'
              render 'cart-drawer'
            endif
            render 'search-drawer'
          endif
          if isAccountDrawer
            render 'account-drawer'
          endif
        %}
      </div>
    </div>

    {% liquid
      if section.settings.header_style contains 'hamburger-menu'
        render 'header-hamburger-menu' section: section
      endif
    %}
  </div>
</{% if section.settings.sticky_header_type == 'sticky-scroll-up' %}sticky-on-scroll{% elsif section.settings.sticky_header_type == 'sticky-always' %}sticky-always{% else %}div{% endif %}>
</div>
{% liquid
  unless section.settings.header_style == 'half-width-menu'
    if request.page_type != 'cart' and settings.cart_behaviour == 'drawer'
      render 'cart-drawer'
    endif
    render 'search-drawer'
  endunless

  if section.settings.is_quick_menu and section.settings.quick_menu != blank and section.settings.sticky_header_type == 'sticky-none'
    assign showStatus = false
    if request.page_type == 'index' and section.settings.quick_menu_home_page
      assign showStatus = true
    endif
    if section.settings.quick_menu_other_page != blank and section.settings.quick_menu_other_page contains request.page_type
      assign showStatus = true
    endif
    if showStatus
      render 'short-menu', section: section
    endif
  endif
  render 'mobile-menu-drawer', section: section
%}

<style>
  .short-menu {
    transition: opacity 0.5s ease-in-out;
    opacity: 1;
  }

  .short-menu.fade-out {
    opacity: 0;
  }

  .short-menu.fade-in {
    opacity: 1;
  }
  .section-header {
    --logo_width: {{ section.settings.desktop_logo_width }}px;
    --transparent_color: {{ section.settings.transparent_color }};
    --transparent_opacity: {{ section.settings.overlay_opacity }};
    --image_bg: {{ settings.header_image_bg }};
    --image_overlay_heading: {{ settings.header_image_overlay_heading }};
    --transparent_border_color: {{ section.settings.transparent_border_color.red }}, {{ section.settings.transparent_border_color.green }}, {{ section.settings.transparent_border_color.blue }};
    --transparent_background: {{ section.settings.overlay_background.red }}, {{ section.settings.overlay_background.green }}, {{ section.settings.overlay_background.blue }};
    --image_overlay_background: {{ settings.header_image_overlay_background.red }}, {{ settings.header_image_overlay_background.green }}, {{ settings.header_image_overlay_background.blue }};

    {% if transparent_spacing_zero and section.settings.transparent_header == 'desktop-transparent' or section.settings.transparent_header == 'both-transparent' %}
      --header_top_spacing: 0px;
      --header_bottom_spacing: 0px;
    {% else %}
      --header_top_spacing: {{ section.settings.top_space_desktop }}px;
      --header_bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
    {% endif %}

    {% unless section.settings.section_container_width == 'no-container' %}
      --header_radius: {{ section.settings.corner_radius }}px;  
    {% endunless %}
  }
  #shopify-section-{{ section.id }} .cart--count {
    --header_background: {{ settings.header_bg_color }};
  }

  @media (max-width: 767px) {
    .section-header {
      --logo_width: {{ section.settings.mobile_logo_width }}px;
      {% if transparent_spacing_zero and section.settings.transparent_header == 'mobile-transparent' or section.settings.transparent_header == 'both-transparent' %}
        --header_top_spacing: 0px;
        --header_bottom_spacing: 0px;
      {% else %}
        --header_top_spacing: {{ section.settings.top_space_mobile }}px;
        --header_bottom_spacing: {{ section.settings.bottom_space_mobile }}px;
      {% endif %}

      {% unless section.settings.section_container_width == 'no-container' %}
      {% if section.settings.corner_radius > 20 %}
      --header_radius: {{ section.settings.corner_radius | divided_by: 2 }}px;  
      {% else %}
      --header_radius: {{ section.settings.corner_radius }}px;  
      {% endif %}
      {% endunless %}
    }
  }
</style>
<script src="{{ 'header.js' | asset_url }}" defer></script>
{% unless settings.seo_microdata %} 
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      {% if section.settings.logo %}
        "logo": {{ section.settings.logo | image_url: width: 500 | prepend: "https:" | json }},
      {% endif %}
      "sameAs": [
        {{ settings.social_twitter_link | json }},
        {{ settings.social_facebook_link | json }},
        {{ settings.social_pinterest_link | json }},
        {{ settings.social_instagram_link | json }},
        {{ settings.social_tiktok_link | json }},
        {{ settings.social_tumblr_link | json }},
        {{ settings.social_snapchat_link | json }},
        {{ settings.social_youtube_link | json }},
        {{ settings.social_vimeo_link | json }}
      ],
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>

  {%- if request.page_type == 'index' -%}
    {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ potential_action_target | json }},
          "query-input": "required name=search_term_string"
        },
        "url": {{ request.origin | append: page.url | json }}
      }
    </script>
  {%- endif -%}
{% endunless %}

{% schema %}
  {
    "name": "t:sections.header.name",
    "class": "section-header section-spacing",
    "tag": "header",
    "settings": [
      {
        "type": "select",
        "id": "section_container_width",
        "label": "t:sections.all.section_container_width.label",
        "default": "no-container",
        "options": [
          {
            "label": "t:sections.all.section_container_width.container-sm.label",
            "value": "container-sm"
          },
          {
            "label": "t:sections.all.section_container_width.container.label",
            "value": "container"
          },
          {
            "label": "t:sections.all.section_container_width.container-md.label",
            "value": "container-md"
          },
          {
            "label": "t:sections.all.section_container_width.container-fullwidth.label",
            "value": "container-fullwidth"
          },
          {
            "label": "t:settings_schema.layout.settings.container_width.container-narrow.label",
            "value": "container-narrow"
          },
          {
            "label": "t:sections.all.section_container_width.no-container.label",
