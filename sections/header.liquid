          }
        ]
      },
      {
        "type": "range",
        "id": "corner_radius",
        "label": "t:settings_schema.global.settings.corner_radius.label",
        "default": 8,
        "min": 0,
        "max": 40,
        "unit": "px",
        "step": 1,
        "visible_if": "{{ section.settings.section_container_width != 'no-container' }}"
      },
      {
        "type": "select",
        "id": "header_style",
        "label": "t:sections.header.settings.header_style.label",
        "default": "logo-left-menu-center",
        "options": [
          {
            "label": "t:sections.header.settings.header_style.logo-left-menu-center.label",
            "value": "logo-left-menu-center"
          },
          {
            "label": "t:sections.header.settings.header_style.logo-left-menu-right.label",
            "value": "logo-left-menu-right"
          },
          {
            "label": "t:sections.header.settings.header_style.logo-left-menu-left.label",
            "value": "logo-left-menu-left"
          },
          {
            "label": "t:sections.header.settings.header_style.logo-center-menu-left.label",
            "value": "logo-center-menu-left"
          },
          {
            "label": "t:sections.header.settings.header_style.half-width-menu.label",
            "value": "half-width-menu"
          },
          {
            "label": "t:sections.header.settings.header_style.hamburger-menu-logo-left.label",
