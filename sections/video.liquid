{% if section.index <= 2 %}
  {{ 'video.css' | asset_url | preload_tag: as: 'style' }}
{% endif %}
{{ 'video.css' | asset_url | stylesheet_tag }}
{% liquid
  if section.settings.section_container_width == 'global'
    assign containerClass = settings.container_width
  else
    assign containerClass = section.settings.section_container_width
  endif

   if section.settings.video_height == 'adapt'
   assign mediaDesktopClass = "d-media-adapt"
   else
   assign mediaDesktopClass = "d-media-fixed"
   endif

   if section.settings.mobile_video_height == 'adapt'
    assign mediaMobileClass = "m-media-adapt"
    else
   assign mediaMobileClass = "m-media-fixed"
   endif
%}
<div class="section-wrapper section-spacing scheme-{{ section.settings.color_scheme }} section-{{ section.settings.section_background }}">
  <div class="{{ containerClass }}"{% if section.settings.play_button == 'floated' %} cursor-class="video"{% endif %}>
    <div class="video--container autoplay-{{ section.settings.autoplay }} video-{% if section.settings.video == blank and section.settings.video_url == blank %}false{% else %}true{% endif %}" data-video-main-wrapper data-video-play-button>
      <div class="video--wrapper pos-relative{% if section.settings.content_visibility == 'always'%} media-overlay{% endif %}" data-video-wrapper>
        {% if section.settings.autoplay == 'false'  %}
          <div class="video-cover-image{% if section.settings.content_visibility == 'hidden'%} media-overlay{% endif %}" data-video-overlay>
            {%- liquid
                assign poster = section.settings.video.preview_image 
                assign cover_image = section.settings.cover_image
                if cover_image != null
                  assign poster = cover_image
                endif
              -%}
              {% if poster != null %}
                {% render 'lazy-image', image: poster, class: '' %}
              {% else %}
                {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
              {% endif %}
          </div>
          <div class="video--content-button d-block d-md-none" data-mobile-content-button>
            <div class="pos-relative video-play-button js-load-media" role="button" aria-label="Play button" data-play-button>
              <svg width="33" height="38" viewBox="0 0 33 38" fill="none">
                <path d="M3.3001 38C2.69618 38 2.09556 37.81 1.56425 37.4338C1.08631 37.0923 0.691864 36.6161 0.418164 36.0503C0.144463 35.4845 0.000544022 34.8476 0 34.1999V3.79939C0 2.48076 0.594018 1.25714 1.56425 0.565529C2.04324 0.226415 2.58926 0.0331475 3.15097 0.00389818C3.71268 -0.0253512 4.27163 0.110378 4.77524 0.398326L31.176 15.5986C31.7242 15.9148 32.1851 16.4004 32.5073 17.001C32.8294 17.6017 33 18.2937 33 18.9997C33 19.7056 32.8294 20.3977 32.5073 20.9983C32.1851 21.599 31.7242 22.0846 31.176 22.4007L4.77524 37.601C4.31323 37.867 3.80172 38 3.3001 38Z" fill="currentColor"/>
              </svg>
              <span class="video-play-text">
                <svg viewBox="0 0 80 80"><defs><path id="qodef-text-circle-6662e7fed9f58" d="M0.5,40C0.5,18.18,18.18,0.5,40,0.5S79.5,18.18,79.5,40S61.82,79.5,40,79.5S0.5,61.82,0.5,40z" fill="none"></path></defs><g><text><textPath xlink:href="#qodef-text-circle-6662e7fed9f58" textLength="300%" lengthAdjust="spacing">
                  {{ section.settings.play_button_text }}  </textPath></text></g></svg>
              </span>
            </div>
        </div>
        {% endif %}
        <div class="media {{ mediaDesktopClass }} {{ mediaMobileClass }}">
          <deferred-media-video class="deferred-media autoplay-status-{{ section.settings.autoplay }}" id="deffered-{{ section.settings.video_url.type }}" data-type="{{ section.settings.video_url.type }}"  data-play-behaviour="{{ section.settings.play_button }}">
              
                  {% if section.settings.video != blank %}
                      <video class="videoBackgroundFile"
                      {% if section.settings.autoplay == 'true' %}
                          autoplay muted loop playsinline
                      {% else %}
                          controls
                      {% endif %}
                      data-autoplay="{{ section.settings.autoplay }}"
                     
                      
                      >
                          <source src="{% if section.settings.video.sources[0].url contains 'mp4' %}{{ section.settings.video.sources[0].url -}}{% else %}{{ section.settings.video.sources[1].url -}}{% endif %}" type="video/mp4" >
                      </video>
                  {% elsif section.settings.video_url != blank %}
                      {%- if section.settings.video_url.type == 'youtube' -%}
                          {% if section.settings.autoplay == 'true' %}
                              <div class="youtubeVideo video_full_width" id="videoBanner-{{ section.id }}" data-id="{{ section.settings.video_url.id }}"></div>
                          {% else %}
                              <iframe
                                  src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay={% if section.settings.autoplay == 'true' %}1{% else %}0{% endif %}&mute={% if section.settings.autoplay == 'true' %}1{% else %}0{% endif %}&loop=1&controls={% if section.settings.autoplay == 'true' %}0{% else %}1{% endif %}&rel=0&showinfo=0&enablejsapi=1&playlist={{ section.settings.video_url.id }}"
                                  class="youtube_video"
                                  {% if section.settings.autoplay == 'true' %}
                                      allow="autoplay; encrypted-media"
                                  {% endif %}
                                  frameborder="0"
                                  allowfullscreen
                                  data-autoplay="{{ section.settings.autoplay }}"
                                  title="{{ section.settings.heading | escape }}"
                                  >
                              </iframe>
                          {% endif %}
                      {%- elsif section.settings.video_url.type == 'vimeo' -%}
                          <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?{% if section.settings.autoplay == 'true' %}autoplay=1&loop=1&autopause=0&muted=1{% else %}&autoplay=0{% endif %}{% if section.settings.autoplay == 'false' %}&background=0{% endif %}"
                              class="vimeo_video"
                              {% if section.settings.autoplay == 'true' %}
                              allow="autoplay; fullscreen encrypted-media"
                              {% endif %}
                              data-autoplay="{{ section.settings.autoplay }}"
                              allowfullscreen
                              title="{{ section.settings.heading | escape }}"
                          ></iframe>
                      {%- endif -%}
                  {% endif %}
             
          </deferred-media-video>
        </div>
      </div>
      {% if section.settings.heading != blank or section.settings.description != blank or section.settings.autoplay == 'false' %}
      <div class="video--content-wrapper container-fullwidth pos-relative{% if section.settings.heading == blank or section.settings.description == blank %} empty-content{% endif %}" data-content-visibility="{{ section.settings.content_visibility }}" data-autoplay="{{ section.settings.autoplay }}" data-content-wrapper>
        <div class="video--content width-100 height-100 text-{{ section.settings.alignment }}">
          <div class="video--content-inner width-100 {{ section.settings.content_width }}-width">
            {% if section.settings.autoplay == 'false' %}
                {% if section.settings.video != blank or section.settings.video_url != blank %}
                    <div class="video--content-button{% if section.settings.play_button == 'floated' %} hidden{% else %} d-none d-md-block{% endif %}" data-content-button>
                        <div class="pos-relative video-play-button js-load-media" role="button" aria-label="Play button" data-play-button>
                          <svg width="33" height="38" viewBox="0 0 33 38" fill="none">
                            <path d="M3.3001 38C2.69618 38 2.09556 37.81 1.56425 37.4338C1.08631 37.0923 0.691864 36.6161 0.418164 36.0503C0.144463 35.4845 0.000544022 34.8476 0 34.1999V3.79939C0 2.48076 0.594018 1.25714 1.56425 0.565529C2.04324 0.226415 2.58926 0.0331475 3.15097 0.00389818C3.71268 -0.0253512 4.27163 0.110378 4.77524 0.398326L31.176 15.5986C31.7242 15.9148 32.1851 16.4004 32.5073 17.001C32.8294 17.6017 33 18.2937 33 18.9997C33 19.7056 32.8294 20.3977 32.5073 20.9983C32.1851 21.599 31.7242 22.0846 31.176 22.4007L4.77524 37.601C4.31323 37.867 3.80172 38 3.3001 38Z" fill="currentColor"/>
                          </svg>
                          <span class="video-play-text">
                            <svg viewBox="0 0 80 80"><defs><path id="qodef-text-circle-6662e7fed9f58" d="M0.5,40C0.5,18.18,18.18,0.5,40,0.5S79.5,18.18,79.5,40S61.82,79.5,40,79.5S0.5,61.82,0.5,40z" fill="none"></path></defs><g><text><textPath xlink:href="#qodef-text-circle-6662e7fed9f58" textLength="300%" lengthAdjust="spacing">
                              {{ section.settings.play_button_text }}  </textPath></text></g></svg>
                          </span>
                        </div>
                    </div>
                {% endif %}
            {% endif %} 
            {% if section.settings.heading != blank or section.settings.description != blank %}
                <variety-heading class="section--header">
                    <div class="section--header-inner">
                        {% if section.settings.heading != blank %}
                            {%- capture markersPrefix -%}
                                <span class="markers-text {{ section.settings.markers_font }} {{ section.settings.markers_text }}">
                            {%- endcapture -%}
                            {%- capture markersSuffix -%}
                                </span>
                            {%- endcapture -%}

                            <{{ section.settings.seo_heading }} class="section--heading heading-font {{ section.settings.heading_size }}" {% if settings.is_layout_animation %}data-saos="{{ settings.heading_animation }}" {% endif %}>
                              {{ section.settings.heading | replace: "[", markersPrefix | replace: "]", markersSuffix | replace: "++", "<br>" }}
                            </{{ section.settings.seo_heading }}>
                        {% endif %}

                        {% if section.settings.description != blank %}
                        <p class="section--description {{ section.settings.description_size }}"  {% if settings.is_layout_animation %}data-saos="slide-up" {% endif %}>
                            {{ section.settings.description | newline_to_br }}
                        </p>
                        {% endif %}
                    </div>
                </variety-heading>
            {% endif %}
          </div>         
        </div>
      </div>
    {% endif %}
      {% if section.settings.video != blank or section.settings.video_url != blank %}
        {% if section.settings.play_button == 'floated' and section.settings.autoplay == 'false' %}
          {% comment %} <div class="king_cursor king_animted">
          </div> {% endcomment %}
          <animated-cursor  class="king_cursor king_animted" data-animated-cursor></animated-cursor>
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
        --top_spacing: {{ section.settings.top_space_desktop }}px;
        --bottom_spacing: {{ section.settings.bottom_space_desktop }}px;
        --content_position: {{ section.settings.content_position }};
	      --content_alignment: {{ section.settings.content_alignment }};
        --image_overlay_opacity: {{ section.settings.overlay_opacity }};
        --object_fit: {{ section.settings.object_fit }};
    }
    
    {% if section.settings.video_height == 'adapt' %}
        #shopify-section-{{ section.id }}{
            --image_ratio: 56.25%;
            --media_height: 100%;
        }
    {% else %}
        #shopify-section-{{ section.id }}{
            --image_ratio:0;
            --media_height:{{ section.settings.video_height }};
        }
    {% endif %}
    @media only screen and (min-width:768px){
      #shopify-section-{{ section.id }} .section--heading,
      #shopify-section-{{ section.id }} .section--description {
          --heading_color: var(--image_overlay_heading);
          --text_color: var(--image_overlay_text);
      }
    }

    @media only screen and (max-width:767px){
        #shopify-section-{{ section.id }}{
            --top_spacing:{{ section.settings.top_space_mobile }}px;
            --bottom_spacing:{{ section.settings.bottom_space_mobile }}px;
        }
        {% if section.settings.mobile_video_height == 'adapt' %}
            #shopify-section-{{ section.id }}{
                --image_ratio: 56.25%;
                --media_height: 100%;
            }
        {% else %}
            #shopify-section-{{ section.id }}{
                --image_ratio:0;
                --media_height:{{ section.settings.mobile_video_height }};
            }
        {% endif %}
    }
    {% if section.settings.section_visibility == 'large' %}
        @media (max-width: 767px) {
            #shopify-section-{{ section.id }}{
                display: none !important;
            }
        }
    {% elsif section.settings.section_visibility == 'small' %}
        @media (min-width: 768px) {
            #shopify-section-{{ section.id }}{
                display: none !important;
            }
        }
    {% endif %}
</style>


{% schema %}
